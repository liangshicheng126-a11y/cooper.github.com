# 生产环境 backend/.env 模板（api.cooperliang.top）
# 复制到服务器：backend/.env 并填入真实密钥，勿提交 Git

PORT=3000
NODE_ENV=production

# 公网 API 根地址（签到二维码降级链接等）
API_PUBLIC_BASE=https://api.cooperliang.top

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=activity_miniapp
DB_USER=activity_app
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING
JWT_EXPIRES_IN=30d

# 微信小程序（须与开发者工具 AppID 一致）
WX_APP_ID=wxa909312a016c6847
WX_APP_SECRET=CHANGE_ME

WX_MINI_ENV_VERSION=release
CHECKIN_QR_MODE=minicode

TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_REGION=ap-guangzhou

COS_BUCKET=
COS_REGION=ap-guangzhou

AES_KEY=CHANGE_ME_32_CHAR_AES_KEY_HERE00

SMS_APP_ID=
SMS_SIGN_NAME=
SMS_TEMPLATE_VERIFY=

AI_POSTER_API_KEY=
AI_POSTER_API_URL=https://ark.cn-beijing.volces.com/api/v3/images/generations

ADMIN_OPENIDS=
AUTO_APPROVE_ACTIVITY_PUBLISH=0

LOG_LEVEL=info
