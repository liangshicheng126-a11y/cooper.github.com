<!-- custom-tab-bar/index.wxml -->
<view class="tab-bar {{animate ? 'tab-bar--visible' : ''}}">

  <!-- 毛玻璃主体 -->
  <view class="tab-bar__body">

    <!-- 顶部高光线 -->
    <view class="tab-bar__top-line"></view>

    <!-- 背景渐变光晕（中心对齐当前 Tab 区域中点） -->
    <view class="tab-bar__glow" style="left: {{glowCenterPx}}px;"></view>

    <!-- 滑动胶囊指示器（宽度与位置按 Tab 居中） -->
    <view
      class="tab-bar__indicator"
      style="width: {{indicatorW}}px; transform: translateX({{indicatorX}}px); opacity: {{indicatorVisible ? 1 : 0}};"
    ></view>

    <!-- Tab 内容行 -->
    <view class="tab-bar__row">
      <view
        wx:for="{{tabs}}"
        wx:key="index"
        class="tab-item {{selected === index ? 'tab-item--active' : ''}}"
        data-index="{{index}}"
        bindtap="onTabTap"
      >
        <!-- 图标区域 -->
        <view class="tab-icon-wrap">
          <!-- 活跃光晕 -->
          <view wx:if="{{selected === index}}" class="tab-glow"></view>

          <!-- 图标图片 -->
          <image
            class="tab-icon-img {{selected === index ? 'tab-icon-img--active' : ''}}"
            src="{{selected === index ? item.iconActive : item.icon}}"
            mode="aspectFit"
          />
        </view>

        <!-- 文字标签 -->
        <text class="tab-label">{{item.text}}</text>

        <!-- 激活指示点 -->
        <view wx:if="{{selected === index}}" class="tab-dot"></view>
      </view>
    </view>

  </view>

</view>
