<!-- custom-tab-bar/index.wxml -->
<view class="tab-bar {{animate ? 'tab-bar--visible' : ''}}">

  <!-- 毛玻璃主体 -->
  <view class="tab-bar__body">

    <!-- 顶部高光线 -->
    <view class="tab-bar__top-line"></view>

    <!-- 背景渐变光晕（跟随选中侧移动） -->
    <view class="tab-bar__glow" style="left: {{glowLeft}};"></view>

    <!-- 滑动胶囊指示器 -->
    <view class="tab-bar__indicator" style="transform: translateX({{indicatorX}}); opacity: {{indicatorVisible ? 1 : 0}};"></view>

    <!-- Tab 内容行 -->
    <view class="tab-bar__row">
      <view
        wx:for="{{tabs}}"
        wx:key="index"
        class="tab-item {{selected === index ? 'tab-item--active' : ''}}"
        data-index="{{index}}"
        bindtap="onTabTap"
      >
        <!-- 发现图标 -->
        <view wx:if="{{index === 0}}" class="icon-wrap">
          <view class="icon-compass {{selected === 0 ? 'icon--active' : ''}}">
            <view class="compass-ring compass-ring--outer"></view>
            <view class="compass-ring compass-ring--inner"></view>
            <view class="compass-needle"></view>
          </view>
          <view wx:if="{{selected === 0}}" class="icon-glow"></view>
        </view>

        <!-- 我的图标 -->
        <view wx:if="{{index === 1}}" class="icon-wrap">
          <view class="icon-profile {{selected === 1 ? 'icon--active' : ''}}">
            <view class="profile-head"></view>
            <view class="profile-body"></view>
          </view>
          <view wx:if="{{selected === 1}}" class="icon-glow"></view>
        </view>

        <text class="tab-label">{{item.text}}</text>
        <view wx:if="{{selected === index}}" class="tab-dot"></view>
      </view>
    </view>

  </view>

  <!-- 安全区 -->
  <view class="tab-bar__safe"></view>
</view>
