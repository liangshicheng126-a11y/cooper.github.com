/* custom-tab-bar/index.wxss · 白色毛玻璃底部导航栏 */

.tab-bar__body {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  height: calc(130rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);

  /* 白色毛玻璃 */
  background: rgba(255,255,255,0.84);
  backdrop-filter: blur(16px) saturate(180%);
  -webkit-backdrop-filter: blur(16px) saturate(180%);

  border-top: 1rpx solid rgba(255,255,255,1);
  box-shadow: 0 -2rpx 12rpx rgba(30,27,75,0.06);
  z-index: 1000;
  overflow: hidden;
}

/* ── 顶部细线（去掉大紫条观感） ── */
.tab-bar__top-line {
  position: absolute; top: 0; left: 0; right: 0;
  height: 1rpx;
  background: rgba(30,27,75,0.06);
}

/* ── 背景光晕：left 为 Tab 区域中点，配合 translateX(-50%) 真正居中 ── */
.tab-bar__glow {
  position: absolute; top: -48rpx;
  height: 140rpx; width: 200rpx; border-radius: 50%;
  opacity: 0.14; filter: blur(22px);
  transition: left 0.38s cubic-bezier(0.34,1.2,0.64,1), opacity 0.3s;
  transform: translateX(-50%);
  background: radial-gradient(circle, rgba(124,58,237,0.45) 0%, rgba(96,165,250,0.25) 55%, transparent 75%);
  pointer-events: none;
}

/* ── 滑动胶囊指示器 ── */
.tab-bar__indicator {
  position: absolute;
  left: 0;
  top: 8rpx;
  height: 112rpx;
  border-radius: 28rpx;
  box-sizing: border-box;
  background: rgba(124,58,237,0.07);
  border: 1rpx solid rgba(124,58,237,0.16);
  box-shadow: 0 2rpx 10rpx rgba(30,27,75,0.06), inset 0 1rpx 0 rgba(255,255,255,1);
  transition: transform 0.38s cubic-bezier(0.34,1.2,0.64,1),
              width 0.38s cubic-bezier(0.34,1.2,0.64,1);
  pointer-events: none; z-index: 0;
}

/* ── Tab 行 ── */
.tab-bar__row {
  position: relative; z-index: 1;
  display: flex; height: 130rpx;
}

/* ── 单个 Tab ── */
.tab-item {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 4rpx; position: relative;
  padding-top: 6rpx;
  transition: transform 0.18s;
}
.tab-item--animate { animation: tab-entry 0.4s cubic-bezier(0.34,1.4,0.64,1) both; }
.tab-item:active   { transform: scale(0.88); }

@keyframes tab-entry {
  from { transform: translateY(24rpx); opacity: 0; }
  to   { transform: translateY(0);     opacity: 1; }
}

/* ── 图标容器（相对定位，承载光晕） ── */
.tab-icon-wrap {
  position: relative;
  width: 56rpx; height: 56rpx;
  display: flex; align-items: center; justify-content: center;
}

/* ── 图标图片 ── */
.tab-icon-img {
  width: 52rpx; height: 52rpx;
  position: relative; z-index: 1;
  transition: transform 0.25s cubic-bezier(0.34,1.4,0.64,1), opacity 0.2s;
  opacity: 0.65;
}
.tab-icon-img--active {
  transform: scale(1.18) translateY(-2rpx);
  opacity: 1;
  filter: drop-shadow(0 2rpx 6rpx rgba(30,27,75,0.12));
}

/* ── 活跃光晕（图标背后） ── */
.tab-glow {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 76rpx; height: 76rpx; border-radius: 50%;
  background: radial-gradient(circle, rgba(124,58,237,0.14) 0%, transparent 72%);
  animation: glow-breathe 2.5s ease-in-out infinite;
  pointer-events: none; z-index: 0;
}
@keyframes glow-breathe {
  0%,100% { transform: translate(-50%,-50%) scale(1);   opacity: 1; }
  50%      { transform: translate(-50%,-50%) scale(1.3); opacity: 0.55; }
}

/* ── 文字标签 ── */
.tab-label {
  font-size: 22rpx; font-weight: 500;
  color: rgba(30,27,75,0.40);
  transition: color 0.2s, font-weight 0.2s;
  letter-spacing: 1rpx;
}
.tab-item--active .tab-label {
  color: #7c3aed; font-weight: 700;
}

/* ── 激活指示点 ── */
.tab-dot {
  width: 8rpx; height: 8rpx; border-radius: 50%;
  background: linear-gradient(135deg, #7c3aed, #2563eb);
  box-shadow: 0 0 4rpx rgba(91,33,182,0.25);
  animation: dot-in 0.25s cubic-bezier(0.34,1.5,0.64,1) both;
}
@keyframes dot-in {
  from { transform: scale(0); opacity: 0; }
  to   { transform: scale(1); opacity: 1; }
}
