/* custom-tab-bar/index.wxss · 简洁高级底部导航栏 */

.tab-bar__body {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  height: calc(130rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);

  background: rgba(255,253,248,0.97);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);

  border-top: 1rpx solid rgba(83,64,34,0.14);
  box-shadow: 0 -14rpx 34rpx rgba(83,64,34,0.10), 0 -2rpx 8rpx rgba(29,28,24,0.05);
  z-index: 1000;
  overflow: hidden;
}

/* ── 顶部细线（去掉大紫条观感） ── */
.tab-bar__top-line {
  position: absolute; top: 0; left: 0; right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(154,107,36,0.22), transparent);
}

/* ── 滑动胶囊指示器 ── */
.tab-bar__indicator {
  position: absolute;
  left: 0;
  top: 8rpx;
  height: 112rpx;
  border-radius: 28rpx;
  box-sizing: border-box;
  background: rgba(154,107,36,0.10);
  border: 1rpx solid rgba(154,107,36,0.22);
  box-shadow:
    0 8rpx 20rpx rgba(83,64,34,0.08),
    inset 0 1rpx 0 rgba(255,255,255,1);
  transition: transform var(--motion-medium) var(--ease-out),
              width var(--motion-medium) var(--ease-out);
  pointer-events: none; z-index: 0;
}

/* ── Tab 行 ── */
.tab-bar__row {
  position: relative; z-index: 1;
  display: flex; height: 130rpx;
}

/* ── 单个 Tab ── */
.tab-item {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 4rpx; position: relative;
  padding-top: 6rpx;
  transition: transform var(--motion-fast) var(--ease-out);
}
.tab-item--animate { animation: tab-entry var(--motion-medium) var(--ease-out) both; }
.tab-item:active   { transform: translateY(2rpx) scale(0.96); }

@keyframes tab-entry {
  from { transform: translateY(24rpx); opacity: 0; }
  to   { transform: translateY(0);     opacity: 1; }
}

/* ── 图标容器（相对定位，承载光晕） ── */
.tab-icon-wrap {
  position: relative;
  width: 56rpx; height: 56rpx;
  display: flex; align-items: center; justify-content: center;
}

/* ── 图标图片 ── */
.tab-icon-img {
  width: 52rpx; height: 52rpx;
  position: relative; z-index: 1;
  transition: transform var(--motion-medium) var(--ease-pop), opacity var(--motion-base), filter var(--motion-base);
  opacity: 0.65;
}
.tab-icon-img--active {
  transform: scale(1.08) translateY(-1rpx);
  opacity: 1;
  filter: none;
}

/* ── 文字标签 ── */
.tab-label {
  font-size: 22rpx; font-weight: 500;
  color: var(--text-muted);
  transition: color var(--motion-base), font-weight var(--motion-base);
  letter-spacing: 1rpx;
}
.tab-item--active .tab-label {
  color: var(--accent-text); font-weight: 700;
}

/* ── 激活指示点 ── */
.tab-dot {
  width: 8rpx; height: 8rpx; border-radius: 50%;
  background: var(--accent);
  box-shadow: none;
  animation: dot-in var(--motion-base) var(--ease-out) both;
}

@media (prefers-reduced-motion: reduce) {
  .tab-item--animate,
  .tab-dot {
    animation: none;
  }
  .tab-item,
  .tab-icon-img,
  .tab-bar__indicator {
    transition: opacity var(--motion-fast), color var(--motion-fast), background var(--motion-fast);
  }
}
@keyframes dot-in {
  from { transform: scale(0); opacity: 0; }
  to   { transform: scale(1); opacity: 1; }
}
