/* custom-tab-bar/index.wxss · 白色毛玻璃底部导航栏 */

.tab-bar__body {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  height: calc(130rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);

  /* 白色毛玻璃 */
  background: rgba(255,255,255,0.84);
  backdrop-filter: blur(24px) saturate(200%);
  -webkit-backdrop-filter: blur(24px) saturate(200%);

  border-top: 1rpx solid rgba(255,255,255,1);
  box-shadow: 0 -4rpx 28rpx rgba(109,40,217,0.10), 0 -1rpx 0 rgba(124,58,237,0.08);
  z-index: 1000;
  overflow: hidden;
}

/* ── 顶部微渐变高光线 ── */
.tab-bar__top-line {
  position: absolute; top: 0; left: 0; right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(124,58,237,0.35), rgba(37,99,235,0.30), transparent);
}

/* ── 背景光晕（跟随 tab 移动） ── */
.tab-bar__glow {
  position: absolute; top: -60rpx;
  height: 160rpx; width: 260rpx; border-radius: 50%;
  opacity: 0.20; filter: blur(28px);
  transition: left 0.38s cubic-bezier(0.34,1.2,0.64,1), opacity 0.3s;
  background: radial-gradient(circle, #a78bfa 0%, #60a5fa 60%, transparent 80%);
  pointer-events: none;
}

/* ── 滑动胶囊指示器 ── */
.tab-bar__indicator {
  position: absolute;
  top: 6rpx;
  height: 118rpx;
  border-radius: 32rpx;
  background: rgba(124,58,237,0.09);
  border: 1rpx solid rgba(124,58,237,0.22);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  box-shadow: 0 4rpx 16rpx rgba(124,58,237,0.12), inset 0 1rpx 0 rgba(255,255,255,1);
  transition: left 0.38s cubic-bezier(0.34,1.2,0.64,1),
              transform 0.38s cubic-bezier(0.34,1.2,0.64,1);
  pointer-events: none; z-index: 0;
}

/* ── Tab 行 ── */
.tab-bar__row {
  position: relative; z-index: 1;
  display: flex; height: 130rpx;
}

/* ── 单个 Tab ── */
.tab-item {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 4rpx; position: relative;
  padding-top: 6rpx;
  transition: transform 0.18s;
}
.tab-item--animate { animation: tab-entry 0.4s cubic-bezier(0.34,1.4,0.64,1) both; }
.tab-item:active   { transform: scale(0.88); }

@keyframes tab-entry {
  from { transform: translateY(24rpx); opacity: 0; }
  to   { transform: translateY(0);     opacity: 1; }
}

/* ── 图标容器（相对定位，承载光晕） ── */
.tab-icon-wrap {
  position: relative;
  width: 56rpx; height: 56rpx;
  display: flex; align-items: center; justify-content: center;
}

/* ── 图标图片 ── */
.tab-icon-img {
  width: 52rpx; height: 52rpx;
  position: relative; z-index: 1;
  transition: transform 0.25s cubic-bezier(0.34,1.4,0.64,1), opacity 0.2s;
  opacity: 0.65;
}
.tab-icon-img--active {
  transform: scale(1.18) translateY(-2rpx);
  opacity: 1;
  filter: drop-shadow(0 2rpx 8rpx rgba(124,58,237,0.28));
}

/* ── 活跃光晕（图标背后） ── */
.tab-glow {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: radial-gradient(circle, rgba(124,58,237,0.18) 0%, transparent 70%);
  animation: glow-breathe 2.5s ease-in-out infinite;
  pointer-events: none; z-index: 0;
}
@keyframes glow-breathe {
  0%,100% { transform: translate(-50%,-50%) scale(1);   opacity: 1; }
  50%      { transform: translate(-50%,-50%) scale(1.3); opacity: 0.55; }
}

/* ── 文字标签 ── */
.tab-label {
  font-size: 22rpx; font-weight: 500;
  color: rgba(30,27,75,0.40);
  transition: color 0.2s, font-weight 0.2s;
  letter-spacing: 1rpx;
}
.tab-item--active .tab-label {
  color: #7c3aed; font-weight: 700;
}

/* ── 激活指示点 ── */
.tab-dot {
  width: 8rpx; height: 8rpx; border-radius: 50%;
  background: linear-gradient(135deg, #7c3aed, #2563eb);
  box-shadow: 0 0 6rpx rgba(124,58,237,0.50);
  animation: dot-in 0.25s cubic-bezier(0.34,1.5,0.64,1) both;
}
@keyframes dot-in {
  from { transform: scale(0); opacity: 0; }
  to   { transform: scale(1); opacity: 1; }
}
