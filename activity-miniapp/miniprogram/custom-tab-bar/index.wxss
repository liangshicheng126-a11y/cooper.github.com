/* custom-tab-bar/index.wxss · 活力年轻底部导航栏 */

.tab-bar__body {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  height: calc(130rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);

  background: rgba(255,255,255,0.94);
  backdrop-filter: blur(16px) saturate(150%);
  -webkit-backdrop-filter: blur(16px) saturate(150%);

  border-top: 1rpx solid rgba(255,90,61,0.10);
  box-shadow: 0 -8rpx 28rpx rgba(255,90,61,0.10), 0 -2rpx 10rpx rgba(37,26,52,0.05);
  z-index: 1000;
  overflow: hidden;
}

/* ── 顶部细线（去掉大紫条观感） ── */
.tab-bar__top-line {
  position: absolute; top: 0; left: 0; right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255,90,61,0.20), transparent);
}

/* ── 背景光晕：left 为 Tab 区域中点，配合 translateX(-50%) 真正居中 ── */
.tab-bar__glow {
  position: absolute; top: -48rpx;
  height: 140rpx; width: 200rpx; border-radius: 50%;
  opacity: 0.22; filter: blur(24px);
  transition: left var(--motion-slow) var(--ease-pop), opacity var(--motion-medium);
  transform: translateX(-50%);
  background: radial-gradient(circle, rgba(255,90,61,0.52) 0%, rgba(250,204,21,0.32) 46%, rgba(124,58,237,0.22) 66%, transparent 78%);
  pointer-events: none;
}

/* ── 滑动胶囊指示器 ── */
.tab-bar__indicator {
  position: absolute;
  left: 0;
  top: 8rpx;
  height: 112rpx;
  border-radius: 28rpx;
  box-sizing: border-box;
  background: linear-gradient(135deg, rgba(255,90,61,0.12), rgba(250,204,21,0.15));
  border: 1rpx solid rgba(255,90,61,0.20);
  box-shadow: 0 8rpx 24rpx rgba(255,90,61,0.10), inset 0 1rpx 0 rgba(255,255,255,1);
  transition: transform var(--motion-slow) var(--ease-pop),
              width var(--motion-slow) var(--ease-pop);
  pointer-events: none; z-index: 0;
}

/* ── Tab 行 ── */
.tab-bar__row {
  position: relative; z-index: 1;
  display: flex; height: 130rpx;
}

/* ── 单个 Tab ── */
.tab-item {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 4rpx; position: relative;
  padding-top: 6rpx;
  transition: transform var(--motion-fast) var(--ease-out);
}
.tab-item--animate { animation: tab-entry var(--motion-slow) var(--ease-pop) both; }
.tab-item:active   { transform: translateY(2rpx) scale(0.9); }

@keyframes tab-entry {
  from { transform: translateY(24rpx); opacity: 0; }
  to   { transform: translateY(0);     opacity: 1; }
}

/* ── 图标容器（相对定位，承载光晕） ── */
.tab-icon-wrap {
  position: relative;
  width: 56rpx; height: 56rpx;
  display: flex; align-items: center; justify-content: center;
}

/* ── 图标图片 ── */
.tab-icon-img {
  width: 52rpx; height: 52rpx;
  position: relative; z-index: 1;
  transition: transform var(--motion-medium) var(--ease-pop), opacity var(--motion-base), filter var(--motion-base);
  opacity: 0.65;
}
.tab-icon-img--active {
  transform: scale(1.18) translateY(-2rpx);
  opacity: 1;
  filter: drop-shadow(0 4rpx 8rpx rgba(255,90,61,0.20));
}

/* ── 活跃光晕（图标背后） ── */
.tab-glow {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 76rpx; height: 76rpx; border-radius: 50%;
  background: radial-gradient(circle, rgba(255,90,61,0.18) 0%, rgba(250,204,21,0.10) 44%, transparent 72%);
  animation: glow-breathe 2.5s ease-in-out infinite;
  pointer-events: none; z-index: 0;
}
@keyframes glow-breathe {
  0%,100% { transform: translate(-50%,-50%) scale(1);   opacity: 1; }
  50%      { transform: translate(-50%,-50%) scale(1.3); opacity: 0.55; }
}

/* ── 文字标签 ── */
.tab-label {
  font-size: 22rpx; font-weight: 500;
  color: var(--text-muted);
  transition: color var(--motion-base), font-weight var(--motion-base);
  letter-spacing: 1rpx;
}
.tab-item--active .tab-label {
  color: var(--accent-text); font-weight: 700;
}

/* ── 激活指示点 ── */
.tab-dot {
  width: 8rpx; height: 8rpx; border-radius: 50%;
  background: linear-gradient(135deg, var(--accent), var(--accent-3));
  box-shadow: 0 0 8rpx rgba(255,90,61,0.30);
  animation: dot-in var(--motion-medium) var(--ease-pop) both;
}

@media (prefers-reduced-motion: reduce) {
  .tab-item--animate,
  .tab-glow,
  .tab-dot {
    animation: none;
  }
  .tab-item,
  .tab-icon-img,
  .tab-bar__glow,
  .tab-bar__indicator {
    transition: opacity var(--motion-fast), color var(--motion-fast), background var(--motion-fast);
  }
}
@keyframes dot-in {
  from { transform: scale(0); opacity: 0; }
  to   { transform: scale(1); opacity: 1; }
}
