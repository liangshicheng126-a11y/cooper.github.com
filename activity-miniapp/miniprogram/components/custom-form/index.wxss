/* components/custom-form/index.wxss */
.options-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  border: 2rpx solid var(--gray-200);
  border-radius: var(--radius-md);
  background: var(--gray-50);
  transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
}

.option-item.option-selected {
  border-color: var(--primary);
  background: var(--primary-light);
}

.option-radio {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid var(--gray-300);
  border-radius: 50%;
  margin-right: 12rpx;
  transition: border-color 0.15s, background 0.15s, color 0.15s;
}

.option-radio.radio-checked {
  border-color: var(--primary);
  background: var(--primary);
  box-shadow: inset 0 0 0 6rpx white;
}

.option-checkbox {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid var(--gray-300);
  border-radius: 8rpx;
  margin-right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: border-color 0.15s, background 0.15s, color 0.15s;
}

.option-checkbox.checkbox-checked {
  background: var(--primary);
  border-color: var(--primary);
}

.check-icon {
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 700;
}

.option-label {
  font-size: 28rpx;
  color: var(--gray-700);
}

.option-selected .option-label {
  color: var(--primary);
  font-weight: 600;
}

.picker-input {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-value {
  font-size: 28rpx;
  color: var(--gray-800);
}

.picker-placeholder {
  font-size: 28rpx;
  color: var(--gray-400);
}

.picker-arrow {
  font-size: 32rpx;
  color: var(--gray-400);
  transform: rotate(90deg);
  display: inline-block;
}
