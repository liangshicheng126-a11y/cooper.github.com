/* components/custom-form/index.wxss */
.options-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  border: 2rpx solid var(--gray-200);
  border-radius: var(--radius-md);
  background: var(--gray-50);
  transition: border-color var(--motion-base), background var(--motion-base), box-shadow var(--motion-base), transform var(--motion-base) var(--ease-out);
}

.option-item.option-selected {
  border-color: var(--primary);
  background: var(--primary-light);
  box-shadow: 0 6rpx 18rpx rgba(255,90,61,0.10);
  transform: translateY(-1rpx);
}

.option-radio {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid var(--gray-300);
  border-radius: 50%;
  margin-right: 12rpx;
  transition: border-color var(--motion-base), background var(--motion-base), color var(--motion-base);
}

.option-radio.radio-checked {
  border-color: var(--primary);
  background: var(--primary);
  box-shadow: inset 0 0 0 6rpx white, 0 0 0 4rpx rgba(255,90,61,0.10);
}

.option-checkbox {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid var(--gray-300);
  border-radius: 8rpx;
  margin-right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: border-color var(--motion-base), background var(--motion-base), color var(--motion-base), box-shadow var(--motion-base);
}

.option-checkbox.checkbox-checked {
  background: var(--primary);
  border-color: var(--primary);
  box-shadow: 0 0 0 4rpx rgba(255,90,61,0.10);
}

.check-icon {
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 700;
}

.option-label {
  font-size: 28rpx;
  color: var(--gray-700);
}

.option-selected .option-label {
  color: var(--primary);
  font-weight: 600;
}

.picker-input {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-value {
  font-size: 28rpx;
  color: var(--gray-800);
}

.picker-placeholder {
  font-size: 28rpx;
  color: var(--gray-400);
}

.picker-arrow {
  font-size: 32rpx;
  color: var(--gray-400);
  transform: rotate(90deg);
  display: inline-block;
}

@media (prefers-reduced-motion: reduce) {
  .option-item,
  .option-radio,
  .option-checkbox {
    transition: background var(--motion-fast), border-color var(--motion-fast);
  }
  .option-item.option-selected {
    transform: none;
  }
}
