/* components/privacy-modal/index.wxss · 毛玻璃隐私协议弹窗 */

/* z-index 必须高于 custom-tab-bar 的 1000 */
.mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.65);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  z-index: 2000;
  display: flex;
  align-items: flex-end;
}

.modal {
  background: rgba(18, 14, 40, 0.96);
  backdrop-filter: blur(30px) saturate(160%);
  -webkit-backdrop-filter: blur(30px) saturate(160%);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-top: 1rpx solid rgba(167,139,250,0.3);
  border-radius: 40rpx 40rpx 0 0;
  width: 100%;
  max-height: 88vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -16rpx 60rpx rgba(0,0,0,0.6);
  animation: slideUp 0.4s cubic-bezier(0.34, 1.2, 0.64, 1) both;
}

@keyframes slideUp {
  from { transform: translateY(60rpx); opacity: 0; }
  to   { transform: translateY(0);     opacity: 1; }
}

/* 顶部高光 */
.modal::before {
  content: '';
  position: absolute;
  top: 0; left: 10%; right: 10%;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(167,139,250,0.6), rgba(96,165,250,0.6), transparent);
  pointer-events: none;
}

.modal-header {
  padding: 40rpx 40rpx 20rpx;
  text-align: center;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
  position: relative;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.95);
  letter-spacing: 1rpx;
}

.modal-scroll {
  flex: 1;
  max-height: 50vh;
}

.modal-body { padding: 28rpx 40rpx; }

.modal-welcome {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #c4b5fd;
  margin-bottom: 12rpx;
}

.modal-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.55);
  line-height: 1.75;
  margin-bottom: 28rpx;
}

.policy-section { margin-bottom: 28rpx; }

.policy-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.85);
  margin-bottom: 12rpx;
}

.policy-text {
  display: block;
  font-size: 25rpx;
  color: rgba(255,255,255,0.5);
  line-height: 1.85;
  padding-left: 8rpx;
}

.modal-footer {
  padding: 24rpx 40rpx 36rpx;
  border-top: 1rpx solid rgba(255,255,255,0.08);
}

.agree-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
  gap: 4rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid rgba(255,255,255,0.25);
  border-radius: 8rpx;
  margin-right: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
  background: rgba(255,255,255,0.05);
}

.checkbox.checked {
  background: linear-gradient(135deg, #7c3aed, #2563eb);
  border-color: #a78bfa;
  box-shadow: 0 2rpx 12rpx rgba(124,58,237,0.4);
}

.check-icon {
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
}

.agree-text {
  font-size: 25rpx;
  color: rgba(255,255,255,0.55);
}

.link-text {
  font-size: 25rpx;
  color: #a78bfa;
  font-weight: 600;
}

.btn-disabled { opacity: 0.35; }

.mt-12 { margin-top: 16rpx; }
