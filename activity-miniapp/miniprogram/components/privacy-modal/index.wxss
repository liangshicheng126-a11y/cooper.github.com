/* components/privacy-modal/index.wxss */
.mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.modal {
  background: #FFFFFF;
  border-radius: 40rpx 40rpx 0 0;
  width: 100%;
  max-height: 88vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  padding: 40rpx 40rpx 20rpx;
  text-align: center;
  border-bottom: 1rpx solid var(--gray-100);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--gray-800);
}

.modal-scroll {
  flex: 1;
  max-height: 55vh;
}

.modal-body {
  padding: 24rpx 40rpx;
}

.modal-welcome {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
  margin-bottom: 12rpx;
}

.modal-desc {
  display: block;
  font-size: 26rpx;
  color: var(--gray-500);
  line-height: 1.7;
  margin-bottom: 24rpx;
}

.policy-section {
  margin-bottom: 24rpx;
}

.policy-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--gray-700);
  margin-bottom: 12rpx;
}

.policy-text {
  display: block;
  font-size: 26rpx;
  color: var(--gray-500);
  line-height: 1.8;
  padding-left: 8rpx;
}

.modal-footer {
  padding: 24rpx 40rpx 32rpx;
  border-top: 1rpx solid var(--gray-100);
}

.agree-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid var(--gray-300);
  border-radius: 8rpx;
  margin-right: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.checkbox.checked {
  background: var(--primary);
  border-color: var(--primary);
}

.check-icon {
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
}

.agree-text {
  font-size: 26rpx;
  color: var(--gray-500);
}

.link-text {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 600;
}

.btn-disabled {
  opacity: 0.5;
}

.mt-12 {
  margin-top: 16rpx;
}
