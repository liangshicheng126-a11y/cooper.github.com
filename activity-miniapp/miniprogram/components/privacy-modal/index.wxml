<!-- components/privacy-modal/index.wxml -->
<view class="mask" wx:if="{{show}}" bindtap="onMaskTap">
  <view class="modal animate-slide-up" catchtap="stop">
    <view class="modal-header">
      <text class="modal-title">隐私协议与服务条款</text>
    </view>
    <scroll-view scroll-y class="modal-scroll">
      <view class="modal-body">
        <text class="modal-welcome">欢迎使用活动报名小程序</text>
        <text class="modal-desc">在使用本服务前，请仔细阅读以下协议。我们非常重视您的隐私保护。</text>

        <view class="policy-section">
          <text class="policy-title">📋 我们收集的信息</text>
          <text class="policy-text">• 微信基础信息（昵称、头像）：用于展示您的身份</text>
          <text class="policy-text">• 活动报名信息（姓名、手机号等）：仅用于活动统计，对非活动创建者加密隐藏</text>
          <text class="policy-text">• 位置信息（可选）：仅用于活动地点导航，不做持久化存储</text>
        </view>

        <view class="policy-section">
          <text class="policy-title">🔒 信息安全</text>
          <text class="policy-text">• 所有敏感信息采用 AES-256 加密存储</text>
          <text class="policy-text">• 手机号、身份证号默认脱敏显示（如 138****5678）</text>
          <text class="policy-text">• 仅活动发起人在二次验证后可导出完整名单</text>
          <text class="policy-text">• 我们不会将您的信息出售给任何第三方</text>
        </view>

        <view class="policy-section">
          <text class="policy-title">📅 存储期限</text>
          <text class="policy-text">• 活动结束 180 天后，报名数据将自动匿名化处理</text>
          <text class="policy-text">• 您可在"我的 → 数据下载与删除"随时申请删除个人数据</text>
        </view>

        <view class="policy-section">
          <text class="policy-title">🔔 消息通知</text>
          <text class="policy-text">• 报名成功后，可选择接收活动开始前提醒</text>
          <text class="policy-text">• 活动信息变更时，系统将通知所有报名者</text>
        </view>
      </view>
    </scroll-view>
    <view class="modal-footer">
      <view class="agree-row">
        <view class="checkbox {{agreed ? 'checked' : ''}}" bindtap="toggleAgree">
          <text wx:if="{{agreed}}" class="check-icon">✓</text>
        </view>
        <text class="agree-text">我已阅读并同意</text>
        <text class="link-text" bindtap="openPrivacy">《隐私协议》</text>
        <text class="agree-text">和</text>
        <text class="link-text" bindtap="openTerms">《服务条款》</text>
      </view>
      <button class="btn btn-primary btn-block {{!agreed ? 'btn-disabled' : ''}}" bindtap="onConfirm" disabled="{{!agreed}}">
        同意并继续
      </button>
      <button class="btn btn-gray btn-block mt-12" bindtap="onDecline">不同意，退出</button>
    </view>
  </view>
</view>
