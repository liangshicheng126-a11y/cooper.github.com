/* components/status-badge/index.wxss · 毛玻璃状态标签 */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.5;
  letter-spacing: 1rpx;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.badge--upcoming {
  background: rgba(251,191,36,0.14);
  color: #fbbf24;
  border: 1rpx solid rgba(251,191,36,0.3);
}
.badge--active {
  background: rgba(52,211,153,0.14);
  color: #34d399;
  border: 1rpx solid rgba(52,211,153,0.3);
  box-shadow: 0 2rpx 12rpx rgba(52,211,153,0.18);
}
.badge--ended {
  background: rgba(255,255,255,0.06);
  color: rgba(255,255,255,0.4);
  border: 1rpx solid rgba(255,255,255,0.12);
}
.badge--cancelled {
  background: rgba(248,113,113,0.12);
  color: #f87171;
  border: 1rpx solid rgba(248,113,113,0.28);
}
.badge--full {
  background: rgba(251,146,60,0.14);
  color: #fb923c;
  border: 1rpx solid rgba(251,146,60,0.3);
}
.badge--draft {
  background: rgba(167,139,250,0.14);
  color: #a78bfa;
  border: 1rpx solid rgba(167,139,250,0.28);
}
