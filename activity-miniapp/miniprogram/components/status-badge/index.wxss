/* components/status-badge/index.wxss · 活力状态标签 */
.badge {
  display: inline-flex; align-items: center;
  padding: 6rpx 18rpx; border-radius: 100rpx;
  font-size: 22rpx; font-weight: 700;
  line-height: 1.5; letter-spacing: 0.5rpx;
  backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
  box-shadow: 0 2rpx 8rpx rgba(37,26,52,0.04);
}
.badge--upcoming  { background: rgba(217,119,6,0.10);  color: #d97706; border: 1rpx solid rgba(217,119,6,0.22); }
.badge--active    { background: rgba(5,150,105,0.10);  color: #059669; border: 1rpx solid rgba(5,150,105,0.22); box-shadow: 0 2rpx 8rpx rgba(5,150,105,0.12); }
.badge--ended     { background: rgba(37,26,52,0.06);   color: var(--text-muted); border: 1rpx solid rgba(37,26,52,0.12); }
.badge--cancelled { background: rgba(220,38,38,0.08);  color: #dc2626; border: 1rpx solid rgba(220,38,38,0.18); }
.badge--full      { background: rgba(220,38,38,0.08);  color: #dc2626; border: 1rpx solid rgba(220,38,38,0.18); }
.badge--draft     { background: rgba(255,90,61,0.11); color: var(--accent-text); border: 1rpx solid rgba(255,90,61,0.24); }
