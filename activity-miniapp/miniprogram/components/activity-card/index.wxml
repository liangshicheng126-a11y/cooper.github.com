<!-- components/activity-card/index.wxml -->
<view class="card activity-card" bindtap="onTap" data-id="{{activity.id}}" role="button" aria-label="查看活动 {{activity.name}}">
  <!-- 封面图（无图或加载失败时用 CSS 占位，避免 SVG/无效 URL 空白） -->
  <view class="card-cover">
    <view class="cover-fallback" wx:if="{{!coverSrc || coverFailed}}" />
    <image
      wx:if="{{coverSrc && !coverFailed}}"
      src="{{coverSrc}}"
      mode="aspectFill"
      class="cover-img"
      lazy-load
      binderror="onCoverError"
    />
    <view class="cover-overlay" />
  </view>

  <!-- 状态角标 -->
  <view class="status-corner {{statusClass}}">
    <view class="pulse-dot" wx:if="{{statusKey === 'active'}}" />
    <text>{{statusText}}</text>
  </view>

  <view class="card-body">
    <!-- 标题行 -->
    <view class="card-title-row">
      <text class="card-title text-ellipsis-2">{{activity.name}}</text>
    </view>

    <!-- 信息行 -->
    <view class="info-row">
      <text class="info-icon">📅</text>
      <text class="info-text">{{startTime}}</text>
    </view>
    <view class="info-row" wx:if="{{activity.locationName || activity.locationAddress}}">
      <text class="info-icon">📍</text>
      <text class="info-text text-ellipsis">{{activity.locationName || activity.locationAddress}}</text>
    </view>

    <!-- 进度条 -->
    <view class="progress-section" wx:if="{{activity.maxParticipants > 0}}">
      <view class="progress-label row-between">
        <text class="progress-count">
          <text class="count-num">{{activity.registrationCount}}</text>
          <text class="count-sep">/</text>
          <text class="count-total">{{activity.maxParticipants}}</text>
          <text class="count-unit">{{peopleUnit}}</text>
        </text>
        <text class="progress-pct">{{progressPct}}%</text>
      </view>
      <view class="progress-track">
        <view class="progress-fill {{progressClass}}" style="width:{{progressPct}}%" />
      </view>
    </view>
    <view class="progress-section" wx:else>
      <text class="no-limit-text">{{registeredNoCapLine}}</text>
    </view>

    <!-- 底部：发起人 & 时间 -->
    <view class="card-footer">
      <view class="creator-info">
        <view class="creator-avatar creator-avatar--fallback" wx:if="{{!creatorAvatarSrc}}" />
        <image
          wx:else
          src="{{creatorAvatarSrc}}"
          class="creator-avatar"
          mode="aspectFill"
          lazy-load
          binderror="onAvatarError"
        />
        <text class="creator-name">{{activity.creatorNickname}}</text>
      </view>
      <text class="publish-time">{{publishTime}}</text>
    </view>
  </view>
</view>
