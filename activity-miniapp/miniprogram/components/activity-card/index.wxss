/* components/activity-card/index.wxss */
.activity-card {
  margin-bottom: 24rpx;
  border-radius: var(--radius-xl);
  overflow: hidden;
  background: #FFFFFF;
  box-shadow: var(--shadow-md);
  position: relative;
  transition: transform 0.15s;
}

.activity-card:active {
  transform: scale(0.98);
}

.card-cover {
  position: relative;
  height: 280rpx;
  overflow: hidden;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-overlay {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 120rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.3));
}

/* 状态角标 */
.status-corner {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 8rpx 18rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  z-index: 2;
}

.status-active {
  background: rgba(16,185,129,0.15);
  color: #059669;
  border: 1.5rpx solid rgba(16,185,129,0.4);
  backdrop-filter: blur(8px);
}

.status-upcoming {
  background: rgba(245,158,11,0.15);
  color: #D97706;
  border: 1.5rpx solid rgba(245,158,11,0.4);
}

.status-ended {
  background: rgba(107,114,128,0.12);
  color: var(--gray-500);
  border: 1.5rpx solid rgba(107,114,128,0.3);
}

.status-full {
  background: rgba(239,68,68,0.12);
  color: #DC2626;
  border: 1.5rpx solid rgba(239,68,68,0.3);
}

.card-body {
  padding: 28rpx 32rpx 24rpx;
}

.card-title-row {
  margin-bottom: 18rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--gray-800);
  line-height: 1.4;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.info-icon {
  font-size: 26rpx;
  margin-right: 10rpx;
  width: 32rpx;
  text-align: center;
}

.info-text {
  font-size: 26rpx;
  color: var(--gray-500);
  flex: 1;
}

/* 进度条 */
.progress-section {
  margin-top: 20rpx;
  margin-bottom: 4rpx;
}

.progress-label {
  margin-bottom: 10rpx;
}

.progress-count {
  font-size: 24rpx;
  color: var(--gray-500);
}

.count-num {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--primary);
}

.count-sep, .count-total {
  color: var(--gray-400);
}

.progress-pct {
  font-size: 22rpx;
  color: var(--gray-400);
}

.progress-track {
  height: 10rpx;
  background: var(--gray-100);
  border-radius: 100rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 100rpx;
  transition: width 0.6s ease;
}

.fill-primary { background: linear-gradient(90deg, #6366F1, #4F46E5); }
.fill-warning { background: linear-gradient(90deg, #FBBF24, #F59E0B); }
.fill-danger  { background: linear-gradient(90deg, #F87171, #EF4444); }

.no-limit-text {
  font-size: 24rpx;
  color: var(--gray-400);
}

/* 底部 */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--gray-100);
}

.creator-info {
  display: flex;
  align-items: center;
}

.creator-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  background: var(--gray-100);
}

.creator-name {
  font-size: 24rpx;
  color: var(--gray-500);
}

.publish-time {
  font-size: 22rpx;
  color: var(--gray-300);
}
