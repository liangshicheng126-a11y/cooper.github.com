/* components/activity-card/index.wxss · 毛玻璃活动卡片 */

.activity-card {
  margin-bottom: 24rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: rgba(255,255,255,0.07);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255,255,255,0.13);
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.4);
  position: relative;
  transition: transform 0.2s, box-shadow 0.2s;
  animation: slideUp 0.35s cubic-bezier(0.25,0.46,0.45,0.94) both;
}

/* 顶部高光线 */
.activity-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.22), transparent);
  z-index: 1;
  pointer-events: none;
}

.activity-card:active {
  transform: scale(0.975);
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.35);
}

@keyframes slideUp {
  from { transform: translateY(30rpx); opacity: 0; }
  to   { transform: translateY(0);     opacity: 1; }
}

/* ── 封面图 ── */
.card-cover {
  position: relative;
  height: 280rpx;
  overflow: hidden;
}

.cover-img { width: 100%; height: 100%; }

.cover-overlay {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 140rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.55));
}

/* ── 状态角标（毛玻璃版） ── */
.status-corner {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 8rpx 18rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  z-index: 2;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  letter-spacing: 1rpx;
}

.status-active {
  background: rgba(52,211,153,0.18);
  color: #34d399;
  border: 1rpx solid rgba(52,211,153,0.35);
  box-shadow: 0 4rpx 16rpx rgba(52,211,153,0.2);
}
.status-upcoming {
  background: rgba(251,191,36,0.15);
  color: #fbbf24;
  border: 1rpx solid rgba(251,191,36,0.32);
}
.status-ended {
  background: rgba(255,255,255,0.07);
  color: rgba(255,255,255,0.45);
  border: 1rpx solid rgba(255,255,255,0.15);
}
.status-full {
  background: rgba(248,113,113,0.15);
  color: #f87171;
  border: 1rpx solid rgba(248,113,113,0.3);
}

/* ── 卡片主体 ── */
.card-body { padding: 28rpx 32rpx 24rpx; }

.card-title-row { margin-bottom: 18rpx; }

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.95);
  line-height: 1.4;
  letter-spacing: 0.5rpx;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.info-icon {
  font-size: 26rpx;
  margin-right: 10rpx;
  width: 32rpx;
  text-align: center;
  opacity: 0.75;
}

.info-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.58);
  flex: 1;
}

/* ── 进度条 ── */
.progress-section {
  margin-top: 20rpx;
  margin-bottom: 4rpx;
}

.progress-label { margin-bottom: 10rpx; }

.progress-count { font-size: 24rpx; color: rgba(255,255,255,0.5); }

.count-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #a78bfa;
}

.count-sep, .count-total { color: rgba(255,255,255,0.3); }

.progress-pct { font-size: 22rpx; color: rgba(255,255,255,0.35); }

.progress-track {
  height: 8rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 100rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 100rpx;
  transition: width 0.7s cubic-bezier(0.25,0.46,0.45,0.94);
}

.fill-primary { background: linear-gradient(90deg, #a78bfa, #60a5fa); }
.fill-warning { background: linear-gradient(90deg, #fde68a, #fbbf24); }
.fill-danger  { background: linear-gradient(90deg, #fca5a5, #f87171); }

.no-limit-text { font-size: 24rpx; color: rgba(255,255,255,0.3); }

/* ── 卡片底栏 ── */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.07);
}

.creator-info { display: flex; align-items: center; }

.creator-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  background: rgba(255,255,255,0.1);
  border: 1rpx solid rgba(255,255,255,0.15);
}

.creator-name { font-size: 24rpx; color: rgba(255,255,255,0.45); }
.publish-time { font-size: 22rpx; color: rgba(255,255,255,0.28); }
