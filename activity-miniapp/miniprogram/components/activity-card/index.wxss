/* components/activity-card/index.wxss · 白色毛玻璃活动卡片 */
.activity-card {
  margin-bottom: 24rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: rgba(255,255,255,0.86);
  border: 1rpx solid rgba(124,58,237,0.10);
  box-shadow: 0 6rpx 20rpx rgba(30,27,75,0.07), 0 2rpx 6rpx rgba(30,27,75,0.04);
  position: relative;
  transition: transform 0.2s, box-shadow 0.2s;
}

/* 顶部高光线 */
.activity-card::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,1), transparent);
  z-index: 1; pointer-events: none;
}

.activity-card:active {
  transform: scale(0.975);
  box-shadow: 0 4rpx 12rpx rgba(30,27,75,0.06);
}

/* ── 封面图 ── */
.card-cover { position: relative; height: 280rpx; overflow: hidden; }
.cover-img  { width: 100%; height: 100%; }
.cover-overlay {
  position: absolute; bottom: 0; left: 0; right: 0; height: 140rpx;
  background: linear-gradient(transparent, rgba(30,27,75,0.30));
}

/* ── 状态角标 ── */
.status-corner {
  position: absolute; top: 20rpx; right: 20rpx;
  padding: 8rpx 18rpx; border-radius: 100rpx;
  font-size: 22rpx; font-weight: 700;
  display: flex; align-items: center; z-index: 2;
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
}
.status-active   { background: rgba(255,255,255,0.78); color: #059669; border: 1rpx solid rgba(5,150,105,0.22); }
.status-upcoming { background: rgba(255,255,255,0.78); color: #d97706; border: 1rpx solid rgba(217,119,6,0.22); }
.status-ended    { background: rgba(255,255,255,0.70); color: rgba(30,27,75,0.45); border: 1rpx solid rgba(30,27,75,0.14); }
.status-full     { background: rgba(255,255,255,0.78); color: #dc2626; border: 1rpx solid rgba(220,38,38,0.22); }

/* ── 卡片主体 ── */
.card-body { padding: 28rpx 32rpx 24rpx; }

.card-title-row { margin-bottom: 18rpx; }
.card-title {
  font-size: 32rpx; font-weight: 700; color: #1e1b4b;
  line-height: 1.4; letter-spacing: 0.5rpx;
}

.info-row    { display: flex; align-items: center; margin-bottom: 10rpx; }
.info-icon   { font-size: 26rpx; margin-right: 10rpx; width: 32rpx; text-align: center; opacity: 0.70; }
.info-text   { font-size: 26rpx; color: rgba(30,27,75,0.60); flex: 1; }

/* ── 进度条 ── */
.progress-section { margin-top: 20rpx; margin-bottom: 4rpx; }
.progress-label   { margin-bottom: 10rpx; }
.progress-count   { font-size: 24rpx; color: rgba(30,27,75,0.50); }

.count-num   { font-size: 28rpx; font-weight: 700; color: #7c3aed; }
.count-sep, .count-total { color: rgba(30,27,75,0.35); }
.progress-pct { font-size: 22rpx; color: rgba(30,27,75,0.38); }

.progress-track {
  height: 8rpx; background: rgba(30,27,75,0.08);
  border-radius: 100rpx; overflow: hidden;
}
.progress-fill {
  height: 100%; border-radius: 100rpx;
  transition: width 0.7s cubic-bezier(0.25,0.46,0.45,0.94);
}

.fill-primary { background: linear-gradient(90deg, #8b5cf6, #3b82f6); }
.fill-warning { background: linear-gradient(90deg, #fde68a, #fbbf24); }
.fill-danger  { background: linear-gradient(90deg, #fca5a5, #f87171); }
.no-limit-text { font-size: 24rpx; color: rgba(30,27,75,0.38); }

/* ── 卡片底栏 ── */
.card-footer {
  display: flex; align-items: center; justify-content: space-between;
  margin-top: 20rpx; padding-top: 20rpx;
  border-top: 1rpx solid rgba(30,27,75,0.07);
}
.creator-info  { display: flex; align-items: center; }
.creator-avatar {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  margin-right: 12rpx; background: rgba(124,58,237,0.08);
  border: 1rpx solid rgba(255,255,255,0.90);
}
.creator-name  { font-size: 24rpx; color: rgba(30,27,75,0.48); }
.publish-time  { font-size: 22rpx; color: rgba(30,27,75,0.32); }
