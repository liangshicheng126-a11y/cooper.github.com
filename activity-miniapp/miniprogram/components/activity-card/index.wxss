/* components/activity-card/index.wxss · 简洁高级活动卡片 */
.activity-card {
  margin-bottom: 28rpx;
  border-radius: 34rpx;
  overflow: hidden;
  background: var(--surface-strong);
  border: 1rpx solid rgba(29,28,24,0.08);
  box-shadow: 0 14rpx 32rpx rgba(29,28,24,0.08), 0 3rpx 10rpx rgba(29,28,24,0.04);
  position: relative;
  transition: transform var(--motion-base) var(--ease-out), box-shadow var(--motion-base) var(--ease-out);
}

.activity-card::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--accent), rgba(154,107,36,0.16));
  z-index: 1; pointer-events: none;
}

.activity-card:active {
  transform: translateY(3rpx) scale(0.982);
  box-shadow: 0 8rpx 20rpx rgba(29,28,24,0.07), 0 2rpx 8rpx rgba(29,28,24,0.04);
}

.card-cover { position: relative; height: 280rpx; overflow: hidden; }
.cover-fallback {
  position: absolute; inset: 0;
  background: linear-gradient(145deg, #f8f6f0 0%, #eee9df 100%);
}
.cover-fallback::before,
.cover-fallback::after {
  content: '';
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}
.cover-fallback::before {
  width: 200rpx; height: 200rpx; top: -40rpx; left: -24rpx;
  background: rgba(154,107,36,0.10);
}
.cover-fallback::after {
  width: 260rpx; height: 260rpx; bottom: -80rpx; right: -40rpx;
  background: rgba(29,28,24,0.06);
}
.cover-img  { position: relative; z-index: 1; width: 100%; height: 100%; }
.cover-overlay {
  position: absolute; bottom: 0; left: 0; right: 0; height: 140rpx;
  background: linear-gradient(transparent, rgba(29,28,24,0.30));
}

.status-corner {
  position: absolute; top: 20rpx; right: 20rpx;
  padding: 9rpx 20rpx; border-radius: 100rpx;
  font-size: 22rpx; font-weight: 700;
  display: flex; align-items: center; z-index: 2;
  backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
}
.status-active   { background: rgba(255,255,255,0.88); color: var(--success); border: 1rpx solid rgba(5,150,105,0.22); }
.status-upcoming { background: rgba(255,255,255,0.88); color: var(--warning); border: 1rpx solid rgba(217,119,6,0.22); }
.status-ended    { background: rgba(255,255,255,0.82); color: var(--text-muted); border: 1rpx solid rgba(29,28,24,0.12); }
.status-full     { background: rgba(255,255,255,0.88); color: var(--danger); border: 1rpx solid rgba(220,38,38,0.20); }

.card-body { padding: 28rpx 32rpx 24rpx; }

.card-title-row { margin-bottom: 18rpx; }
.card-title {
  font-size: 34rpx; font-weight: 760; color: var(--text-primary);
  line-height: 1.42; letter-spacing: 0;
}

.info-row    { display: flex; align-items: flex-start; margin-bottom: 10rpx; gap: 14rpx; }
.info-icon   { font-size: 21rpx; line-height: 34rpx; width: 48rpx; color: var(--text-muted); flex-shrink: 0; }
.info-text   { font-size: 26rpx; color: var(--text-secondary); flex: 1; }

.progress-section { margin-top: 20rpx; margin-bottom: 4rpx; }
.progress-label   { margin-bottom: 10rpx; }
.progress-count   { font-size: 24rpx; color: var(--text-muted); }

.count-num   { font-size: 28rpx; font-weight: 800; color: var(--text-primary); }
.count-sep, .count-total { color: var(--text-muted); }
.progress-pct { font-size: 22rpx; color: var(--text-muted); }

.progress-track {
  height: 10rpx; background: rgba(37,26,52,0.08);
  border-radius: 100rpx; overflow: hidden;
}
.progress-fill {
  height: 100%; border-radius: 100rpx;
  transition: width 0.7s var(--ease-out);
}

.fill-primary { background: linear-gradient(90deg, var(--accent), var(--accent-3)); }
.fill-warning { background: linear-gradient(90deg, #facc15, #fb923c); }
.fill-danger  { background: linear-gradient(90deg, #fb7185, #ef4444); }
.no-limit-text { font-size: 24rpx; color: var(--text-muted); }

.card-footer {
  display: flex; align-items: center; justify-content: space-between;
  margin-top: 20rpx; padding-top: 20rpx;
  border-top: 1rpx solid var(--divider);
}
.creator-info  { display: flex; align-items: center; }
.creator-avatar {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  margin-right: 12rpx; background: linear-gradient(145deg, rgba(154,107,36,0.18), rgba(29,28,24,0.06));
  border: 1rpx solid rgba(29,28,24,0.08);
}
.creator-name  { font-size: 24rpx; color: var(--text-muted); }
.publish-time  { font-size: 22rpx; color: rgba(29,28,24,0.34); }

@media (prefers-reduced-motion: reduce) {
  .activity-card,
  .progress-fill {
    transition: opacity var(--motion-fast), box-shadow var(--motion-fast);
  }
  .activity-card:active {
    transform: none;
  }
}
