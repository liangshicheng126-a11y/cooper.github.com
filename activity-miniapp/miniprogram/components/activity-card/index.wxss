/* components/activity-card/index.wxss · 活力年轻活动卡片 */
.activity-card {
  margin-bottom: 28rpx;
  border-radius: 34rpx;
  overflow: hidden;
  background: var(--surface-strong);
  border: 1rpx solid rgba(255,255,255,0.96);
  box-shadow: 0 14rpx 34rpx rgba(255,90,61,0.12), 0 4rpx 12rpx rgba(37,26,52,0.06);
  position: relative;
  transition: transform var(--motion-base) var(--ease-out), box-shadow var(--motion-base) var(--ease-out);
}

.activity-card::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--accent), var(--accent-3), var(--accent-2));
  z-index: 1; pointer-events: none;
}

.activity-card:active {
  transform: translateY(3rpx) scale(0.982);
  box-shadow: 0 8rpx 20rpx rgba(255,90,61,0.10), 0 2rpx 8rpx rgba(37,26,52,0.05);
}

.card-cover { position: relative; height: 280rpx; overflow: hidden; }
.cover-img  { width: 100%; height: 100%; }
.cover-overlay {
  position: absolute; bottom: 0; left: 0; right: 0; height: 140rpx;
  background: linear-gradient(transparent, rgba(37,26,52,0.34));
}

.status-corner {
  position: absolute; top: 20rpx; right: 20rpx;
  padding: 9rpx 20rpx; border-radius: 100rpx;
  font-size: 22rpx; font-weight: 700;
  display: flex; align-items: center; z-index: 2;
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
}
.status-active   { background: rgba(255,255,255,0.86); color: var(--success); border: 1rpx solid rgba(5,150,105,0.24); }
.status-upcoming { background: rgba(255,255,255,0.88); color: var(--warning); border: 1rpx solid rgba(217,119,6,0.24); }
.status-ended    { background: rgba(255,255,255,0.78); color: var(--text-muted); border: 1rpx solid rgba(37,26,52,0.14); }
.status-full     { background: rgba(255,255,255,0.88); color: var(--danger); border: 1rpx solid rgba(220,38,38,0.22); }

.card-body { padding: 28rpx 32rpx 24rpx; }

.card-title-row { margin-bottom: 18rpx; }
.card-title {
  font-size: 34rpx; font-weight: 800; color: var(--text-primary);
  line-height: 1.4; letter-spacing: 0.5rpx;
}

.info-row    { display: flex; align-items: center; margin-bottom: 10rpx; }
.info-icon   { font-size: 26rpx; margin-right: 10rpx; width: 32rpx; text-align: center; opacity: 0.82; }
.info-text   { font-size: 26rpx; color: var(--text-secondary); flex: 1; }

.progress-section { margin-top: 20rpx; margin-bottom: 4rpx; }
.progress-label   { margin-bottom: 10rpx; }
.progress-count   { font-size: 24rpx; color: var(--text-muted); }

.count-num   { font-size: 28rpx; font-weight: 800; color: var(--accent-text); }
.count-sep, .count-total { color: var(--text-muted); }
.progress-pct { font-size: 22rpx; color: var(--text-muted); }

.progress-track {
  height: 10rpx; background: rgba(37,26,52,0.08);
  border-radius: 100rpx; overflow: hidden;
}
.progress-fill {
  height: 100%; border-radius: 100rpx;
  transition: width 0.7s var(--ease-out);
}

.fill-primary { background: linear-gradient(90deg, var(--accent), var(--accent-2)); }
.fill-warning { background: linear-gradient(90deg, #facc15, #fb923c); }
.fill-danger  { background: linear-gradient(90deg, #fb7185, #ef4444); }
.no-limit-text { font-size: 24rpx; color: var(--text-muted); }

.card-footer {
  display: flex; align-items: center; justify-content: space-between;
  margin-top: 20rpx; padding-top: 20rpx;
  border-top: 1rpx solid var(--divider);
}
.creator-info  { display: flex; align-items: center; }
.creator-avatar {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  margin-right: 12rpx; background: var(--accent-light);
  border: 1rpx solid rgba(255,255,255,0.90);
}
.creator-name  { font-size: 24rpx; color: var(--text-muted); }
.publish-time  { font-size: 22rpx; color: rgba(37,26,52,0.32); }

@media (prefers-reduced-motion: reduce) {
  .activity-card,
  .progress-fill {
    transition: opacity var(--motion-fast), box-shadow var(--motion-fast);
  }
  .activity-card:active {
    transform: none;
  }
}
