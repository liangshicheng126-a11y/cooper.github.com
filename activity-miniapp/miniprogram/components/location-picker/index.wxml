<!-- components/location-picker/index.wxml -->
<view wx:if="{{show}}" class="picker-mask" catchtap="onClose">
  <view class="picker-panel" catchtap="">

    <!-- 标题栏 -->
    <view class="panel-header">
      <text class="panel-title">선택 지점 / 选择地点</text>
      <text class="panel-close" catchtap="onClose">✕</text>
    </view>

    <!-- 国内 / 海外 模式切换 -->
    <view class="mode-tabs">
      <view
        class="mode-tab {{mode === 'china' ? 'mode-tab--active' : ''}}"
        bindtap="setModeChina"
      >🇨🇳 中国地点</view>
      <view
        class="mode-tab {{mode === 'intl' ? 'mode-tab--active' : ''}}"
        bindtap="setModeIntl"
      >🌏 海外地点</view>
    </view>

    <!-- 国内：直接调腾讯地图 -->
    <view wx:if="{{mode === 'china'}}" class="mode-body">
      <view class="china-tip">调起微信内置地图，支持搜索国内所有地址</view>
      <button class="btn-pick-china" bindtap="pickChina" loading="{{loading}}">
        📍 打开地图选择
      </button>
    </view>

    <!-- 海外：文字搜索 -->
    <view wx:else class="mode-body">

      <!-- 语言选择 -->
      <view class="lang-tabs">
        <view
          class="lang-tab {{lang === 'ko' ? 'lang-tab--active' : ''}}"
          bindtap="setLangKo"
        >🇰🇷 한국어</view>
        <view
          class="lang-tab {{lang === 'zh' ? 'lang-tab--active' : ''}}"
          bindtap="setLangZh"
        >🇨🇳 中文</view>
        <view
          class="lang-tab {{lang === 'en' ? 'lang-tab--active' : ''}}"
          bindtap="setLangEn"
        >🌐 English</view>
      </view>

      <!-- 韩语快捷城市 -->
      <scroll-view wx:if="{{lang === 'ko'}}" scroll-x class="shortcut-scroll">
        <view class="shortcut-list">
          <view
            wx:for="{{koShortcuts}}"
            wx:key="*this"
            class="shortcut-chip"
            data-kw="{{item}}"
            bindtap="onShortcut"
          >{{item}}</view>
        </view>
      </scroll-view>

      <!-- 搜索框 -->
      <view class="search-row">
        <input
          class="search-input"
          placeholder="{{placeholder}}"
          value="{{keyword}}"
          bindinput="onKeywordInput"
          confirm-type="search"
          bindconfirm="doSearch"
          focus="{{mode === 'intl'}}"
        />
        <view class="search-btn {{loading ? 'search-btn--loading' : ''}}" bindtap="doSearch">
          <text wx:if="{{!loading}}">{{lang === 'ko' ? '검색' : '搜索'}}</text>
          <view wx:else class="loading-dots"><text>·</text><text>·</text><text>·</text></view>
        </view>
      </view>
      <text class="search-tip">{{searchTip}}</text>

      <!-- 搜索结果 -->
      <scroll-view scroll-y class="result-list" wx:if="{{results.length > 0}}">
        <view
          wx:for="{{results}}"
          wx:key="place_id"
          class="result-item"
          data-idx="{{index}}"
          bindtap="onSelectResult"
        >
          <view class="result-main">
            <text class="result-name">{{item.primary_name}}</text>
            <text class="result-badge" wx:if="{{item.country_code}}">{{item.country_flag}}</text>
          </view>
          <text class="result-sub" wx:if="{{item.secondary_name}}">{{item.secondary_name}}</text>
          <text class="result-addr">{{item.display_name}}</text>
        </view>
      </scroll-view>

      <view class="no-result" wx:if="{{searched && results.length === 0 && !loading}}">
        <text wx:if="{{lang === 'ko'}}">검색 결과가 없습니다. 다른 키워드를 입력해 보세요.</text>
        <text wx:else>未找到相关地点，请尝试其他关键词</text>
      </view>

    </view>

  </view>
</view>
