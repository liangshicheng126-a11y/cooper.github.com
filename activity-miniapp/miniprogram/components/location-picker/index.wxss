/* components/location-picker/index.wxss · 毛玻璃地点选择器 */
.picker-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.65);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}
.picker-panel {
  width: 100%;
  max-height: 92vh;
  background: rgba(20,16,50,0.96);
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-top: 1rpx solid rgba(255,255,255,0.2);
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 -12rpx 48rpx rgba(0,0,0,0.6);
}

/* ── 标题栏 ── */
.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx 0;
  flex-shrink: 0;
}
.header-left { display: flex; align-items: center; }
.panel-title { font-size: 30rpx; font-weight: 600; color: rgba(255,255,255,0.95); }
.panel-close { font-size: 36rpx; color: rgba(255,255,255,0.4); padding: 8rpx 0 8rpx 24rpx; }
.back-btn    { display: flex; align-items: center; gap: 4rpx; }
.back-arrow  { font-size: 44rpx; color: #a78bfa; line-height: 1; }
.back-text   { font-size: 26rpx; color: #a78bfa; }

/* ── 国内/海外 tab ── */
.mode-tabs {
  display: flex;
  margin: 20rpx 32rpx 0;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 16rpx;
  padding: 6rpx;
  flex-shrink: 0;
}
.mode-tab {
  flex: 1; text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: rgba(255,255,255,0.45);
  border-radius: 12rpx;
  transition: all 0.2s;
}
.mode-tab--active {
  background: linear-gradient(135deg, rgba(124,58,237,0.55), rgba(37,99,235,0.55));
  color: #fff; font-weight: 600;
  box-shadow: 0 2rpx 12rpx rgba(124,58,237,0.3);
}

/* ── 搜索步骤内容 ── */
.step-body { flex: 1; overflow-y: auto; }
.mode-body { padding: 24rpx 32rpx 32rpx; }

/* ── 文字输入地址栏 ── */
.text-input-section { margin-bottom: 4rpx; }
.section-label { font-size: 24rpx; color: rgba(255,255,255,0.45); margin-bottom: 12rpx; display: block; }
.text-addr-row { display: flex; gap: 12rpx; margin-bottom: 8rpx; }
.text-addr-input {
  flex: 1; height: 80rpx;
  background: rgba(255,255,255,0.07);
  border: 1rpx solid rgba(167,139,250,0.25);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
}
.addr-search-btn {
  width: 110rpx; height: 80rpx;
  background: linear-gradient(135deg, #7c3aed, #2563eb);
  color: #fff; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(124,58,237,0.35);
}
.addr-search-btn--loading { opacity: 0.6; }
.section-hint { font-size: 21rpx; color: rgba(255,255,255,0.25); display: block; margin-bottom: 20rpx; }

/* ── 分隔线 ── */
.divider-row {
  display: flex; align-items: center;
  margin: 20rpx 0; gap: 16rpx;
}
.divider-row::before, .divider-row::after {
  content: ''; flex: 1;
  height: 1rpx; background: rgba(255,255,255,0.08);
}
.divider-text { font-size: 22rpx; color: rgba(255,255,255,0.25); white-space: nowrap; }

/* ── 国内按钮 ── */
.china-tip { font-size: 26rpx; color: rgba(255,255,255,0.45); text-align: center; margin-bottom: 20rpx; }
.btn-pick-china {
  background: linear-gradient(135deg, #7c3aed, #2563eb);
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
  padding: 24rpx;
  border: none;
  box-shadow: 0 6rpx 24rpx rgba(124,58,237,0.4);
}

/* ── 语言 tab ── */
.lang-tabs { display: flex; gap: 12rpx; margin-bottom: 16rpx; flex-shrink: 0; }
.lang-tab  {
  flex: 1; text-align: center;
  padding: 14rpx 0;
  font-size: 23rpx;
  color: rgba(255,255,255,0.4);
  background: rgba(255,255,255,0.06);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
  transition: all 0.2s;
}
.lang-tab--active {
  color: #a78bfa;
  background: rgba(167,139,250,0.12);
  border-color: rgba(167,139,250,0.35);
  font-weight: 600;
}

/* ── 韩语快捷 ── */
.shortcut-scroll { width: 100%; margin-bottom: 16rpx; }
.shortcut-list   { display: flex; gap: 12rpx; width: max-content; padding-bottom: 4rpx; }
.shortcut-chip   {
  padding: 10rpx 24rpx;
  background: rgba(248,113,113,0.1);
  color: #f87171;
  border-radius: 30rpx;
  font-size: 24rpx;
  white-space: nowrap;
  border: 1rpx solid rgba(248,113,113,0.22);
}

/* ── 关键词搜索框 ── */
.search-row { display: flex; gap: 12rpx; margin-bottom: 10rpx; flex-shrink: 0; }
.search-input {
  flex: 1; height: 80rpx;
  background: rgba(255,255,255,0.07);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 27rpx;
  color: rgba(255,255,255,0.9);
}
.search-btn {
  width: 120rpx; height: 80rpx;
  background: linear-gradient(135deg, #7c3aed, #2563eb);
  color: #fff; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; flex-shrink: 0;
}
.search-btn--loading { opacity: 0.6; }
.loading-dots { display: flex; gap: 4rpx; }
.loading-dots text { font-size: 40rpx; line-height: 1; }
.search-tip { font-size: 22rpx; color: rgba(255,255,255,0.25); display: block; margin-bottom: 16rpx; }

/* ── 结果列表 ── */
.result-list { max-height: 44vh; }
.result-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.07);
  display: flex; flex-direction: column; gap: 6rpx;
}
.result-item:active { background: rgba(167,139,250,0.07); border-radius: 8rpx; padding: 22rpx 8rpx; }
.result-main { display: flex; align-items: center; gap: 10rpx; }
.result-name { font-size: 29rpx; font-weight: 600; color: rgba(255,255,255,0.9); flex: 1; }
.result-badge { font-size: 28rpx; }
.result-sub  { font-size: 24rpx; color: #a78bfa; }
.result-addr { font-size: 21rpx; color: rgba(255,255,255,0.35); line-height: 1.5; }
.no-result   { text-align: center; color: rgba(255,255,255,0.28); font-size: 26rpx; padding: 48rpx 0; }

/* ══ 地图确认步骤 ══ */
.map-confirm-body { flex: 1; display: flex; flex-direction: column; overflow: hidden; }

.confirm-addr-card {
  padding: 20rpx 32rpx 16rpx;
  background: rgba(167,139,250,0.07);
  border-bottom: 1rpx solid rgba(167,139,250,0.15);
  flex-shrink: 0;
}
.confirm-name { font-size: 28rpx; font-weight: 600; color: rgba(255,255,255,0.9); display: block; }
.confirm-addr { font-size: 22rpx; color: rgba(255,255,255,0.45); display: block; margin-top: 4rpx; line-height: 1.5; }
.confirm-hint { font-size: 21rpx; color: #a78bfa; display: block; margin-top: 8rpx; }

.confirm-map { flex: 1; width: 100%; min-height: 400rpx; }

/* 缩放控制 */
.map-controls {
  position: absolute;
  right: 24rpx; bottom: 280rpx;
  display: flex; flex-direction: column; gap: 2rpx; z-index: 10;
}
.map-ctrl-btn {
  width: 72rpx; height: 72rpx;
  background: rgba(20,16,50,0.85);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1rpx solid rgba(255,255,255,0.15);
  border-radius: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.4);
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; color: rgba(255,255,255,0.85); font-weight: 300;
}

/* 坐标条 */
.coord-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 32rpx;
  background: rgba(13,11,30,0.7);
  border-top: 1rpx solid rgba(255,255,255,0.08);
  flex-shrink: 0;
}
.coord-text  { font-size: 22rpx; color: rgba(255,255,255,0.35); font-family: monospace; }
.coord-reset {
  font-size: 22rpx; color: #a78bfa;
  padding: 6rpx 16rpx;
  background: rgba(167,139,250,0.1);
  border: 1rpx solid rgba(167,139,250,0.25);
  border-radius: 20rpx;
}

/* 确认按钮栏 */
.confirm-bar { padding: 16rpx 32rpx 32rpx; flex-shrink: 0; }
.btn-confirm {
  width: 100%;
  background: linear-gradient(135deg, #7c3aed, #2563eb);
  color: #fff; border-radius: 20rpx;
  font-size: 30rpx; padding: 26rpx;
  border: none; font-weight: 600;
  box-shadow: 0 6rpx 24rpx rgba(124,58,237,0.45);
}
