/* components/location-picker/index.wxss */
.picker-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.picker-panel {
  width: 100%;
  max-height: 88vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ── 标题栏 ── */
.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 0;
  flex-shrink: 0;
}
.panel-title { font-size: 30rpx; font-weight: 600; color: #1a1a1a; }
.panel-close { font-size: 36rpx; color: #999; padding: 8rpx 0 8rpx 24rpx; }

/* ── 国内/海外 tab ── */
.mode-tabs {
  display: flex;
  margin: 20rpx 32rpx 0;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 6rpx;
  flex-shrink: 0;
}
.mode-tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: #666;
  border-radius: 12rpx;
}
.mode-tab--active {
  background: #fff;
  color: #4a6cf7;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,.08);
}

/* ── 语言 tab ── */
.lang-tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
  flex-shrink: 0;
}
.lang-tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 24rpx;
  color: #888;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}
.lang-tab--active {
  color: #4a6cf7;
  background: #eef2ff;
  border-color: #4a6cf7;
  font-weight: 600;
}

/* ── 韩国城市快捷按钮 ── */
.shortcut-scroll {
  width: 100%;
  margin-bottom: 20rpx;
  flex-shrink: 0;
}
.shortcut-list {
  display: flex;
  gap: 12rpx;
  width: max-content;
  padding-bottom: 4rpx;
}
.shortcut-chip {
  padding: 10rpx 24rpx;
  background: #fff0f3;
  color: #c0392b;
  border-radius: 30rpx;
  font-size: 24rpx;
  white-space: nowrap;
  border: 1rpx solid #ffc2c8;
}

/* ── 内容区 ── */
.mode-body {
  padding: 24rpx 32rpx 0;
  flex: 1;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
}

/* ── 国内按钮 ── */
.china-tip { font-size: 26rpx; color: #888; text-align: center; margin-bottom: 32rpx; }
.btn-pick-china {
  background: #4a6cf7;
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
  padding: 24rpx;
  border: none;
}

/* ── 搜索框 ── */
.search-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 10rpx;
  flex-shrink: 0;
}
.search-input {
  flex: 1;
  height: 84rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}
.search-btn {
  width: 120rpx;
  height: 84rpx;
  background: #4a6cf7;
  color: #fff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  flex-shrink: 0;
}
.search-btn--loading { background: #8fa5f9; }
.loading-dots { display: flex; gap: 4rpx; }
.loading-dots text { font-size: 40rpx; line-height: 1; animation: blink 1s infinite; }
.loading-dots text:nth-child(2) { animation-delay: .2s; }
.loading-dots text:nth-child(3) { animation-delay: .4s; }
@keyframes blink { 0%,100%{opacity:.2} 50%{opacity:1} }

.search-tip {
  font-size: 22rpx;
  color: #bbb;
  display: block;
  margin-bottom: 16rpx;
  flex-shrink: 0;
}

/* ── 结果列表 ── */
.result-list { flex: 1; min-height: 0; }
.result-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  cursor: pointer;
}
.result-item:active { background: #f7f9ff; border-radius: 8rpx; }

.result-main {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.result-name  { font-size: 30rpx; font-weight: 600; color: #1a1a1a; flex: 1; }
.result-badge { font-size: 28rpx; }

.result-sub  { font-size: 24rpx; color: #4a6cf7; }
.result-addr { font-size: 22rpx; color: #aaa; line-height: 1.5; }

.no-result {
  text-align: center;
  color: #bbb;
  font-size: 26rpx;
  padding: 60rpx 0;
}
