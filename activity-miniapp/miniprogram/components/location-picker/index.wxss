/* components/location-picker/index.wxss */
.picker-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}
.picker-panel {
  width: 100%;
  max-height: 92vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ── 标题栏 ── */
.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx 0;
  flex-shrink: 0;
}
.header-left { display: flex; align-items: center; }
.panel-title { font-size: 30rpx; font-weight: 600; color: #1a1a1a; }
.panel-close { font-size: 36rpx; color: #999; padding: 8rpx 0 8rpx 24rpx; }
.back-btn    { display: flex; align-items: center; gap: 4rpx; }
.back-arrow  { font-size: 44rpx; color: #4a6cf7; line-height: 1; }
.back-text   { font-size: 26rpx; color: #4a6cf7; }

/* ── 国内/海外 tab ── */
.mode-tabs {
  display: flex;
  margin: 20rpx 32rpx 0;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 6rpx;
  flex-shrink: 0;
}
.mode-tab { flex:1; text-align:center; padding:14rpx 0; font-size:26rpx; color:#666; border-radius:12rpx; }
.mode-tab--active { background:#fff; color:#4a6cf7; font-weight:600; box-shadow:0 2rpx 8rpx rgba(0,0,0,.08); }

/* ── 搜索步骤 ── */
.step-body  { flex:1; overflow-y:auto; }
.mode-body  { padding:24rpx 32rpx 32rpx; }

/* ── 文字输入地址栏 ── */
.text-input-section { margin-bottom: 4rpx; }
.section-label { font-size: 24rpx; color: #888; margin-bottom: 12rpx; display: block; }
.text-addr-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 8rpx;
}
.text-addr-input {
  flex: 1;
  height: 80rpx;
  background: #f0f4ff;
  border: 2rpx solid #c7d4ff;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #1a1a1a;
}
.addr-search-btn {
  width: 110rpx;
  height: 80rpx;
  background: #4a6cf7;
  color: #fff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  flex-shrink: 0;
}
.addr-search-btn--loading { background: #8fa5f9; }
.section-hint { font-size: 21rpx; color: #bbb; display: block; margin-bottom: 20rpx; }

/* ── 分隔线 ── */
.divider-row {
  display: flex;
  align-items: center;
  margin: 20rpx 0;
  gap: 16rpx;
}
.divider-row::before,
.divider-row::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: #eee;
}
.divider-text { font-size: 22rpx; color: #bbb; white-space: nowrap; }

/* ── 国内按钮 ── */
.china-tip { font-size: 26rpx; color: #888; text-align: center; margin-bottom: 20rpx; }
.btn-pick-china {
  background: #4a6cf7;
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
  padding: 24rpx;
  border: none;
}

/* ── 语言 tab ── */
.lang-tabs { display:flex; gap:12rpx; margin-bottom:16rpx; flex-shrink:0; }
.lang-tab  { flex:1; text-align:center; padding:14rpx 0; font-size:23rpx; color:#888; background:#f8f8f8; border-radius:12rpx; border:2rpx solid transparent; }
.lang-tab--active { color:#4a6cf7; background:#eef2ff; border-color:#4a6cf7; font-weight:600; }

/* ── 韩语快捷 ── */
.shortcut-scroll { width:100%; margin-bottom:16rpx; }
.shortcut-list   { display:flex; gap:12rpx; width:max-content; padding-bottom:4rpx; }
.shortcut-chip   { padding:10rpx 24rpx; background:#fff0f3; color:#c0392b; border-radius:30rpx; font-size:24rpx; white-space:nowrap; border:1rpx solid #ffc2c8; }

/* ── 关键词搜索框 ── */
.search-row { display:flex; gap:12rpx; margin-bottom:10rpx; flex-shrink:0; }
.search-input { flex:1; height:80rpx; background:#f5f5f5; border-radius:12rpx; padding:0 24rpx; font-size:27rpx; }
.search-btn { width:120rpx; height:80rpx; background:#4a6cf7; color:#fff; border-radius:12rpx; display:flex; align-items:center; justify-content:center; font-size:26rpx; flex-shrink:0; }
.search-btn--loading { background:#8fa5f9; }
.loading-dots { display:flex; gap:4rpx; }
.loading-dots text { font-size:40rpx; line-height:1; }
.search-tip { font-size:22rpx; color:#bbb; display:block; margin-bottom:16rpx; }

/* ── 结果列表 ── */
.result-list { max-height: 44vh; }
.result-item { padding:22rpx 0; border-bottom:1rpx solid #f0f0f0; display:flex; flex-direction:column; gap:6rpx; }
.result-item:active { background:#f7f9ff; border-radius:8rpx; }
.result-main { display:flex; align-items:center; gap:10rpx; }
.result-name { font-size:29rpx; font-weight:600; color:#1a1a1a; flex:1; }
.result-badge { font-size:28rpx; }
.result-sub  { font-size:24rpx; color:#4a6cf7; }
.result-addr { font-size:21rpx; color:#aaa; line-height:1.5; }
.no-result   { text-align:center; color:#bbb; font-size:26rpx; padding:48rpx 0; }

/* ══ 地图确认步骤 ══ */
.map-confirm-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.confirm-addr-card {
  padding: 20rpx 32rpx 16rpx;
  background: #f7f9ff;
  border-bottom: 1rpx solid #e8eeff;
  flex-shrink: 0;
}
.confirm-name { font-size: 28rpx; font-weight: 600; color: #1a1a1a; display: block; }
.confirm-addr { font-size: 22rpx; color: #888; display: block; margin-top: 4rpx; line-height: 1.5; }
.confirm-hint { font-size: 21rpx; color: #4a6cf7; display: block; margin-top: 8rpx; }

.confirm-map {
  flex: 1;
  width: 100%;
  min-height: 400rpx;
}

/* 缩放控制 */
.map-controls {
  position: absolute;
  right: 24rpx;
  bottom: 280rpx;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  z-index: 10;
}
.map-ctrl-btn {
  width: 72rpx;
  height: 72rpx;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #333;
  font-weight: 300;
}

/* 坐标条 */
.coord-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 32rpx;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}
.coord-text  { font-size: 22rpx; color: #999; font-family: monospace; }
.coord-reset { font-size: 22rpx; color: #4a6cf7; padding: 6rpx 16rpx; background: #eef2ff; border-radius: 20rpx; }

/* 确认按钮栏 */
.confirm-bar {
  padding: 16rpx 32rpx 32rpx;
  flex-shrink: 0;
}
.btn-confirm {
  width: 100%;
  background: #4a6cf7;
  color: #fff;
  border-radius: 20rpx;
  font-size: 30rpx;
  padding: 26rpx;
  border: none;
  font-weight: 600;
}
