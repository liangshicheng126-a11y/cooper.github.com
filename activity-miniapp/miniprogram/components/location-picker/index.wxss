/* components/location-picker/index.wxss */
.picker-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.picker-panel {
  width: 100%;
  max-height: 80vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 0;
}
.panel-title { font-size: 32rpx; font-weight: 600; color: #1a1a1a; }
.panel-close  { font-size: 36rpx; color: #999; padding: 8rpx 8rpx 8rpx 24rpx; }

/* 模式 tab */
.mode-tabs {
  display: flex;
  margin: 24rpx 32rpx 0;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 6rpx;
}
.mode-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #666;
  border-radius: 12rpx;
  transition: all .2s;
}
.mode-tab--active {
  background: #fff;
  color: #4a6cf7;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,.08);
}

/* 内容区 */
.mode-body {
  padding: 32rpx;
  flex: 1;
  overflow-y: auto;
}

/* 国内 */
.china-tip { font-size: 26rpx; color: #888; text-align: center; margin-bottom: 32rpx; }
.btn-pick-china {
  background: #4a6cf7;
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
  padding: 24rpx;
  border: none;
}

/* 海外搜索 */
.search-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.search-input {
  flex: 1;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}
.search-btn {
  width: 120rpx;
  height: 80rpx;
  background: #4a6cf7;
  color: #fff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}
.search-tip { font-size: 22rpx; color: #bbb; display: block; margin-bottom: 24rpx; }

/* 结果列表 */
.result-list { max-height: 50vh; }
.result-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.result-name { font-size: 28rpx; font-weight: 500; color: #1a1a1a; }
.result-addr { font-size: 22rpx; color: #888; line-height: 1.5; }
.no-result   { text-align: center; color: #bbb; font-size: 26rpx; padding: 48rpx 0; }
