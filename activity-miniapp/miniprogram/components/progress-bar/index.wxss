/* components/progress-bar/index.wxss · 白色毛玻璃进度条 */
.progress-wrap { width: 100%; }

.progress-info { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10rpx; }
.progress-label { font-size: 24rpx; color: rgba(30,27,75,0.50); letter-spacing: 0.5rpx; }
.progress-count { font-size: 24rpx; color: rgba(30,27,75,0.75); font-weight: 600; }

.progress-track {
  width: 100%; height: 10rpx;
  background: rgba(30,27,75,0.08); border-radius: 100rpx; overflow: hidden;
}
.progress-fill {
  height: 100%; border-radius: 100rpx;
  transition: width 0.7s cubic-bezier(0.25,0.46,0.45,0.94);
}
.progress-fill--normal  { background: linear-gradient(90deg, #8b5cf6, #3b82f6); box-shadow: 0 0 10rpx rgba(124,58,237,0.22); }
.progress-fill--warning { background: linear-gradient(90deg, #fde68a, #fbbf24); box-shadow: 0 0 10rpx rgba(217,119,6,0.22); }
.progress-fill--danger  { background: linear-gradient(90deg, #fca5a5, #f87171); box-shadow: 0 0 10rpx rgba(220,38,38,0.22); }
