/* components/progress-bar/index.wxss · 活力进度条 */
.progress-wrap { width: 100%; }

.progress-info { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10rpx; }
.progress-label { font-size: 24rpx; color: var(--text-muted); letter-spacing: 0.5rpx; }
.progress-count { font-size: 24rpx; color: var(--text-primary); font-weight: 700; }

.progress-track {
  width: 100%; height: 12rpx;
  background: rgba(37,26,52,0.08); border-radius: 100rpx; overflow: hidden;
}
.progress-fill {
  height: 100%; border-radius: 100rpx;
  transition: width 0.7s var(--ease-out);
}
.progress-fill--normal  { background: linear-gradient(90deg, var(--accent), var(--accent-2)); box-shadow: 0 0 12rpx rgba(255,90,61,0.24); }
.progress-fill--warning { background: linear-gradient(90deg, #facc15, #fb923c); box-shadow: 0 0 10rpx rgba(217,119,6,0.22); }
.progress-fill--danger  { background: linear-gradient(90deg, #fca5a5, #f87171); box-shadow: 0 0 10rpx rgba(220,38,38,0.22); }

@media (prefers-reduced-motion: reduce) {
  .progress-fill {
    transition: none;
  }
}
