/* components/progress-bar/index.wxss */
.progress-wrap { width: 100%; }

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}
.progress-label { font-size: 24rpx; color: #666; }
.progress-count { font-size: 24rpx; color: #333; font-weight: 500; }

.progress-track {
  width: 100%;
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.4s ease;
}
.progress-fill--normal  { background: linear-gradient(90deg, #4facfe, #00f2fe); }
.progress-fill--warning { background: linear-gradient(90deg, #f7971e, #ffd200); }
.progress-fill--danger  { background: linear-gradient(90deg, #ff416c, #ff4b2b); }
