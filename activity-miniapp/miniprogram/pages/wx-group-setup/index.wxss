.page {
  min-height: 100vh;
  padding: 32rpx 24rpx 80rpx;
  box-sizing: border-box;
  background: var(--bg-radial);
}

.card {
  background: var(--surface-strong);
  border-radius: 28rpx;
  padding: 36rpx 28rpx;
  box-shadow: var(--shadow-md);
}

.hint {
  display: block;
  font-size: 26rpx;
  color: var(--accent-text);
  opacity: 0.85;
  line-height: 1.5;
  margin-bottom: 32rpx;
}

.field {
  margin-bottom: 36rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.input {
  width: 100%;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  border-radius: 16rpx;
  background: rgba(154,107,36,0.07);
  box-sizing: border-box;
}

.upload-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.pick-btn {
  flex: none;
}

.clear {
  font-size: 26rpx;
  color: var(--accent-text);
  text-decoration: underline;
}

.preview {
  width: 100%;
  max-width: 400rpx;
  border-radius: 16rpx;
  margin-top: 8rpx;
}

.mini-hint {
  font-size: 24rpx;
  color: #9ca3af;
}

.save-btn {
  margin-top: 16rpx;
  border-radius: 44rpx;
}
