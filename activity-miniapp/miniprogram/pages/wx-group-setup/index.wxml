<view class="page">
  <view class="card">
    <text class="hint">进群为自愿行为，报名者可在详情页长按识别二维码。</text>

    <view class="field">
      <text class="label">群名称</text>
      <input class="input" maxlength="200" placeholder="默认为活动标题" value="{{wxGroupChatName}}" bindinput="onNameInput" />
    </view>

    <view class="field">
      <text class="label">群二维码</text>
      <view class="upload-row">
        <button class="pick-btn" type="primary" plain bindtap="chooseQrcodeImage">选择图片</button>
        <text wx:if="{{wxGroupChatQrcodeUrl}}" class="clear" bindtap="clearQrcode">清除</text>
      </view>
      <image wx:if="{{previewUrl}}" class="preview" src="{{previewUrl}}" mode="widthFix" show-menu-by-longpress />
      <text class="mini-hint" wx:if="{{!previewUrl}}">请上传微信群聊二维码截图（有效期内）</text>
    </view>

    <button class="save-btn" type="primary" loading="{{submitting}}" disabled="{{submitting}}" bindtap="onSave">
      保存
    </button>
  </view>
</view>
