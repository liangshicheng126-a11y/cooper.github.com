<!-- pages/index/index.wxml - 首页活动列表 -->
<view class="page">
  <!-- 顶部搜索栏 -->
  <view class="top-bar">
    <view class="search-box" bindtap="onSearchTap" role="button" aria-label="搜索活动">
      <text class="search-icon">⌕</text>
      <text class="search-placeholder">{{searchPlaceholder}}</text>
    </view>
    <view class="lang-btn" bindtap="toggleLanguage" role="button" aria-label="切换语言">
      <text class="lang-text">{{langText}}</text>
    </view>
  </view>

  <!-- 隐私协议弹窗 -->
  <privacy-modal show="{{showPrivacy}}" bind:confirm="onPrivacyConfirm" />

  <!-- 分类标签 -->
  <scroll-view scroll-x class="category-scroll" show-scrollbar="{{false}}">
    <view class="category-list">
      <view
        wx:for="{{categories}}"
        wx:key="key"
        class="category-tag {{activeCategory === item.key ? 'category-active' : ''}}"
        data-key="{{item.key}}"
        bindtap="onCategoryChange"
        role="button"
        aria-label="筛选{{item.label}}"
      >
        <text>{{item.label}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 列表标题 -->
  <view class="list-header">
    <text class="section-title">{{listTitle}}</text>
    <view class="filter-btn" bindtap="openFilter" role="button" aria-label="打开排序筛选">
      <text>{{filterBtnLabel}}</text>
    </view>
  </view>

  <!-- 活动列表 -->
  <scroll-view
    scroll-y
    class="activity-list"
    refresher-enabled
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
    bindscrolltolower="onScrollToLower"
    lower-threshold="100"
  >
    <view wx:if="{{loading && !activities.length}}" class="skeleton-list">
      <view wx:for="{{[1,2,3]}}" wx:key="*this" class="skeleton-card">
        <view class="skeleton-img skeleton-animate" />
        <view class="skeleton-body">
          <view class="skeleton-line w80 skeleton-animate" />
          <view class="skeleton-line w50 skeleton-animate" />
          <view class="skeleton-line w60 skeleton-animate" />
        </view>
      </view>
    </view>

    <view wx:elif="{{loadError && !loading}}">
      <view class="empty-state error-state">
        <text class="empty-icon">!</text>
        <text class="empty-text">后端服务未连接</text>
        <text class="empty-sub">{{loadErrorText}}</text>
        <button class="retry-btn" bindtap="onRetryLoad">重新加载</button>
      </view>
    </view>

    <view wx:elif="{{activities.length === 0 && !loading}}">
      <view class="empty-state">
        <text class="empty-icon">·</text>
        <text class="empty-text">{{emptyActivities}}</text>
        <text class="empty-sub">{{emptySubActivities}}</text>
      </view>
    </view>

    <activity-card
      wx:for="{{activities}}"
      wx:key="id"
      activity="{{item}}"
      locale-rev="{{localeRev}}"
      bind:tap="onActivityTap"
    />

    <view wx:if="{{loadingMore}}" class="loading-more">
      <text>{{loadingEllipsis}}</text>
    </view>
    <view wx:elif="{{noMore && activities.length > 0}}" class="no-more">
      <text>{{loadedAllFooter}}</text>
    </view>
  </scroll-view>

  <!-- 发布活动 FAB -->
  <view class="fab" bindtap="onCreateActivity" role="button" aria-label="发布活动">
    <text class="fab-icon">+</text>
  </view>
</view>
