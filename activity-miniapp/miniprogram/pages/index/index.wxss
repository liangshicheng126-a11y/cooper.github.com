/* pages/index/index.wxss · 白色毛玻璃首页 */

.page {
  min-height: 100vh;
  background: var(--bg-gradient);
}

/* ══ 顶部搜索栏 ══ */
.top-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx 16rpx;
  gap: 16rpx;
  background: rgba(255,255,255,0.75);
  backdrop-filter: blur(16px) saturate(160%);
  -webkit-backdrop-filter: blur(16px) saturate(160%);
  border-bottom: 1rpx solid rgba(124,58,237,0.08);
  position: sticky; top: 0; z-index: 20;
  box-shadow: 0 2rpx 12rpx rgba(30,27,75,0.05);
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: rgba(124,58,237,0.07);
  border: 1rpx solid rgba(124,58,237,0.14);
  border-radius: 100rpx;
  padding: 16rpx 28rpx;
  transition: background 0.2s;
}
.search-box:active { background: rgba(124,58,237,0.12); }

.search-icon { font-size: 28rpx; margin-right: 12rpx; opacity: 0.6; }
.search-placeholder { font-size: 26rpx; color: rgba(30,27,75,0.40); }

.lang-btn {
  padding: 14rpx 22rpx;
  background: rgba(124,58,237,0.10);
  border: 1rpx solid rgba(124,58,237,0.22);
  border-radius: 100rpx;
}
.lang-btn:active { background: rgba(124,58,237,0.18); }
.lang-text { font-size: 24rpx; color: #7c3aed; font-weight: 600; }

/* ══ 分类标签 ══ */
.category-scroll {
  background: rgba(255,255,255,0.60);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1rpx solid rgba(124,58,237,0.07);
}

.category-list {
  display: flex;
  padding: 18rpx 20rpx;
  gap: 12rpx;
  white-space: nowrap;
}

.category-tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  border-radius: 100rpx;
  background: rgba(255,255,255,0.72);
  border: 1rpx solid rgba(124,58,237,0.12);
  font-size: 26rpx;
  color: rgba(30,27,75,0.60);
  white-space: nowrap;
  box-shadow: 0 2rpx 8rpx rgba(30,27,75,0.04);
  transition: background 0.2s, color 0.2s, box-shadow 0.2s, border-color 0.2s;
}

.category-tag.category-active {
  background: linear-gradient(135deg, #7c3aed, #2563eb);
  border-color: transparent;
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 14rpx rgba(91,33,182,0.22);
}

/* ══ Banner ══ */
.banner-swiper {
  height: 310rpx;
  margin: 24rpx 24rpx 0;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(30,27,75,0.08);
}

.banner-img { width: 100%; height: 100%; }

.banner-info {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 24rpx 32rpx;
  background: linear-gradient(transparent, rgba(30,27,75,0.60));
}

.banner-title {
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  display: block;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}
.banner-time {
  color: rgba(255,255,255,0.82);
  font-size: 24rpx;
  margin-top: 4rpx;
  display: block;
}

/* ══ 列表头 ══ */
.list-header {
  display: flex; align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx 12rpx;
}

.filter-btn {
  font-size: 24rpx;
  color: #7c3aed;
  padding: 10rpx 20rpx;
  background: rgba(124,58,237,0.09);
  border: 1rpx solid rgba(124,58,237,0.20);
  border-radius: 100rpx;
}
.filter-btn:active { background: rgba(124,58,237,0.15); }

/* ══ 活动列表 ══ */
.activity-list {
  padding: 8rpx 24rpx 180rpx;
  height: calc(100vh - 280rpx);
  box-sizing: border-box;
}

/* ══ 骨架屏 ══ */
.skeleton-card {
  background: rgba(255,255,255,0.70);
  border: 1rpx solid rgba(255,255,255,0.92);
  border-radius: 28rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 14rpx rgba(30,27,75,0.06);
}
.skeleton-img {
  height: 280rpx;
  background: linear-gradient(90deg,
    rgba(124,58,237,0.05) 25%,
    rgba(124,58,237,0.12) 50%,
    rgba(124,58,237,0.05) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.8s infinite;
}
.skeleton-body { padding: 28rpx 32rpx; }
.skeleton-line {
  height: 26rpx;
  background: linear-gradient(90deg,
    rgba(124,58,237,0.05) 25%,
    rgba(124,58,237,0.12) 50%,
    rgba(124,58,237,0.05) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.8s infinite;
  border-radius: 13rpx;
  margin-bottom: 16rpx;
}
.skeleton-animate { animation: shimmer 1.8s infinite; }
.w80 { width: 80%; }
.w50 { width: 50%; }
.w60 { width: 60%; }

@keyframes shimmer {
  0%   { background-position: -200% 0; }
  100% { background-position:  200% 0; }
}

/* ══ 加载更多 ══ */
.loading-more, .no-more {
  text-align: center;
  padding: 28rpx;
  color: rgba(30,27,75,0.35);
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.error-state {
  padding: 72rpx 48rpx;
}

.retry-btn {
  margin-top: 28rpx;
  min-width: 220rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  background: var(--accent-grad);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(124,58,237,0.22);
}
.retry-btn::after { border: none; }

/* ══ FAB（页面 2/3 位置） ══ */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: calc(100vh / 3 - 52rpx);
  width: 104rpx;
  height: 104rpx;
  background: linear-gradient(135deg, #7c3aed, #2563eb);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(30,27,75,0.12);
  z-index: 50;
  transition: transform 0.15s, box-shadow 0.15s;
}
.fab:active {
  transform: scale(0.90);
  box-shadow: 0 4rpx 12rpx rgba(30,27,75,0.10);
}

.fab-icon {
  color: #fff;
  font-size: 60rpx;
  font-weight: 300;
  line-height: 1;
  margin-top: -4rpx;
}
