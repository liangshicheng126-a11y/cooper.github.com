/* pages/index/index.wxss · 毛玻璃风格首页 */

/* ── 页面底色 ── */
.page {
  min-height: 100vh;
  background: linear-gradient(145deg, #0d0b1e 0%, #1a1040 40%, #0d1f3c 100%);
  background-attachment: fixed;
}

/* ══ 顶部搜索栏 ══ */
.top-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx 16rpx;
  gap: 16rpx;
  background: rgba(13,11,30,0.75);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1rpx solid rgba(255,255,255,0.07);
  position: sticky;
  top: 0;
  z-index: 20;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.07);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 100rpx;
  padding: 16rpx 28rpx;
  transition: background 0.2s;
}
.search-box:active { background: rgba(255,255,255,0.12); }

.search-icon { font-size: 28rpx; margin-right: 12rpx; opacity: 0.7; }
.search-placeholder { font-size: 26rpx; color: rgba(255,255,255,0.4); }

.lang-btn {
  padding: 14rpx 22rpx;
  background: rgba(167,139,250,0.12);
  border: 1rpx solid rgba(167,139,250,0.3);
  border-radius: 100rpx;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}
.lang-btn:active { background: rgba(167,139,250,0.22); }
.lang-text { font-size: 24rpx; color: #c4b5fd; font-weight: 600; }

/* ══ 分类标签 ══ */
.category-scroll {
  background: transparent;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.category-list {
  display: flex;
  padding: 18rpx 20rpx;
  gap: 12rpx;
  white-space: nowrap;
}

.category-tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  border-radius: 100rpx;
  background: rgba(255,255,255,0.07);
  border: 1rpx solid rgba(255,255,255,0.11);
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
  white-space: nowrap;
  transition: all 0.2s;
}

.category-tag.category-active {
  background: linear-gradient(135deg, rgba(124,58,237,0.55), rgba(37,99,235,0.55));
  border-color: rgba(167,139,250,0.45);
  color: #ffffff;
  font-weight: 600;
  box-shadow: 0 4rpx 20rpx rgba(124,58,237,0.3);
}

/* ══ Banner 轮播 ══ */
.banner-swiper {
  height: 310rpx;
  margin: 24rpx 24rpx 0;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 48rpx rgba(0,0,0,0.5);
}

.banner-img { width: 100%; height: 100%; }

.banner-info {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 24rpx 32rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.75));
}

.banner-title {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  display: block;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.5);
}

.banner-time {
  color: rgba(255,255,255,0.75);
  font-size: 24rpx;
  margin-top: 4rpx;
  display: block;
}

/* ══ 列表头 ══ */
.list-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx 12rpx;
}

.filter-btn {
  font-size: 24rpx;
  color: #c4b5fd;
  padding: 10rpx 20rpx;
  background: rgba(167,139,250,0.1);
  border: 1rpx solid rgba(167,139,250,0.25);
  border-radius: 100rpx;
  letter-spacing: 1rpx;
}
.filter-btn:active { background: rgba(167,139,250,0.2); }

/* ══ 活动列表 ══ */
.activity-list {
  padding: 8rpx 24rpx 180rpx;
  height: calc(100vh - 280rpx);
  box-sizing: border-box;
}

/* ══ 骨架屏（深色版） ══ */
.skeleton-card {
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 28rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}
.skeleton-img {
  height: 280rpx;
  background: linear-gradient(90deg,
    rgba(255,255,255,0.04) 25%,
    rgba(255,255,255,0.09) 50%,
    rgba(255,255,255,0.04) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.8s infinite;
}
.skeleton-body { padding: 28rpx 32rpx; }
.skeleton-line {
  height: 26rpx;
  background: linear-gradient(90deg,
    rgba(255,255,255,0.05) 25%,
    rgba(255,255,255,0.10) 50%,
    rgba(255,255,255,0.05) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.8s infinite;
  border-radius: 13rpx;
  margin-bottom: 16rpx;
}
.skeleton-animate { animation: shimmer 1.8s infinite; }
.w80 { width: 80%; }
.w50 { width: 50%; }
.w60 { width: 60%; }

@keyframes shimmer {
  0%   { background-position: -200% 0; }
  100% { background-position:  200% 0; }
}

/* ══ 加载更多 ══ */
.loading-more, .no-more {
  text-align: center;
  padding: 28rpx;
  color: rgba(255,255,255,0.3);
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

/* ══ FAB 发布按钮（页面 2/3 垂直位置） ══ */
.fab {
  position: fixed;
  right: 40rpx;
  /* 2/3 from top = 1/3 from bottom，减去按钮自身半径居中 */
  bottom: calc(100vh / 3 - 52rpx);
  width: 104rpx;
  height: 104rpx;
  background: linear-gradient(135deg, #7c3aed, #2563eb);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 40rpx rgba(124,58,237,0.5), 0 0 0 2rpx rgba(167,139,250,0.2);
  z-index: 50;
  transition: transform 0.15s, box-shadow 0.15s;
  animation: glow-pulse 3s infinite;
}
.fab:active {
  transform: scale(0.9);
  box-shadow: 0 4rpx 20rpx rgba(124,58,237,0.4);
}

@keyframes glow-pulse {
  0%,100% { box-shadow: 0 8rpx 40rpx rgba(124,58,237,0.5), 0 0 0 2rpx rgba(167,139,250,0.2); }
  50%      { box-shadow: 0 8rpx 56rpx rgba(124,58,237,0.7), 0 0 0 4rpx rgba(167,139,250,0.15); }
}

.fab-icon {
  color: #ffffff;
  font-size: 60rpx;
  font-weight: 300;
  line-height: 1;
  margin-top: -4rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}
