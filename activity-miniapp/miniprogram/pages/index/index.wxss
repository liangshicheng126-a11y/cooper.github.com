/* pages/index/index.wxss · 活力年轻首页 */

.page {
  min-height: 100vh;
  background: var(--bg-radial);
}

/* ══ 顶部搜索栏 ══ */
.top-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx 16rpx;
  gap: 16rpx;
  background: rgba(255,255,255,0.90);
  backdrop-filter: blur(14px) saturate(150%);
  -webkit-backdrop-filter: blur(14px) saturate(150%);
  border-bottom: 1rpx solid rgba(255,90,61,0.10);
  position: sticky; top: 0; z-index: 20;
  box-shadow: 0 6rpx 18rpx rgba(255,90,61,0.08);
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: rgba(255,90,61,0.08);
  border: 1rpx solid rgba(255,90,61,0.18);
  border-radius: 100rpx;
  padding: 16rpx 28rpx;
  transition: background var(--motion-base), transform var(--motion-base) var(--ease-out), box-shadow var(--motion-base);
}
.search-box:active { background: rgba(255,90,61,0.14); transform: scale(0.99); box-shadow: 0 4rpx 14rpx rgba(255,90,61,0.10); }

.search-icon { font-size: 28rpx; margin-right: 12rpx; opacity: 0.6; }
.search-placeholder { font-size: 26rpx; color: var(--text-muted); }

.lang-btn {
  padding: 14rpx 22rpx;
  background: rgba(124,58,237,0.10);
  border: 1rpx solid rgba(124,58,237,0.20);
  border-radius: 100rpx;
}
.lang-btn:active { background: rgba(124,58,237,0.18); transform: scale(0.96); }
.lang-text { font-size: 24rpx; color: var(--accent-2); font-weight: 700; }

/* ══ 分类标签 ══ */
.category-scroll {
  background: rgba(255,255,255,0.72);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-bottom: 1rpx solid rgba(255,90,61,0.08);
}

.category-list {
  display: flex;
  padding: 18rpx 20rpx;
  gap: 12rpx;
  white-space: nowrap;
}

.category-tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  border-radius: 100rpx;
  background: rgba(255,255,255,0.88);
  border: 1rpx solid rgba(255,90,61,0.14);
  font-size: 26rpx;
  color: var(--text-secondary);
  white-space: nowrap;
  box-shadow: 0 3rpx 10rpx rgba(37,26,52,0.04);
  transition: background var(--motion-base), color var(--motion-base), box-shadow var(--motion-base), border-color var(--motion-base), transform var(--motion-base) var(--ease-out);
}

.category-tag.category-active {
  background: var(--accent-grad);
  border-color: transparent;
  color: #fff;
  font-weight: 700;
  box-shadow: 0 8rpx 22rpx rgba(255,90,61,0.22);
  transform: translateY(-2rpx);
}

/* ══ Banner ══ */
.banner-swiper {
  height: 310rpx;
  margin: 24rpx 24rpx 0;
  border-radius: 34rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 38rpx rgba(255,90,61,0.14), 0 4rpx 12rpx rgba(37,26,52,0.06);
}

.banner-cover { position: relative; width: 100%; height: 100%; }
.banner-fallback {
  position: absolute; inset: 0;
  background: linear-gradient(145deg, #fff7ed 0%, #fff1f2 48%, #eef2ff 100%);
}
.banner-fallback::after {
  content: '';
  position: absolute;
  width: 280rpx; height: 280rpx;
  top: -60rpx; right: -40rpx;
  border-radius: 50%;
  background: rgba(255,90,61,0.14);
}
.banner-img { position: relative; z-index: 1; width: 100%; height: 100%; }

.banner-info {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 24rpx 32rpx;
  background: linear-gradient(transparent, rgba(37,26,52,0.66));
}

.banner-title {
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  display: block;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}
.banner-time {
  color: rgba(255,255,255,0.82);
  font-size: 24rpx;
  margin-top: 4rpx;
  display: block;
}

/* ══ 列表头 ══ */
.list-header {
  display: flex; align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx 12rpx;
}

.filter-btn {
  font-size: 24rpx;
  color: var(--accent-text);
  padding: 10rpx 20rpx;
  background: rgba(255,90,61,0.10);
  border: 1rpx solid rgba(255,90,61,0.20);
  border-radius: 100rpx;
}
.filter-btn:active { background: rgba(255,90,61,0.16); transform: scale(0.96); }

/* ══ 活动列表 ══ */
.activity-list {
  padding: 8rpx 24rpx 180rpx;
  height: calc(100vh - 280rpx);
  box-sizing: border-box;
}

/* ══ 骨架屏 ══ */
.skeleton-card {
  background: var(--surface);
  border: 1rpx solid rgba(255,255,255,0.96);
  border-radius: 32rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-md);
}
.skeleton-img {
  height: 280rpx;
  background: linear-gradient(90deg,
    rgba(255,90,61,0.05) 25%,
    rgba(255,90,61,0.14) 50%,
    rgba(124,58,237,0.06) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.8s infinite;
}
.skeleton-body { padding: 28rpx 32rpx; }
.skeleton-line {
  height: 26rpx;
  background: linear-gradient(90deg,
    rgba(255,90,61,0.05) 25%,
    rgba(255,90,61,0.14) 50%,
    rgba(124,58,237,0.06) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.8s infinite;
  border-radius: 13rpx;
  margin-bottom: 16rpx;
}
.skeleton-animate { animation: shimmer 1.8s infinite; }
.w80 { width: 80%; }
.w50 { width: 50%; }
.w60 { width: 60%; }

@keyframes shimmer {
  0%   { background-position: -200% 0; }
  100% { background-position:  200% 0; }
}

/* ══ 加载更多 ══ */
.loading-more, .no-more {
  text-align: center;
  padding: 28rpx;
  color: var(--text-muted);
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.error-state {
  padding: 72rpx 48rpx;
}

.retry-btn {
  margin-top: 28rpx;
  min-width: 220rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  background: var(--accent-grad);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(124,58,237,0.22);
}
.retry-btn::after { border: none; }

/* ══ FAB（页面 2/3 位置） ══ */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: calc(100vh / 3 - 52rpx);
  width: 104rpx;
  height: 104rpx;
  background: var(--accent-grad);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 30rpx rgba(255,90,61,0.28), 0 4rpx 12rpx rgba(124,58,237,0.14);
  z-index: 50;
  transition: transform var(--motion-fast) var(--ease-out), box-shadow var(--motion-fast);
}
.fab:active {
  transform: translateY(4rpx) scale(0.92);
  box-shadow: 0 6rpx 16rpx rgba(255,90,61,0.20);
}

.fab-icon {
  color: #fff;
  font-size: 60rpx;
  font-weight: 300;
  line-height: 1;
  margin-top: -4rpx;
}

@media (prefers-reduced-motion: reduce) {
  .category-tag.category-active,
  .search-box:active,
  .fab:active {
    transform: none;
  }
  .skeleton-animate,
  .skeleton-img,
  .skeleton-line {
    animation: none;
  }
}
