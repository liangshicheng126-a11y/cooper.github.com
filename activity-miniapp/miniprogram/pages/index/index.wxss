/* pages/index/index.wxss · 简洁高级首页 */

.page {
  min-height: 100vh;
  background: var(--bg-radial);
}

/* ══ 顶部搜索栏 ══ */
.top-bar {
  display: flex;
  align-items: center;
  padding: 22rpx 24rpx 18rpx;
  gap: 16rpx;
  background: rgba(247,245,239,0.96);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border-bottom: 1rpx solid rgba(29,28,24,0.08);
  position: sticky; top: 0; z-index: 20;
  box-shadow: 0 6rpx 16rpx rgba(29,28,24,0.04);
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.82);
  border: 1rpx solid rgba(29,28,24,0.10);
  border-radius: 100rpx;
  padding: 16rpx 28rpx;
  transition: background var(--motion-base), transform var(--motion-base) var(--ease-out), box-shadow var(--motion-base);
}
.search-box:active { background: #fff; transform: scale(0.992); box-shadow: 0 4rpx 14rpx rgba(29,28,24,0.08); }

.search-icon { font-size: 32rpx; margin-right: 12rpx; opacity: 0.62; line-height: 1; }
.search-placeholder { font-size: 26rpx; color: var(--text-muted); }

.lang-btn {
  padding: 14rpx 22rpx;
  background: rgba(154,107,36,0.08);
  border: 1rpx solid rgba(154,107,36,0.18);
  border-radius: 100rpx;
}
.lang-btn:active { background: rgba(154,107,36,0.14); transform: scale(0.98); }
.lang-text { font-size: 24rpx; color: var(--accent-text); font-weight: 700; }

/* ══ 分类标签 ══ */
.category-scroll {
  background: rgba(247,245,239,0.90);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  border-bottom: 1rpx solid rgba(29,28,24,0.07);
}

.category-list {
  display: flex;
  padding: 18rpx 20rpx;
  gap: 12rpx;
  white-space: nowrap;
}

.category-tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  border-radius: 100rpx;
  background: rgba(255,255,255,0.76);
  border: 1rpx solid rgba(29,28,24,0.10);
  font-size: 26rpx;
  color: var(--text-secondary);
  white-space: nowrap;
  box-shadow: 0 3rpx 10rpx rgba(29,28,24,0.03);
  transition: background var(--motion-base), color var(--motion-base), box-shadow var(--motion-base), border-color var(--motion-base), transform var(--motion-base) var(--ease-out);
}

.category-tag.category-active {
  background: var(--accent-grad);
  border-color: transparent;
  color: #fff;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(29,28,24,0.12);
  transform: translateY(-1rpx);
}

/* ══ 列表头 ══ */
.list-header {
  display: flex; align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx 12rpx;
}

.filter-btn {
  font-size: 24rpx;
  color: var(--accent-text);
  padding: 10rpx 20rpx;
  background: rgba(154,107,36,0.08);
  border: 1rpx solid rgba(154,107,36,0.18);
  border-radius: 100rpx;
}
.filter-btn:active { background: rgba(154,107,36,0.14); transform: scale(0.98); }

/* ══ 活动列表 ══ */
.activity-list {
  padding: 8rpx 24rpx 180rpx;
  height: calc(100vh - 230rpx);
  box-sizing: border-box;
}

/* ══ 骨架屏 ══ */
.skeleton-card {
  background: var(--surface);
  border: 1rpx solid rgba(29,28,24,0.08);
  border-radius: 32rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-md);
}
.skeleton-img {
  height: 280rpx;
  background: linear-gradient(90deg,
    rgba(29,28,24,0.05) 25%,
    rgba(154,107,36,0.12) 50%,
    rgba(29,28,24,0.05) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.8s infinite;
}
.skeleton-body { padding: 28rpx 32rpx; }
.skeleton-line {
  height: 26rpx;
  background: linear-gradient(90deg,
    rgba(29,28,24,0.05) 25%,
    rgba(154,107,36,0.12) 50%,
    rgba(29,28,24,0.05) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.8s infinite;
  border-radius: 13rpx;
  margin-bottom: 16rpx;
}
.skeleton-animate { animation: shimmer 1.8s infinite; }
.w80 { width: 80%; }
.w50 { width: 50%; }
.w60 { width: 60%; }

@keyframes shimmer {
  0%   { background-position: -200% 0; }
  100% { background-position:  200% 0; }
}

/* ══ 加载更多 ══ */
.loading-more, .no-more {
  text-align: center;
  padding: 28rpx;
  color: var(--text-muted);
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.error-state {
  padding: 72rpx 48rpx;
}

.retry-btn {
  margin-top: 28rpx;
  min-width: 220rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  background: var(--accent-grad);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(29,28,24,0.14);
}
.retry-btn::after { border: none; }

/* ══ FAB（页面 2/3 位置） ══ */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: calc(100vh / 3 - 52rpx);
  width: 104rpx;
  height: 104rpx;
  background: var(--accent-grad);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 28rpx rgba(29,28,24,0.18);
  z-index: 50;
  transition: transform var(--motion-fast) var(--ease-out), box-shadow var(--motion-fast);
}
.fab:active {
  transform: translateY(3rpx) scale(0.95);
  box-shadow: 0 6rpx 16rpx rgba(29,28,24,0.14);
}

.fab-icon {
  color: #fff;
  font-size: 60rpx;
  font-weight: 300;
  line-height: 1;
  margin-top: -4rpx;
}

@media (prefers-reduced-motion: reduce) {
  .category-tag.category-active,
  .search-box:active,
  .fab:active {
    transform: none;
  }
  .skeleton-animate,
  .skeleton-img,
  .skeleton-line {
    animation: none;
  }
}
