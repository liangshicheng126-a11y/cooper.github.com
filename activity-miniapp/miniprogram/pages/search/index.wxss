/* pages/search/index.wxss · 简洁高级搜索页 */
.page {
  min-height: 100vh;
  background: var(--bg-radial);
}

/* ── 搜索栏 ── */
.search-bar {
  display: flex; align-items: center; gap: 12rpx;
  padding-bottom: 16rpx;
  padding-left: 20rpx;
  padding-right: 20rpx;
  box-sizing: border-box;
  background: rgba(247,245,239,0.96);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border-bottom: 1rpx solid rgba(29,28,24,0.08);
  box-shadow: 0 6rpx 16rpx rgba(29,28,24,0.04);
  position: sticky; top: 0; z-index: 20;
}

.back-btn {
  width: 64rpx; height: 64rpx; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
}
.back-arrow { font-size: 52rpx; color: var(--text-primary); font-weight: 300; line-height: 1; }

.search-input-wrap {
  flex: 1; display: flex; align-items: center; gap: 12rpx;
  background: rgba(255,255,255,0.82);
  border: 1rpx solid rgba(29,28,24,0.10);
  border-radius: 100rpx; padding: 14rpx 24rpx;
}
.search-icon-txt { font-size: 32rpx; opacity: 0.58; line-height: 1; }
.search-input {
  flex: 1; font-size: 28rpx; color: var(--text-primary);
  background: transparent;
}
.search-placeholder { color: var(--text-muted); }
.clear-btn { padding: 4rpx 8rpx; color: var(--text-muted); font-size: 26rpx; }

.search-btn-text {
  color: var(--accent-text); font-size: 28rpx; font-weight: 700;
  flex-shrink: 0; padding: 0 8rpx;
}

/* ── Section 标题 ── */
.section-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 32rpx 16rpx;
}
.section-label { font-size: 26rpx; font-weight: 700; color: var(--text-secondary); letter-spacing: 0.5rpx; }
.clear-text { font-size: 24rpx; color: var(--text-muted); }

/* ── 标签云 ── */
.tag-wrap { display: flex; flex-wrap: wrap; gap: 12rpx; padding: 0 28rpx 20rpx; }

.history-tag {
  padding: 12rpx 24rpx; border-radius: 100rpx;
  background: rgba(255,255,255,0.86);
  border: 1rpx solid rgba(29,28,24,0.10);
  font-size: 26rpx; color: var(--text-secondary);
  box-shadow: 0 3rpx 10rpx rgba(37,26,52,0.04);
}
.history-tag:active { background: rgba(154,107,36,0.08); }

.hot-tag {
  padding: 12rpx 24rpx; border-radius: 100rpx;
  background: rgba(154,107,36,0.08);
  border: 1rpx solid rgba(154,107,36,0.18);
  font-size: 26rpx; color: var(--accent-text);
}
.hot-tag:active { background: rgba(154,107,36,0.14); }

/* ── 结果 ── */
.result-count {
  padding: 16rpx 32rpx 8rpx;
  font-size: 24rpx; color: var(--text-muted);
}
.loading-wrap {
  display: flex; align-items: center; justify-content: center;
  padding: 80rpx;
}
.loading-text { font-size: 28rpx; color: var(--text-muted); }

.empty-state {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 80rpx 40rpx; gap: 16rpx;
}
.empty-icon { font-size: 80rpx; opacity: 0.45; }
.empty-text { font-size: 30rpx; font-weight: 700; color: var(--text-secondary); }
.empty-sub  { font-size: 24rpx; color: var(--text-muted); }

/* 结果卡片容器 */
activity-card { margin: 0 24rpx; display: block; }
