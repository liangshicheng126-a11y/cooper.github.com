/* pages/search/index.wxss · 白色毛玻璃搜索页 */
.page {
  min-height: 100vh;
  background: linear-gradient(145deg, #ede9fe 0%, #faf5ff 45%, #eff6ff 100%);
}

/* ── 搜索栏 ── */
.search-bar {
  display: flex; align-items: center; gap: 12rpx;
  padding: calc(env(safe-area-inset-top) + 16rpx) 20rpx 16rpx;
  background: rgba(255,255,255,0.82);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border-bottom: 1rpx solid rgba(124,58,237,0.08);
  box-shadow: 0 2rpx 12rpx rgba(109,40,217,0.05);
  position: sticky; top: 0; z-index: 20;
}

.back-btn {
  width: 64rpx; height: 64rpx; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
}
.back-arrow { font-size: 52rpx; color: #7c3aed; font-weight: 300; line-height: 1; }

.search-input-wrap {
  flex: 1; display: flex; align-items: center; gap: 12rpx;
  background: rgba(124,58,237,0.08);
  border: 1rpx solid rgba(124,58,237,0.15);
  border-radius: 100rpx; padding: 14rpx 24rpx;
}
.search-icon-txt { font-size: 28rpx; opacity: 0.55; }
.search-input {
  flex: 1; font-size: 28rpx; color: #1e1b4b;
  background: transparent;
}
.search-placeholder { color: rgba(30,27,75,0.38); }
.clear-btn { padding: 4rpx 8rpx; color: rgba(30,27,75,0.35); font-size: 26rpx; }

.search-btn-text {
  color: #7c3aed; font-size: 28rpx; font-weight: 600;
  flex-shrink: 0; padding: 0 8rpx;
}

/* ── Section 标题 ── */
.section-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 32rpx 16rpx;
}
.section-label { font-size: 26rpx; font-weight: 700; color: rgba(30,27,75,0.65); letter-spacing: 0.5rpx; }
.clear-text { font-size: 24rpx; color: rgba(30,27,75,0.38); }

/* ── 标签云 ── */
.tag-wrap { display: flex; flex-wrap: wrap; gap: 12rpx; padding: 0 28rpx 20rpx; }

.history-tag {
  padding: 12rpx 24rpx; border-radius: 100rpx;
  background: rgba(255,255,255,0.72);
  border: 1rpx solid rgba(124,58,237,0.12);
  font-size: 26rpx; color: rgba(30,27,75,0.65);
  box-shadow: 0 2rpx 8rpx rgba(109,40,217,0.05);
}
.history-tag:active { background: rgba(124,58,237,0.08); }

.hot-tag {
  padding: 12rpx 24rpx; border-radius: 100rpx;
  background: rgba(124,58,237,0.08);
  border: 1rpx solid rgba(124,58,237,0.16);
  font-size: 26rpx; color: #7c3aed;
}
.hot-tag:active { background: rgba(124,58,237,0.14); }

/* ── 结果 ── */
.result-count {
  padding: 16rpx 32rpx 8rpx;
  font-size: 24rpx; color: rgba(30,27,75,0.40);
}
.loading-wrap {
  display: flex; align-items: center; justify-content: center;
  padding: 80rpx;
}
.loading-text { font-size: 28rpx; color: rgba(30,27,75,0.42); }

.empty-state {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 80rpx 40rpx; gap: 16rpx;
}
.empty-icon { font-size: 80rpx; opacity: 0.45; }
.empty-text { font-size: 30rpx; font-weight: 600; color: rgba(30,27,75,0.55); }
.empty-sub  { font-size: 24rpx; color: rgba(30,27,75,0.35); }

/* 结果卡片容器 */
activity-card { margin: 0 24rpx; display: block; }
