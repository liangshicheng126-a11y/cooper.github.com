<!-- pages/register/index.wxml - 报名表单页 -->
<view class="page">
  <scroll-view scroll-y class="scroll-view">
    <!-- 活动简要信息 -->
    <view class="activity-brief card">
      <text class="brief-name">{{activity.name}}</text>
      <view class="brief-row">
        <text class="brief-icon">📅</text>
        <text class="brief-time">{{startTimeText}}</text>
      </view>
      <view class="brief-row" wx:if="{{subActivity}}">
        <text class="brief-icon">🎯</text>
        <text class="brief-time">场次：{{subActivity.name}} · {{subActivity.startTimeText}}</text>
      </view>
    </view>

    <!-- 邀请码输入（需要时显示） -->
    <view class="form-card card" wx:if="{{activity.requireInvite}}">
      <view class="invite-header">
        <text class="invite-icon">🔑</text>
        <view>
          <text class="invite-title">需要邀请码</text>
          <text class="invite-desc">请输入发布者提供的邀请码</text>
        </view>
      </view>
      <input
        class="invite-input {{inviteCodeError ? 'invite-input--error' : ''}}"
        placeholder="输入邀请码"
        value="{{inviteCode}}"
        bindinput="onInviteCodeInput"
        maxlength="12"
        style="text-transform:uppercase;letter-spacing:8rpx;text-align:center;font-size:36rpx;font-weight:700;"
      />
      <text class="invite-error" wx:if="{{inviteCodeError}}">{{inviteCodeError}}</text>
    </view>

    <!-- 报名表单 -->
    <view class="form-card card">
      <view class="section-title">填写报名信息</view>
      <custom-form id="customForm" fields="{{fields}}" bind:change="onFormChange" />
    </view>

    <view style="height: 200rpx;" />
  </scroll-view>

  <view class="bottom-bar">
    <button class="btn btn-primary btn-block btn-lg" bindtap="onSubmit" loading="{{submitting}}">
      提交报名
    </button>
  </view>
</view>
