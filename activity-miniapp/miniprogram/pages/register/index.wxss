/* pages/register/index.wxss · 白色毛玻璃报名页 */
.page {
  min-height: 100vh;
  background: linear-gradient(145deg, #ede9fe 0%, #faf5ff 45%, #eff6ff 100%);
}
.scroll-view { height: calc(100vh - 160rpx); }

/* ── 活动摘要卡 ── */
.activity-brief {
  margin: 24rpx 20rpx 20rpx;
  padding: 28rpx 32rpx;
  background: rgba(255,255,255,0.72);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1rpx solid rgba(255,255,255,0.95);
  border-radius: 24rpx;
  border-left: 4rpx solid #7c3aed;
  box-shadow: 0 6rpx 24rpx rgba(109,40,217,0.08);
}
.brief-name { font-size: 30rpx; font-weight: 700; color: #1e1b4b; display: block; margin-bottom: 16rpx; }
.brief-row  { display: flex; align-items: center; margin-bottom: 8rpx; }
.brief-icon { font-size: 26rpx; margin-right: 10rpx; opacity: 0.65; }
.brief-time { font-size: 26rpx; color: rgba(30,27,75,0.55); }

/* ── 表单卡片 ── */
.form-card {
  margin: 0 20rpx 20rpx;
  padding: 28rpx 32rpx;
  background: rgba(255,255,255,0.72);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1rpx solid rgba(255,255,255,0.95);
  border-radius: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(109,40,217,0.07);
}

/* ── 邀请码 ── */
.invite-header { display: flex; align-items: center; gap: 20rpx; margin-bottom: 24rpx; }
.invite-icon  { font-size: 44rpx; }
.invite-title { font-size: 28rpx; font-weight: 600; color: #1e1b4b; display: block; }
.invite-desc  { font-size: 22rpx; color: rgba(30,27,75,0.50); display: block; margin-top: 4rpx; }

.invite-input {
  width: 100%; height: 96rpx;
  background: rgba(255,255,255,0.80);
  border: 1.5rpx solid rgba(124,58,237,0.22);
  border-radius: 16rpx; color: #7c3aed;
  box-sizing: border-box; padding: 0 24rpx;
  font-size: 32rpx; letter-spacing: 4rpx; font-weight: 700;
  text-align: center; transition: border-color 0.2s;
}
.invite-input:focus {
  border-color: rgba(124,58,237,0.50);
  box-shadow: 0 0 0 4rpx rgba(124,58,237,0.10);
}
.invite-input--error {
  border-color: rgba(220,38,38,0.40);
  background: rgba(220,38,38,0.04);
}
.invite-error { color: #dc2626; font-size: 22rpx; margin-top: 10rpx; display: block; }
