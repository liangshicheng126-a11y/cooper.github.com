/* pages/register/index.wxss · 毛玻璃报名页 */
.page {
  min-height: 100vh;
  background: linear-gradient(145deg, #0d0b1e 0%, #1a1040 40%, #0d1f3c 100%);
}
.scroll-view { height: calc(100vh - 160rpx); }

/* ── 活动摘要卡 ── */
.activity-brief {
  margin: 24rpx 20rpx 20rpx;
  padding: 28rpx 32rpx;
  background: rgba(255,255,255,0.07);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 24rpx;
  border-left: 4rpx solid #a78bfa;
  position: relative;
  overflow: hidden;
}
.activity-brief::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  pointer-events: none;
}

.brief-name { font-size: 30rpx; font-weight: 700; color: rgba(255,255,255,0.95); display: block; margin-bottom: 16rpx; }
.brief-row  { display: flex; align-items: center; margin-bottom: 8rpx; }
.brief-icon { font-size: 26rpx; margin-right: 10rpx; opacity: 0.7; }
.brief-time { font-size: 26rpx; color: rgba(255,255,255,0.5); }

/* ── 表单卡片 ── */
.form-card {
  margin: 0 20rpx;
  padding: 28rpx 32rpx;
  background: rgba(255,255,255,0.07);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 24rpx;
  box-shadow: 0 6rpx 30rpx rgba(0,0,0,0.3);
  margin-bottom: 20rpx;
  position: relative;
}
.form-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent);
  pointer-events: none;
}

/* ── 邀请码 ── */
.invite-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}
.invite-icon  { font-size: 44rpx; }
.invite-title { font-size: 28rpx; font-weight: 600; color: rgba(255,255,255,0.9); display: block; }
.invite-desc  { font-size: 22rpx; color: rgba(255,255,255,0.45); display: block; margin-top: 4rpx; }

.invite-input {
  width: 100%;
  height: 96rpx;
  background: rgba(255,255,255,0.06);
  border: 1.5rpx solid rgba(167,139,250,0.3);
  border-radius: 16rpx;
  color: #c4b5fd;
  box-sizing: border-box;
  padding: 0 24rpx;
  font-size: 32rpx;
  letter-spacing: 4rpx;
  font-weight: 700;
  text-align: center;
  transition: border-color 0.2s;
}
.invite-input:focus {
  border-color: rgba(167,139,250,0.6);
  background: rgba(167,139,250,0.06);
}
.invite-input--error {
  border-color: rgba(248,113,113,0.5);
  background: rgba(248,113,113,0.06);
}
.invite-error {
  color: #f87171;
  font-size: 22rpx;
  margin-top: 10rpx;
  display: block;
}
