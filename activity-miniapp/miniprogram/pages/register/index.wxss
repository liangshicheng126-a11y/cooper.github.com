/* pages/register/index.wxss */
.page { min-height: 100vh; background: var(--gray-50); }
.scroll-view { height: calc(100vh - 160rpx); }

.activity-brief {
  margin: 24rpx 24rpx 20rpx;
  padding: 28rpx 32rpx;
  border-left: 8rpx solid var(--primary);
}

.brief-name { font-size: 30rpx; font-weight: 700; color: var(--gray-800); display: block; margin-bottom: 16rpx; }
.brief-row { display: flex; align-items: center; margin-bottom: 8rpx; }
.brief-icon { font-size: 26rpx; margin-right: 10rpx; }
.brief-time { font-size: 26rpx; color: var(--gray-500); }

.form-card {
  margin: 0 24rpx;
  padding: 28rpx 32rpx;
}

/* 邀请码 */
.invite-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}
.invite-icon   { font-size: 44rpx; }
.invite-title  { font-size: 28rpx; font-weight: 600; color: #1a1a1a; display: block; }
.invite-desc   { font-size: 22rpx; color: #888; display: block; margin-top: 4rpx; }

.invite-input {
  width: 100%;
  height: 96rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  border: 2rpx solid #f0f0f0;
  color: #d48806;
  box-sizing: border-box;
  padding: 0 24rpx;
}
.invite-input--error {
  border-color: #ff4d4f;
  background: #fff1f0;
}
.invite-error {
  color: #ff4d4f;
  font-size: 22rpx;
  margin-top: 10rpx;
  display: block;
}

