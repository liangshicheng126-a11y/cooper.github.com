/* pages/register/index.wxss · 简洁高级报名页 */
.page {
  min-height: 100vh;
  background: var(--bg-radial);
}
.scroll-view { height: calc(100vh - 160rpx); }

/* ── 活动摘要卡 ── */
.activity-brief {
  margin: 24rpx 20rpx 20rpx;
  padding: 28rpx 32rpx;
  background: var(--surface);
  border: 1rpx solid rgba(29,28,24,0.08);
  border-radius: 24rpx;
  border-left: 6rpx solid var(--accent);
  box-shadow: var(--shadow-md);
}
.brief-name { font-size: 30rpx; font-weight: 760; color: var(--text-primary); display: block; margin-bottom: 16rpx; }
.brief-row  { display: flex; align-items: flex-start; margin-bottom: 8rpx; gap: 12rpx; }
.brief-icon { width: 52rpx; font-size: 21rpx; line-height: 34rpx; color: var(--text-muted); flex-shrink: 0; }
.brief-time { font-size: 26rpx; color: var(--text-secondary); }

/* ── 表单卡片 ── */
.form-card {
  margin: 0 20rpx 20rpx;
  padding: 28rpx 32rpx;
  background: var(--surface);
  border: 1rpx solid rgba(29,28,24,0.08);
  border-radius: 24rpx;
  box-shadow: var(--shadow-md);
}

/* ── 邀请码 ── */
.invite-header { display: flex; align-items: center; gap: 20rpx; margin-bottom: 24rpx; }
.invite-icon  { width: 52rpx; height: 52rpx; border-radius: 50%; background: var(--accent-light); color: var(--accent-text); font-size: 24rpx; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.invite-title { font-size: 28rpx; font-weight: 700; color: var(--text-primary); display: block; }
.invite-desc  { font-size: 22rpx; color: var(--text-muted); display: block; margin-top: 4rpx; }

.invite-input {
  width: 100%; height: 96rpx;
  background: rgba(255,255,255,0.88);
  border: 1.5rpx solid rgba(154,107,36,0.22);
  border-radius: 16rpx; color: var(--accent-text);
  box-sizing: border-box; padding: 0 24rpx;
  font-size: 32rpx; letter-spacing: 4rpx; font-weight: 700;
  text-align: center; transition: border-color var(--motion-base), box-shadow var(--motion-base), background var(--motion-base);
}
.invite-input:focus {
  border-color: rgba(154,107,36,0.48);
  box-shadow: 0 0 0 5rpx rgba(154,107,36,0.10);
}
.invite-input--error {
  border-color: rgba(220,38,38,0.40);
  background: rgba(220,38,38,0.04);
}
.invite-error { color: #dc2626; font-size: 22rpx; margin-top: 10rpx; display: block; }
