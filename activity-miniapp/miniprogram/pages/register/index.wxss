/* pages/register/index.wxss · 活力年轻报名页 */
.page {
  min-height: 100vh;
  background: var(--bg-radial);
}
.scroll-view { height: calc(100vh - 160rpx); }

/* ── 活动摘要卡 ── */
.activity-brief {
  margin: 24rpx 20rpx 20rpx;
  padding: 28rpx 32rpx;
  background: var(--surface);
  backdrop-filter: blur(14px) saturate(150%);
  -webkit-backdrop-filter: blur(14px) saturate(150%);
  border: 1rpx solid rgba(255,255,255,0.95);
  border-radius: 24rpx;
  border-left: 6rpx solid var(--accent);
  box-shadow: var(--shadow-md);
}
.brief-name { font-size: 30rpx; font-weight: 800; color: var(--text-primary); display: block; margin-bottom: 16rpx; }
.brief-row  { display: flex; align-items: center; margin-bottom: 8rpx; }
.brief-icon { font-size: 26rpx; margin-right: 10rpx; opacity: 0.65; }
.brief-time { font-size: 26rpx; color: var(--text-secondary); }

/* ── 表单卡片 ── */
.form-card {
  margin: 0 20rpx 20rpx;
  padding: 28rpx 32rpx;
  background: var(--surface);
  backdrop-filter: blur(14px) saturate(150%);
  -webkit-backdrop-filter: blur(14px) saturate(150%);
  border: 1rpx solid rgba(255,255,255,0.95);
  border-radius: 24rpx;
  box-shadow: var(--shadow-md);
}

/* ── 邀请码 ── */
.invite-header { display: flex; align-items: center; gap: 20rpx; margin-bottom: 24rpx; }
.invite-icon  { font-size: 44rpx; }
.invite-title { font-size: 28rpx; font-weight: 700; color: var(--text-primary); display: block; }
.invite-desc  { font-size: 22rpx; color: var(--text-muted); display: block; margin-top: 4rpx; }

.invite-input {
  width: 100%; height: 96rpx;
  background: rgba(255,255,255,0.88);
  border: 1.5rpx solid rgba(255,90,61,0.22);
  border-radius: 16rpx; color: var(--accent-text);
  box-sizing: border-box; padding: 0 24rpx;
  font-size: 32rpx; letter-spacing: 4rpx; font-weight: 700;
  text-align: center; transition: border-color var(--motion-base), box-shadow var(--motion-base), background var(--motion-base);
}
.invite-input:focus {
  border-color: rgba(255,90,61,0.50);
  box-shadow: 0 0 0 5rpx rgba(255,90,61,0.11);
}
.invite-input--error {
  border-color: rgba(220,38,38,0.40);
  background: rgba(220,38,38,0.04);
}
.invite-error { color: #dc2626; font-size: 22rpx; margin-top: 10rpx; display: block; }
