<!-- pages/admin/index.wxml - 管理员后台 -->
<view class="page">
  <!-- 顶部 Tab -->
  <view class="admin-tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="admin-tab {{activeTab === item.key ? 'tab-active' : ''}}"
      data-tab="{{item.key}}"
      bindtap="switchTab"
    >
      <text>{{item.label}}</text>
    </view>
  </view>

  <scroll-view scroll-y class="scroll-view">
    <!-- Tab: 报名名单 -->
    <view wx:if="{{activeTab === 'list'}}">
      <!-- 活动选择 -->
      <view class="filter-bar">
        <picker mode="selector" range="{{myActivities}}" range-key="name" value="{{selectedActivityIdx}}" bindchange="onActivityChange">
          <view class="activity-picker">
            <text class="picker-activity-name">{{selectedActivity.name || '选择活动'}}</text>
            <text class="picker-arrow">▾</text>
          </view>
        </picker>

        <!-- 子活动筛选 -->
        <scroll-view scroll-x class="sub-filter-scroll" wx:if="{{subActivities.length > 0}}">
          <view class="sub-filter-list">
            <view
              class="sub-filter-tag {{selectedSubId === 'all' ? 'tag-active' : ''}}"
              data-id="all"
              bindtap="onFilterSub"
            >全部场次</view>
            <view
              wx:for="{{subActivities}}"
              wx:key="id"
              wx:for-item="sub"
              class="sub-filter-tag {{selectedSubId === sub.id ? 'tag-active' : ''}}"
              data-id="{{sub.id}}"
              bindtap="onFilterSub"
            >{{sub.name}}</view>
          </view>
        </scroll-view>
      </view>

      <view class="roster-check-bar card" wx:if="{{rosterChoices.length > 1}}">
        <picker mode="selector" range="{{rosterChoices}}" range-key="title" value="{{rosterPickIdx}}" bindchange="onRosterForCheckChange">
          <view class="roster-picker-line">
            <text class="roster-picker-label">对照名册</text>
            <text class="roster-picker-val">{{rosterChoices[rosterPickIdx].title}}</text>
            <text class="picker-arrow">▾</text>
          </view>
        </picker>
        <text class="roster-summary" wx:if="{{rosterMatchSummary}}">{{rosterMatchSummary}}</text>
        <text class="roster-hint">按报名表中带手机号的字段、学号类字段自动比对名册</text>
      </view>

      <!-- 搜索 -->
      <view class="search-bar">
        <input class="search-input" placeholder="搜索姓名/手机号..." value="{{searchKeyword}}" bindinput="onSearch" />
        <text class="result-count">共 {{filteredList.length}} 人</text>
      </view>

      <!-- 脱敏提示 -->
      <view class="desensitize-tip">
        <text class="tip-icon">隐</text>
        <text class="tip-text">敏感信息已脱敏，点击"查看"按钮显示明文（操作将被记录）</text>
      </view>

      <!-- 名单列表 -->
      <view wx:for="{{filteredList}}" wx:key="id" class="registration-item card">
        <view class="reg-header">
          <image src="{{item.avatarUrl || '/images/default-avatar.svg'}}" class="reg-avatar" lazy-load />
          <view class="reg-info">
            <text class="reg-name">{{item.displayName}}</text>
            <text class="reg-time">{{item.registrationTimeText}}</text>
          </view>
          <text class="reg-roster-tag" wx:if="{{item.rosterCheckLabel}}">{{item.rosterCheckLabel}}</text>
          <view class="reg-checkin {{item.checkinTime ? 'checkin-done' : ''}}" wx:if="{{item.checkinTime}}">
            <text>✓ 已签到</text>
          </view>
          <view class="reg-actions">
            <text class="action-reveal" data-id="{{item.id}}" bindtap="revealData">查看</text>
          </view>
        </view>

        <!-- 自定义字段 -->
        <view class="reg-fields" wx:if="{{item.expandedFields}}">
          <view wx:for="{{item.expandedFields}}" wx:key="key" wx:for-item="field" class="field-row">
            <text class="field-key">{{field.label}}：</text>
            <text class="field-val">{{field.value}}</text>
          </view>
        </view>
      </view>

      <!-- 底部：导出 -->
      <view class="export-bar">
        <button class="btn btn-outline" bindtap="onExportExcel">导出 Excel</button>
      </view>
    </view>

    <!-- Tab: 学生名册（Excel 导入） -->
    <view wx:if="{{activeTab === 'roster'}}">
      <view class="card roster-guide">
        <view class="section-title">批量导入在校生/名单</view>
        <text class="guide-p">从学校教务导出的表格中选择文件上传。识别列名包括但不限于：</text>
        <text class="guide-li">姓名（必填）</text>
        <text class="guide-li">学号、手机、班级、年级、备注</text>
        <text class="guide-li">中英文表头皆可；其它列写入「额外信息」以备核对。</text>
      </view>
      <view class="card roster-form">
        <text class="input-label">名册名称</text>
        <input class="roster-title-input" placeholder="如：机电学院2024级在校生" value="{{newRosterTitle}}" bindinput="onRosterTitleInput" />
        <button class="btn btn-primary btn-block mt-16" bindtap="tapImportRosterExcel">从聊天中选择 Excel (.xlsx)</button>
      </view>
      <view class="section-title px-24">已导入名册</view>
      <view wx:for="{{rosters}}" wx:key="id" class="card roster-card">
        <view class="roster-card-head">
          <text class="roster-card-title">{{item.title}}</text>
          <text class="roster-meta">{{item.rowSuccess}} 人 · {{item.sourceFilename}}</text>
        </view>
        <view class="roster-card-actions">
          <button size="mini" class="btn btn-outline" data-id="{{item.id}}" bindtap="tapPreviewRoster">预览前100条</button>
          <button size="mini" class="btn btn-danger-plain" data-id="{{item.id}}" bindtap="tapDeleteRoster">删除</button>
        </view>
      </view>
      <view class="card" wx:if="{{rosterStudentPreview.length}}">
        <view class="section-title">预览（{{rosterStudentPreview.length}} / {{rosterPreviewTotal}}）</view>
        <scroll-view scroll-y class="preview-scroll">
          <view wx:for="{{rosterStudentPreview}}" wx:key="id" class="preview-row">
            <text class="p-name">{{item.name}}</text>
            <text class="p-sub">{{item.studentNo}} {{item.clazz}} {{item.grade}}</text>
            <text class="p-phone">{{item.phoneMasked}}</text>
          </view>
        </scroll-view>
      </view>
      <view class="empty-state" wx:if="{{rosters.length === 0}}">
        <text class="empty-icon">·</text>
        <text class="empty-text">暂无名册，请先导入 Excel</text>
      </view>
    </view>

    <!-- Tab: 活动分析 -->
    <view wx:if="{{activeTab === 'analytics'}}">
      <view class="analytics-card card">
        <view class="section-title">报名趋势</view>
        <view class="trend-chart">
          <view
            wx:for="{{trendData}}"
            wx:key="date"
            class="trend-bar-wrap"
          >
            <view class="trend-bar" style="height:{{item.heightPct}}%">
              <text class="trend-num">{{item.count}}</text>
            </view>
            <text class="trend-date">{{item.dateLabel}}</text>
          </view>
        </view>
      </view>

      <view class="analytics-card card">
        <view class="section-title">数据概览</view>
        <view class="overview-grid">
          <view class="overview-item">
            <text class="overview-num text-primary">{{analytics.totalRegistrations}}</text>
            <text class="overview-label">报名总数</text>
          </view>
          <view class="overview-item">
            <text class="overview-num text-success">{{analytics.checkinCount}}</text>
            <text class="overview-label">已签到</text>
          </view>
          <view class="overview-item">
            <text class="overview-num text-warning">{{analytics.cancelCount}}</text>
            <text class="overview-label">取消报名</text>
          </view>
          <view class="overview-item">
            <text class="overview-num text-danger">{{analytics.checkinRate}}%</text>
            <text class="overview-label">到场率</text>
          </view>
        </view>
      </view>

      <!-- 字段分布（如性别、地区） -->
      <view class="analytics-card card" wx:for="{{analytics.fieldStats}}" wx:key="key" wx:for-item="stat">
        <view class="section-title">{{stat.label}} 分布</view>
        <view wx:for="{{stat.distribution}}" wx:key="value" wx:for-item="d" class="dist-item">
          <view class="dist-label-row">
            <text class="dist-label">{{d.value}}</text>
            <text class="dist-count">{{d.count}}人 ({{d.pct}}%)</text>
          </view>
          <view class="dist-track">
            <view class="dist-fill" style="width:{{d.pct}}%" />
          </view>
        </view>
      </view>
    </view>

    <!-- Tab: 平台活动审核（ADMIN_OPENIDS 账号） -->
    <view wx:if="{{activeTab === 'moderate'}}">
      <view class="moderate-intro card" wx:if="{{isPlatformAdmin}}">
        <text class="moderate-intro-text">待审核的活动不会出现在「发现」广场；通过后方可被报名。</text>
      </view>
      <view wx:if="{{!isPlatformAdmin}}" class="empty-state card">
        <text class="empty-icon">隐</text>
        <text class="empty-text">仅平台管理员可审核活动（请在服务端配置 ADMIN_OPENIDS）</text>
      </view>

      <view wx:if="{{isPlatformAdmin}}">
        <view wx:for="{{pendingModerations}}" wx:key="id" class="card moderate-card">
          <view class="moderate-head" bindtap="tapPendingActivityDetail" data-id="{{item.id}}">
            <text class="moderate-title">{{item.name}}</text>
            <text class="moderate-meta">{{item.startTimeText}} · {{item.category}}</text>
          </view>
          <text class="moderate-creator" wx:if="{{item.creatorNickname}}">发起人：{{item.creatorNickname}}</text>
          <view class="moderate-actions">
            <button class="btn btn-sm btn-outline" bindtap="onModerationReject" data-id="{{item.id}}">驳回</button>
            <button class="btn btn-sm btn-primary" bindtap="onModerationPass" data-id="{{item.id}}">通过</button>
          </view>
        </view>
        <view class="empty-state" wx:if="{{pendingModerations.length === 0}}">
          <text class="empty-icon">✅</text>
          <text class="empty-text">暂无待审核活动</text>
        </view>
      </view>
    </view>

    <!-- Tab: 举报管理 -->
    <view wx:if="{{activeTab === 'reports'}}">
      <view wx:for="{{reportList}}" wx:key="id" class="report-item card">
        <view class="report-header">
          <text class="report-activity">{{item.activityName}}</text>
          <view class="report-status {{item.handled ? 'handled' : 'pending-status'}}">
            <text>{{item.handled ? '已处理' : '待处理'}}</text>
          </view>
        </view>
        <text class="report-reason">举报原因：{{item.reason}}</text>
        <text class="report-time">{{item.createdAtText}}</text>
        <view class="report-actions" wx:if="{{!item.handled}}">
          <button class="btn btn-sm btn-gray" data-id="{{item.id}}" bindtap="onIgnoreReport">忽略</button>
          <button class="btn btn-sm btn-danger" data-id="{{item.activityId}}" bindtap="onOfflineFromReport">下架活动</button>
        </view>
      </view>

      <view class="empty-state" wx:if="{{reportList.length === 0}}">
        <text class="empty-icon">✅</text>
        <text class="empty-text">暂无举报</text>
      </view>
    </view>

    <view style="height: 60rpx;" />
  </scroll-view>
</view>
