/* pages/admin/index.wxss · 活力年轻管理后台 */
.page {
  min-height: 100vh;
  background: var(--bg-radial);
}
.scroll-view { height: calc(100vh - 100rpx); }

/* ── Tab ── */
.admin-tabs {
  display: flex;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
  border-bottom: 1rpx solid rgba(255,90,61,0.10);
  box-shadow: 0 6rpx 18rpx rgba(255,90,61,0.08);
}
.admin-tab {
  flex: 1; text-align: center; padding: 28rpx 0;
  font-size: 26rpx; color: var(--text-muted); transition: color var(--motion-base);
}
.tab-active { color: var(--accent-text); font-weight: 700; border-bottom: 4rpx solid var(--accent); }

/* ── 活动审核（平台管理员） ── */
.moderate-intro { margin: 20rpx 24rpx; padding: 20rpx 24rpx; }
.moderate-intro-text { font-size: 24rpx; color: var(--text-secondary); line-height: 1.55; }
.moderate-card { margin: 0 24rpx 20rpx; padding: 24rpx; }
.moderate-head { padding-bottom: 12rpx; }
.moderate-title { font-size: 30rpx; font-weight: 700; color: var(--text-primary); display: block; }
.moderate-meta { font-size: 24rpx; color: var(--text-muted); margin-top: 6rpx; display: block; }
.moderate-creator { font-size: 24rpx; color: #64748b; margin-bottom: 20rpx; display: block; }
.moderate-actions { display: flex; gap: 16rpx; justify-content: flex-end; }

/* ── 筛选栏 ── */
.filter-bar {
  background: rgba(255,255,255,0.78);
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  padding: 20rpx 24rpx; border-bottom: 1rpx solid rgba(255,90,61,0.08);
}
.activity-picker {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 24rpx;
  background: rgba(255,90,61,0.08);
  border: 1rpx solid rgba(255,90,61,0.20); border-radius: 16rpx;
}
.picker-activity-name { font-size: 28rpx; color: var(--accent-text); font-weight: 700; flex: 1; }
.picker-arrow { font-size: 24rpx; color: var(--accent-text); }

.sub-filter-scroll { margin-top: 16rpx; }
.sub-filter-list { display: flex; gap: 12rpx; padding: 4rpx 0; white-space: nowrap; }
.sub-filter-tag {
  padding: 10rpx 24rpx; border-radius: 100rpx;
  background: rgba(255,255,255,0.72);
  border: 1rpx solid rgba(255,90,61,0.14);
  font-size: 24rpx; color: var(--text-secondary); white-space: nowrap;
}
.tag-active {
  background: var(--accent-grad);
  border-color: transparent; color: #fff; font-weight: 600;
}

/* ── 搜索 ── */
.search-bar {
  display: flex; align-items: center; padding: 16rpx 24rpx;
  background: rgba(255,255,255,0.55); gap: 20rpx;
  border-bottom: 1rpx solid var(--divider);
}
.search-input {
  flex: 1; background: rgba(255,255,255,0.80);
  border: 1rpx solid rgba(255,90,61,0.16); border-radius: 100rpx;
  padding: 14rpx 28rpx; font-size: 26rpx; color: var(--text-primary);
}
.result-count { font-size: 24rpx; color: var(--text-muted); white-space: nowrap; }

/* ── 脱敏提示 ── */
.desensitize-tip {
  display: flex; align-items: center; padding: 16rpx 24rpx;
  background: rgba(217,119,6,0.07); border-bottom: 1rpx solid rgba(217,119,6,0.15); gap: 12rpx;
}
.tip-icon { font-size: 28rpx; }
.tip-text { font-size: 22rpx; color: #92400e; }

/* ── 名单项 ── */
.registration-item {
  margin: 16rpx 20rpx 0; padding: 24rpx 28rpx;
  background: var(--surface);
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  border: 1rpx solid rgba(255,255,255,0.95);
  border-radius: 20rpx;
  box-shadow: var(--shadow-sm);
}
.reg-header { display: flex; align-items: center; gap: 16rpx; flex-wrap: wrap; }
.reg-roster-tag {
  font-size: 20rpx; color: #2563eb; background: rgba(37,99,235,0.08);
  padding: 6rpx 14rpx; border-radius: 100rpx; border: 1rpx solid rgba(37,99,235,0.2);
}

.roster-check-bar {
  margin: 16rpx 20rpx 0; padding: 20rpx 24rpx;
}
.roster-picker-line {
  display: flex; align-items: center; gap: 12rpx;
}
.roster-picker-label { font-size: 24rpx; color: var(--text-muted); }
.roster-picker-val { flex: 1; font-size: 26rpx; color: var(--accent-text); font-weight: 700; }
.roster-summary { display: block; margin-top: 12rpx; font-size: 24rpx; color: #059669; }
.roster-hint { display: block; margin-top: 8rpx; font-size: 22rpx; color: var(--text-muted); }

.roster-guide { margin: 20rpx; padding: 24rpx 28rpx; }
.guide-p { display: block; font-size: 24rpx; color: var(--text-secondary); margin-bottom: 12rpx; }
.guide-li { display: block; font-size: 22rpx; color: var(--text-muted); margin-left: 8rpx; line-height: 1.6; }

.roster-form { margin: 0 20rpx 20rpx; padding: 24rpx 28rpx; }
.input-label { font-size: 24rpx; color: var(--text-muted); }
.roster-title-input {
  margin-top: 12rpx; padding: 16rpx 24rpx; border-radius: 12rpx;
  border: 1rpx solid rgba(255,90,61,0.2); background: rgba(255,255,255,0.9);
  font-size: 28rpx;
}
.mt-16 { margin-top: 16rpx; }
.px-24 { padding-left: 24rpx; padding-right: 24rpx; }

.roster-card { margin: 12rpx 20rpx; padding: 24rpx 28rpx; }
.roster-card-head { margin-bottom: 16rpx; }
.roster-card-title { font-size: 30rpx; font-weight: 700; color: var(--text-primary); display: block; }
.roster-meta { font-size: 22rpx; color: var(--text-muted); display: block; margin-top: 8rpx; }
.roster-card-actions { display: flex; gap: 16rpx; }

.btn-danger-plain {
  background: rgba(239,68,68,0.08); color: #dc2626; border: 1rpx solid rgba(239,68,68,0.25);
}

.preview-scroll { max-height: 480rpx; margin-top: 16rpx; }
.preview-row {
  display: flex; flex-direction: column; padding: 16rpx 0;
  border-bottom: 1rpx solid var(--divider);
}
.p-name { font-size: 28rpx; font-weight: 600; color: var(--text-primary); }
.p-sub { font-size: 22rpx; color: var(--text-muted); margin-top: 4rpx; }
.p-phone { font-size: 22rpx; color: var(--accent-text); margin-top: 4rpx; }

.reg-avatar {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: var(--accent-light);
  border: 2rpx solid rgba(255,255,255,0.90);
}
.reg-info { flex: 1; }
.reg-name { font-size: 28rpx; font-weight: 600; color: var(--text-primary); display: block; }
.reg-time { font-size: 22rpx; color: var(--text-muted); display: block; margin-top: 4rpx; }

.reg-checkin { padding: 8rpx 16rpx; border-radius: 100rpx; font-size: 20rpx; }
.checkin-done { background: rgba(5,150,105,0.10); color: #059669; border: 1rpx solid rgba(5,150,105,0.22); }

.action-reveal { font-size: 24rpx; color: var(--accent-text); padding: 8rpx 16rpx; }

.reg-fields {
  margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid var(--divider);
}
.field-row { display: flex; margin-bottom: 8rpx; }
.field-key { font-size: 24rpx; color: var(--text-muted); width: 160rpx; flex-shrink: 0; }
.field-val { font-size: 24rpx; color: var(--text-secondary); flex: 1; }

/* ── 导出 ── */
.export-bar { padding: 24rpx; display: flex; justify-content: center; }

/* ── 分析卡片 ── */
.analytics-card {
  margin: 20rpx 20rpx 0; padding: 28rpx 32rpx;
  background: rgba(255,255,255,0.72);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255,255,255,0.95);
  border-radius: 24rpx; box-shadow: 0 6rpx 24rpx rgba(109,40,217,0.07);
}

.trend-chart {
  display: flex; align-items: flex-end; gap: 12rpx;
  height: 200rpx; padding-bottom: 40rpx;
  border-bottom: 1rpx solid rgba(30,27,75,0.08);
}
.trend-bar-wrap {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: flex-end; height: 100%;
}
.trend-bar {
  width: 100%;
  background: linear-gradient(to top, #7c3aed, #a78bfa);
  border-radius: 6rpx 6rpx 0 0;
  display: flex; align-items: flex-start; justify-content: center;
  min-height: 8rpx;
  box-shadow: 0 -4rpx 10rpx rgba(124,58,237,0.18);
}
.trend-num  { font-size: 18rpx; color: #fff; padding-top: 4rpx; }
.trend-date { font-size: 18rpx; color: rgba(30,27,75,0.40); margin-top: 8rpx; white-space: nowrap; }

.overview-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20rpx; margin-top: 16rpx; }
.overview-item {
  background: rgba(124,58,237,0.05);
  border: 1rpx solid rgba(124,58,237,0.10);
  border-radius: 16rpx; padding: 24rpx; text-align: center;
}
.overview-num   { font-size: 48rpx; font-weight: 800; display: block; }
.overview-label { font-size: 22rpx; color: rgba(30,27,75,0.45); margin-top: 8rpx; display: block; }
.text-primary { color: #7c3aed; }
.text-success { color: #059669; }
.text-warning { color: #d97706; }
.text-danger  { color: #dc2626; }

/* ── 分布条 ── */
.dist-item { margin-bottom: 20rpx; }
.dist-label-row { display: flex; justify-content: space-between; margin-bottom: 8rpx; }
.dist-label { font-size: 26rpx; color: rgba(30,27,75,0.75); }
.dist-count { font-size: 24rpx; color: rgba(30,27,75,0.42); }
.dist-track { height: 10rpx; background: rgba(30,27,75,0.08); border-radius: 100rpx; overflow: hidden; }
.dist-fill  { height: 100%; background: linear-gradient(90deg, #7c3aed, #3b82f6); border-radius: 100rpx; }

/* ── 举报 ── */
.report-item {
  margin: 16rpx 20rpx 0; padding: 24rpx 28rpx;
  background: rgba(255,255,255,0.72); border: 1rpx solid rgba(255,255,255,0.95);
  border-radius: 20rpx;
}
.report-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12rpx; }
.report-activity { font-size: 28rpx; font-weight: 600; color: #1e1b4b; flex: 1; }
.report-status { padding: 6rpx 16rpx; border-radius: 100rpx; font-size: 20rpx; }
.handled        { background: rgba(30,27,75,0.06); color: rgba(30,27,75,0.42); border: 1rpx solid rgba(30,27,75,0.12); }
.pending-status { background: rgba(220,38,38,0.08); color: #dc2626; border: 1rpx solid rgba(220,38,38,0.18); }
.report-reason  { font-size: 26rpx; color: rgba(30,27,75,0.60); display: block; margin-bottom: 8rpx; }
.report-time    { font-size: 22rpx; color: rgba(30,27,75,0.38); display: block; margin-bottom: 16rpx; }
.report-actions { display: flex; gap: 16rpx; }
