/* pages/admin/index.wxss */
.page { min-height: 100vh; background: var(--gray-50); }
.scroll-view { height: calc(100vh - 100rpx); }

/* Tab */
.admin-tabs {
  display: flex;
  background: #FFFFFF;
  box-shadow: var(--shadow-sm);
}
.admin-tab {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 26rpx;
  color: var(--gray-400);
}
.tab-active { color: var(--primary); font-weight: 700; border-bottom: 4rpx solid var(--primary); }

/* 筛选栏 */
.filter-bar {
  background: #FFFFFF;
  padding: 20rpx 24rpx;
  box-shadow: var(--shadow-sm);
}

.activity-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: var(--primary-light);
  border-radius: var(--radius-md);
}

.picker-activity-name { font-size: 28rpx; color: var(--primary); font-weight: 600; flex: 1; }
.picker-arrow { font-size: 24rpx; color: var(--primary); }

.sub-filter-scroll { margin-top: 16rpx; }
.sub-filter-list { display: flex; gap: 12rpx; padding: 4rpx 0; white-space: nowrap; }
.sub-filter-tag {
  padding: 10rpx 24rpx;
  border-radius: 100rpx;
  background: var(--gray-100);
  font-size: 24rpx;
  color: var(--gray-500);
  white-space: nowrap;
}
.tag-active { background: var(--primary); color: #FFFFFF; }

/* 搜索 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #FFFFFF;
  gap: 20rpx;
  border-bottom: 1rpx solid var(--gray-100);
}
.search-input {
  flex: 1;
  background: var(--gray-100);
  border-radius: 100rpx;
  padding: 14rpx 28rpx;
  font-size: 26rpx;
}
.result-count { font-size: 24rpx; color: var(--gray-400); white-space: nowrap; }

/* 脱敏提示 */
.desensitize-tip {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #FFFBEB;
  gap: 12rpx;
}
.tip-icon { font-size: 28rpx; }
.tip-text { font-size: 22rpx; color: #92400E; }

/* 名单项 */
.registration-item {
  margin: 16rpx 24rpx 0;
  padding: 24rpx 28rpx;
  border-radius: var(--radius-lg);
}

.reg-header { display: flex; align-items: center; gap: 16rpx; }
.reg-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; background: var(--gray-100); }
.reg-info { flex: 1; }
.reg-name { font-size: 28rpx; font-weight: 600; color: var(--gray-800); display: block; }
.reg-time { font-size: 22rpx; color: var(--gray-400); display: block; margin-top: 4rpx; }

.reg-checkin {
  padding: 8rpx 16rpx;
  border-radius: 100rpx;
  font-size: 20rpx;
}
.checkin-done { background: #DCFCE7; color: #16A34A; }

.action-reveal { font-size: 24rpx; color: var(--primary); padding: 8rpx 16rpx; }

.reg-fields {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--gray-100);
}
.field-row { display: flex; margin-bottom: 8rpx; }
.field-key { font-size: 24rpx; color: var(--gray-400); width: 160rpx; flex-shrink: 0; }
.field-val { font-size: 24rpx; color: var(--gray-700); flex: 1; }

/* 导出 */
.export-bar {
  padding: 24rpx 24rpx;
  display: flex;
  justify-content: center;
}

/* 分析 */
.analytics-card {
  margin: 20rpx 24rpx 0;
  padding: 28rpx 32rpx;
}

.trend-chart {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  height: 200rpx;
  padding-bottom: 40rpx;
  border-bottom: 2rpx solid var(--gray-100);
}

.trend-bar-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  height: 100%;
}

.trend-bar {
  width: 100%;
  background: linear-gradient(var(--primary), #7C3AED);
  border-radius: 6rpx 6rpx 0 0;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  min-height: 8rpx;
}

.trend-num { font-size: 18rpx; color: #FFFFFF; padding-top: 4rpx; }
.trend-date { font-size: 18rpx; color: var(--gray-400); margin-top: 8rpx; white-space: nowrap; }

.overview-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-top: 16rpx;
}

.overview-item {
  background: var(--gray-50);
  border-radius: var(--radius-md);
  padding: 24rpx;
  text-align: center;
}

.overview-num { font-size: 48rpx; font-weight: 800; display: block; }
.overview-label { font-size: 22rpx; color: var(--gray-400); margin-top: 8rpx; display: block; }
.text-primary { color: var(--primary); }
.text-success { color: var(--success); }
.text-warning { color: var(--warning); }
.text-danger { color: var(--danger); }

/* 分布条 */
.dist-item { margin-bottom: 20rpx; }
.dist-label-row { display: flex; justify-content: space-between; margin-bottom: 8rpx; }
.dist-label { font-size: 26rpx; color: var(--gray-700); }
.dist-count { font-size: 24rpx; color: var(--gray-400); }
.dist-track { height: 12rpx; background: var(--gray-100); border-radius: 100rpx; overflow: hidden; }
.dist-fill { height: 100%; background: linear-gradient(90deg, #6366F1, #4F46E5); border-radius: 100rpx; }

/* 举报 */
.report-item {
  margin: 16rpx 24rpx 0;
  padding: 24rpx 28rpx;
}
.report-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12rpx; }
.report-activity { font-size: 28rpx; font-weight: 600; color: var(--gray-800); flex: 1; }
.report-status { padding: 6rpx 16rpx; border-radius: 100rpx; font-size: 20rpx; }
.handled { background: var(--gray-100); color: var(--gray-400); }
.pending-status { background: #FEE2E2; color: #DC2626; }
.report-reason { font-size: 26rpx; color: var(--gray-500); display: block; margin-bottom: 8rpx; }
.report-time { font-size: 22rpx; color: var(--gray-400); display: block; margin-bottom: 16rpx; }
.report-actions { display: flex; gap: 16rpx; }
