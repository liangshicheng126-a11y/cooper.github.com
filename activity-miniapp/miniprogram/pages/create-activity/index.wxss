/* pages/create-activity/index.wxss */
.page { min-height: 100vh; background: var(--gray-50); }
.scroll-view { height: calc(100vh - 200rpx); }

/* 步骤条 */
.step-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 40rpx;
  background: #FFFFFF;
  box-shadow: var(--shadow-sm);
}

.step-item {
  display: flex;
  align-items: center;
  position: relative;
}

.step-circle {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 3rpx solid var(--gray-300);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--gray-400);
  font-weight: 700;
  background: #FFFFFF;
  flex-shrink: 0;
  transition: all 0.2s;
}

.step-active .step-circle {
  border-color: var(--primary);
  background: var(--primary);
  color: #FFFFFF;
}

.step-done .step-circle {
  border-color: var(--success);
  background: var(--success);
  color: #FFFFFF;
}

.step-label {
  font-size: 22rpx;
  color: var(--gray-400);
  margin-left: 8rpx;
}

.step-active .step-label { color: var(--primary); font-weight: 600; }
.step-done .step-label { color: var(--success); }

.step-line {
  width: 60rpx;
  height: 3rpx;
  background: var(--gray-200);
  margin: 0 12rpx;
}

/* 内容区 */
.step-content { padding: 20rpx 0; }
.section-card { margin: 0 24rpx 20rpx; padding: 28rpx 32rpx; }

.category-scroll { margin-top: 8rpx; }
.cat-list { display: flex; gap: 12rpx; white-space: nowrap; padding: 4rpx 0; }
.cat-item {
  padding: 12rpx 24rpx;
  border-radius: 100rpx;
  background: var(--gray-100);
  font-size: 26rpx;
  color: var(--gray-600);
  white-space: nowrap;
}
.cat-active { background: var(--primary); color: #FFFFFF; }

/* 封面 */
.cover-picker {
  width: 100%;
  height: 280rpx;
  border: 3rpx dashed var(--gray-300);
  border-radius: var(--radius-lg);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--gray-50);
}

.cover-preview { width: 100%; height: 100%; }

.cover-placeholder-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.cover-plus { font-size: 80rpx; color: var(--gray-300); line-height: 1; }
.cover-hint { font-size: 26rpx; color: var(--gray-400); }

/* 地点 */
.location-picker {
  border: 2rpx solid var(--gray-200);
  border-radius: var(--radius-md);
  padding: 24rpx 28rpx;
  background: var(--gray-50);
}

.location-selected {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.location-name { font-size: 28rpx; font-weight: 600; color: var(--gray-800); display: block; }
.location-addr { font-size: 24rpx; color: var(--gray-400); display: block; margin-top: 4rpx; }
.location-change { font-size: 26rpx; color: var(--primary); }

.location-empty {
  display: flex;
  align-items: center;
  gap: 12rpx;
  justify-content: center;
}
.location-icon { font-size: 32rpx; }
.location-hint { font-size: 28rpx; color: var(--gray-400); }

.map-preview { margin-top: 20rpx; border-radius: var(--radius-md); overflow: hidden; }
.mini-map { width: 100%; height: 240rpx; }

/* 子活动 */
.section-title-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.add-sub-btn { font-size: 26rpx; color: var(--primary); font-weight: 600; }

.sub-form-item {
  border: 2rpx solid var(--gray-200);
  border-radius: var(--radius-md);
  padding: 20rpx;
  margin-top: 20rpx;
}

.sub-form-header { display: flex; justify-content: space-between; margin-bottom: 16rpx; }
.sub-form-title { font-size: 26rpx; font-weight: 600; color: var(--gray-700); }
.sub-form-del { font-size: 26rpx; color: var(--danger); }

/* 人数限制 */
.limit-toggle {
  display: flex;
  border: 2rpx solid var(--gray-200);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.limit-option {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--gray-500);
  transition: all 0.15s;
}

.limit-active { background: var(--primary); color: #FFFFFF; font-weight: 600; }

/* 字段设置 */
.field-toggle-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--gray-100);
}

.field-info { flex: 1; }
.field-name { font-size: 28rpx; color: var(--gray-700); font-weight: 500; }
.field-desc { font-size: 22rpx; color: var(--gray-400); display: block; margin-top: 4rpx; }

.field-switches { display: flex; gap: 12rpx; }

.field-switch-btn, .field-required-btn {
  padding: 10rpx 20rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  background: var(--gray-100);
  color: var(--gray-500);
  transition: all 0.15s;
}

.switch-on { background: #DCFCE7; color: #16A34A; }
.required-on { background: #FEE2E2; color: #DC2626; }

.custom-fields-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 32rpx;
  margin-bottom: 16rpx;
}
.add-field-btn { font-size: 26rpx; color: var(--primary); font-weight: 600; }

.custom-field-item {
  padding: 20rpx;
  border: 2rpx solid var(--gray-200);
  border-radius: var(--radius-md);
  margin-bottom: 16rpx;
}

.custom-field-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.field-del-btn { font-size: 32rpx; color: var(--gray-400); padding: 8rpx; }
.form-hint-inline { font-size: 22rpx; color: var(--gray-400); font-weight: 400; }
.mt-12 { margin-top: 16rpx; }
.mt-16 { margin-top: 20rpx; }

/* 底部 */
.btn-row { display: flex; gap: 20rpx; }
