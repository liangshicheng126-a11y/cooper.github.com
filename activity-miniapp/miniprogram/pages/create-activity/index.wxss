/* pages/create-activity/index.wxss · 毛玻璃发布活动 */
.page {
  min-height: 100vh;
  background: linear-gradient(145deg, #0d0b1e 0%, #1a1040 40%, #0d1f3c 100%);
}
.scroll-view { height: calc(100vh - 200rpx); }

/* ── 步骤条 ── */
.step-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 40rpx;
  background: rgba(13,11,30,0.8);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}

.step-item { display: flex; align-items: center; position: relative; }

.step-circle {
  width: 52rpx; height: 52rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255,255,255,0.18);
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx;
  color: rgba(255,255,255,0.35);
  font-weight: 700;
  background: rgba(255,255,255,0.05);
  flex-shrink: 0;
  transition: all 0.3s;
}

.step-active .step-circle {
  border-color: #a78bfa;
  background: linear-gradient(135deg, #7c3aed, #2563eb);
  color: #fff;
  box-shadow: 0 4rpx 20rpx rgba(124,58,237,0.45);
}

.step-done .step-circle {
  border-color: #34d399;
  background: rgba(52,211,153,0.2);
  color: #34d399;
}

.step-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.35);
  margin-left: 8rpx;
}
.step-active .step-label { color: #c4b5fd; font-weight: 600; }
.step-done .step-label   { color: #34d399; }

.step-line {
  width: 60rpx; height: 2rpx;
  background: rgba(255,255,255,0.1);
  margin: 0 12rpx;
}

/* ── 内容区 ── */
.step-content { padding: 20rpx 0; }
.section-card {
  margin: 0 20rpx 20rpx;
  padding: 28rpx 32rpx;
  background: rgba(255,255,255,0.07);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 24rpx;
  box-shadow: 0 6rpx 30rpx rgba(0,0,0,0.3);
  position: relative;
}
.section-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  pointer-events: none;
}

/* ── 分类 ── */
.category-scroll { margin-top: 8rpx; }
.cat-list { display: flex; gap: 12rpx; white-space: nowrap; padding: 4rpx 0; }
.cat-item {
  padding: 12rpx 24rpx;
  border-radius: 100rpx;
  background: rgba(255,255,255,0.07);
  border: 1rpx solid rgba(255,255,255,0.11);
  font-size: 26rpx;
  color: rgba(255,255,255,0.55);
  white-space: nowrap;
  transition: all 0.2s;
}
.cat-active {
  background: linear-gradient(135deg, rgba(124,58,237,0.5), rgba(37,99,235,0.5));
  border-color: rgba(167,139,250,0.4);
  color: #fff;
  font-weight: 600;
}

/* ── 封面选择 ── */
.cover-picker {
  width: 100%; height: 280rpx;
  border: 2rpx dashed rgba(255,255,255,0.18);
  border-radius: 20rpx;
  overflow: hidden;
  display: flex; align-items: center; justify-content: center;
  background: rgba(255,255,255,0.04);
  transition: border-color 0.2s, background 0.2s;
}
.cover-picker:active { background: rgba(255,255,255,0.07); border-color: rgba(167,139,250,0.4); }

.cover-preview { width: 100%; height: 100%; }

.cover-placeholder-btn { display: flex; flex-direction: column; align-items: center; gap: 12rpx; }
.cover-plus { font-size: 80rpx; color: rgba(255,255,255,0.2); line-height: 1; }
.cover-hint { font-size: 26rpx; color: rgba(255,255,255,0.35); }

/* ── 地点 ── */
.location-picker {
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  background: rgba(255,255,255,0.05);
  transition: border-color 0.2s;
}
.location-picker:active { border-color: rgba(167,139,250,0.4); }

.location-selected { display: flex; align-items: center; justify-content: space-between; }
.location-name  { font-size: 28rpx; font-weight: 600; color: rgba(255,255,255,0.9); display: block; }
.location-addr  { font-size: 24rpx; color: rgba(255,255,255,0.4); display: block; margin-top: 4rpx; }
.location-change { font-size: 26rpx; color: #a78bfa; }

.location-empty { display: flex; align-items: center; gap: 12rpx; justify-content: center; }
.location-icon  { font-size: 32rpx; opacity: 0.6; }
.location-hint  { font-size: 28rpx; color: rgba(255,255,255,0.35); }

.map-preview { margin-top: 20rpx; border-radius: 12rpx; overflow: hidden; }
.mini-map    { width: 100%; height: 240rpx; }

/* ── 子活动 ── */
.section-title-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.add-sub-btn { font-size: 26rpx; color: #a78bfa; font-weight: 600; }

.sub-form-item {
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-top: 20rpx;
  background: rgba(255,255,255,0.04);
}

.sub-form-header { display: flex; justify-content: space-between; margin-bottom: 16rpx; }
.sub-form-title  { font-size: 26rpx; font-weight: 600; color: rgba(255,255,255,0.7); }
.sub-form-del    { font-size: 26rpx; color: #f87171; }

/* ── 人数限制切换 ── */
.limit-toggle {
  display: flex;
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 16rpx;
  overflow: hidden;
}
.limit-option {
  flex: 1; text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: rgba(255,255,255,0.45);
  transition: all 0.15s;
  background: rgba(255,255,255,0.04);
}
.limit-active {
  background: linear-gradient(135deg, rgba(124,58,237,0.45), rgba(37,99,235,0.45));
  color: #fff;
  font-weight: 600;
}

/* ── 字段开关 ── */
.field-toggle-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.07);
}
.field-info { flex: 1; }
.field-name  { font-size: 28rpx; color: rgba(255,255,255,0.8); font-weight: 500; }
.field-desc  { font-size: 22rpx; color: rgba(255,255,255,0.35); display: block; margin-top: 4rpx; }
.field-switches { display: flex; gap: 12rpx; }

.field-switch-btn, .field-required-btn {
  padding: 10rpx 20rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  background: rgba(255,255,255,0.07);
  color: rgba(255,255,255,0.4);
  border: 1rpx solid rgba(255,255,255,0.1);
  transition: all 0.15s;
}
.switch-on   { background: rgba(52,211,153,0.15);  color: #34d399; border-color: rgba(52,211,153,0.3); }
.required-on { background: rgba(248,113,113,0.15); color: #f87171; border-color: rgba(248,113,113,0.3); }

.custom-fields-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-top: 32rpx; margin-bottom: 16rpx;
}
.add-field-btn { font-size: 26rpx; color: #a78bfa; font-weight: 600; }

.custom-field-item {
  padding: 20rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  background: rgba(255,255,255,0.04);
}
.custom-field-row { display: flex; align-items: center; gap: 12rpx; }
.field-del-btn { font-size: 32rpx; color: rgba(255,255,255,0.3); padding: 8rpx; }
.form-hint-inline { font-size: 22rpx; color: rgba(255,255,255,0.3); font-weight: 400; }
.mt-12 { margin-top: 16rpx; }
.mt-16 { margin-top: 20rpx; }

/* ── 底部按钮行 ── */
.btn-row { display: flex; gap: 20rpx; }

/* ── 邀请码 ── */
.invite-code-box {
  margin-top: 24rpx;
  background: rgba(167,139,250,0.07);
  border: 1rpx solid rgba(167,139,250,0.25);
  border-radius: 16rpx;
  padding: 24rpx;
}
.invite-code-label {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
}
.invite-auto-btn {
  color: #a78bfa;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  background: rgba(167,139,250,0.12);
  border: 1rpx solid rgba(167,139,250,0.25);
  border-radius: 20rpx;
}
.invite-code-input-row { display: flex; gap: 12rpx; align-items: center; }
.invite-code-input {
  flex: 1;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(167,139,250,0.35);
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 36rpx;
  letter-spacing: 8rpx;
  font-weight: 700;
  color: #c4b5fd;
  text-align: center;
}
.invite-copy-btn {
  padding: 0 28rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #7c3aed, #2563eb);
  color: #fff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  font-size: 26rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(124,58,237,0.35);
}
