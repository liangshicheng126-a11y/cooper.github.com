/* pages/my-registered/index.wxss */
.page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(40rpx + env(safe-area-inset-bottom));
  background: var(--bg-radial);
}

.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 50vh;
  padding: 40rpx;
}

.state-wrap.empty { gap: 16rpx; }
.state-text { font-size: 28rpx; color: var(--text-muted); }

.empty-icon { font-size: 80rpx; }
.empty-title { font-size: 30rpx; color: var(--text-primary); font-weight: 700; margin-bottom: 24rpx; }

.btn-primary {
  margin-top: 8rpx;
  background: var(--accent-grad);
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 56rpx;
  border-radius: 100rpx;
  border: none;
}

.btn-primary::after { border: none; }

.list-wrap { padding-bottom: 24rpx; }

.my-activity-item {
  display: flex;
  margin-bottom: 20rpx;
  overflow: hidden;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.82);
  border: 1rpx solid rgba(255,255,255,0.95);
  box-shadow: var(--shadow-md);
}

.my-activity-item:active {
  opacity: 0.92;
  transform: scale(0.99);
}

.item-cover-box { position: relative; width: 200rpx; height: 160rpx; flex-shrink: 0; flex-grow: 0; overflow: hidden; }
.item-cover-fallback {
  position: absolute; inset: 0;
  background: linear-gradient(145deg, #fff7ed 0%, #fff1f2 48%, #eef2ff 100%);
}
.item-cover { width: 200rpx; height: 160rpx; flex-shrink: 0; flex-grow: 0; }

.item-body {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.text-ellipsis {
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.item-info-row { margin-top: 8rpx; }
.item-loc-row { margin-top: 6rpx; }
.item-time { font-size: 22rpx; color: var(--text-muted); }
.item-loc { font-size: 22rpx; color: var(--accent-text); }

.item-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 10rpx;
  gap: 12rpx;
}

.status-mini {
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  font-size: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.status-mini-active { background: rgba(5,150,105,0.10); color: #059669; border: 1rpx solid rgba(5,150,105,0.20); }
.status-mini-upcoming { background: rgba(217,119,6,0.10); color: #d97706; border: 1rpx solid rgba(217,119,6,0.20); }
.status-mini-ended { background: rgba(37,26,52,0.06); color: var(--text-muted); border: 1rpx solid rgba(37,26,52,0.12); }
.status-mini-full { background: rgba(220,38,38,0.08); color: #dc2626; border: 1rpx solid rgba(220,38,38,0.18); }

.item-meta {
  font-size: 21rpx;
  color: var(--text-muted);
  text-align: right;
  flex: 1;
  min-width: 0;
}
