<!-- pages/activity-detail/index.wxml -->
<view class="page-wrap">

  <!-- 与胶囊垂直对齐，避免压住状态栏时间 -->
  <view
    class="nav-back-slot"
    style="top: {{navBackTop}}px; height: {{navBackHeight}}px;"
    bindtap="goBack"
  >
    <view class="nav-back-circle">
      <text class="nav-back-arrow">‹</text>
    </view>
  </view>

  <!-- 骨架屏（加载中） -->
  <view wx:if="{{loading}}" class="skeleton-wrap">
    <view class="skeleton-cover skeleton-shine" />
    <view class="skeleton-body">
      <view class="skeleton-line w90 skeleton-shine" style="height:40rpx;margin-bottom:24rpx;" />
      <view class="skeleton-line w60 skeleton-shine" />
      <view class="skeleton-line w75 skeleton-shine" />
      <view class="skeleton-line w50 skeleton-shine" />
    </view>
  </view>

  <!-- 加载失败 -->
  <view wx:elif="{{loadError}}" class="error-state">
    <text class="error-icon">⚠️</text>
    <text class="error-text">活动信息加载失败</text>
    <view class="btn btn-primary btn-sm" style="margin-top:24rpx;" bindtap="onRetry">重新加载</view>
  </view>

  <!-- ===== 正文内容（原生滚动） ===== -->
  <block wx:else>

    <!-- 封面图 -->
    <view class="cover-section">
      <image wx:if="{{activity.coverImage}}" src="{{activity.coverImage}}" mode="aspectFill" class="cover-image" />
      <view wx:else class="cover-placeholder"><text class="cover-emoji">🎊</text></view>
      <view class="cover-gradient" />
    </view>

    <!-- 主信息卡 -->
    <view class="main-card">
      <view class="hero-title-block">
        <view class="hero-title-row">
          <text class="activity-title">{{activity.name}}</text>
        </view>
        <view class="hero-meta">
          <text class="category-chip">{{categoryLabel}}</text>
          <view class="status-badge {{statusClass}}">
            <view class="pulse-dot" wx:if="{{statusKey === 'active'}}" />
            <text>{{statusText}}</text>
          </view>
        </view>
        <text class="creator-line" wx:if="{{activity.creatorNickname}}">发起人 · {{activity.creatorNickname}}</text>
      </view>
      <view class="divider" />

      <!-- 时间 -->
      <view class="info-item info-item--time">
        <view class="info-icon-wrap bg-blue"><text class="info-emoji">📅</text></view>
        <view class="info-content">
          <text class="info-label">活动时间</text>
          <text class="info-value info-value--strong">开始 {{scheduleStartFull}}</text>
          <text class="info-value info-value--end">结束 {{scheduleEndFull}}</text>
          <text class="info-duration-pill" wx:if="{{scheduleDurationNatural}}">{{scheduleDurationNatural}}</text>
        </view>
      </view>

      <!-- 地点（手动填写，无导航坐标时可复制） -->
      <view class="info-item" bindtap="onCopyLocation" wx:if="{{activity.locationName || activity.locationAddress}}">
        <view class="info-icon-wrap bg-green"><text class="info-emoji">📍</text></view>
        <view class="info-content flex-1">
          <text class="info-label">活动地点</text>
          <text class="info-value" wx:if="{{activity.locationName}}">{{activity.locationName}}</text>
          <text class="info-sub" wx:if="{{activity.locationAddress}}">{{activity.locationAddress}}</text>
          <text class="info-sub info-copy-hint">轻触复制完整地址</text>
        </view>
      </view>

      <!-- 人数 -->
      <view class="info-item">
        <view class="info-icon-wrap bg-purple"><text class="info-emoji">👥</text></view>
        <view class="info-content flex-1">
          <text class="info-label">报名人数</text>
          <view class="participants-row">
            <text class="participants-num">{{activity.registrationCount}}</text>
            <text class="participants-total" wx:if="{{activity.maxParticipants > 0}}"> / {{activity.maxParticipants}} 人</text>
            <text class="participants-total" wx:else>人（不限）</text>
          </view>
        </view>
        <view class="progress-mini" wx:if="{{activity.maxParticipants > 0}}">
          <view class="progress-track-mini">
            <view class="progress-fill-mini {{progressClass}}" style="width:{{progressPct}}%" />
          </view>
          <text class="progress-mini-pct">{{progressPct}}%</text>
        </view>
      </view>

      <!-- 邀请码提示 -->
      <view wx:if="{{activity.requireInvite}}" class="invite-banner">
        <text class="invite-banner-icon">🔑</text>
        <view class="invite-banner-info">
          <text class="invite-banner-title">需要邀请码才能报名</text>
          <view wx:if="{{isCreator && activity.inviteCode}}" class="invite-code-reveal">
            <text class="invite-code-text">{{showInviteCode ? activity.inviteCode : '••••••'}}</text>
            <text class="invite-code-eye" bindtap="toggleInviteCode">{{showInviteCode ? '隐藏' : '查看'}}</text>
            <text class="invite-code-copy" bindtap="copyInviteCode">复制</text>
          </view>
        </view>
      </view>

      <!-- 提醒 -->
      <view class="reminder-box" wx:if="{{activity.reminder}}">
        <text class="reminder-icon">💡</text>
        <text class="reminder-text">{{activity.reminder}}</text>
      </view>
    </view>

    <!-- 活动交流群 -->
    <view
      wx:if="{{hasWxGroupQr && wxGroupVisible}}"
      id="wx-group-card"
      class="section-card wx-group-card {{wxGroupHighlight ? 'wx-group-card--highlight' : ''}}"
    >
      <view class="section-head-row">
        <view class="section-title section-title--bare">活动交流群（自愿加入）</view>
      </view>
      <text class="wx-group-name" wx:if="{{activity.wxGroupChatName}}">「{{activity.wxGroupChatName}}」</text>
      <image
        class="wx-group-qrcode"
        src="{{activity.wxGroupChatQrcodeUrl}}"
        mode="widthFix"
        show-menu-by-longpress
      />
      <text class="wx-group-hint">长按二维码识别，是否加群请自行判断</text>
    </view>
    <view class="section-card wx-group-teaser" wx:elif="{{hasWxGroupQr && !wxGroupVisible}}">
      <text class="section-title section-title--bare">活动交流群</text>
      <text class="wx-group-teaser-desc">群主已上传群二维码，报名成功后可在此处自愿扫码加入。</text>
    </view>

    <!-- 场次 -->
    <view class="section-card" wx:if="{{subActivities.length > 0}}">
      <view class="section-title">选择场次</view>
      <view
        wx:for="{{subActivities}}" wx:key="id"
        class="sub-item {{selectedSubId === item.id ? 'sub-selected' : ''}} {{item.isFull ? 'sub-disabled' : ''}}"
        data-id="{{item.id}}" bindtap="onSelectSub"
      >
        <view class="sub-left">
          <view class="sub-radio {{selectedSubId === item.id ? 'radio-checked' : ''}}" />
          <view class="sub-info">
            <text class="sub-name">{{item.name}}</text>
            <text class="sub-time">{{item.startTimeText}} ~ {{item.endTimeText}}</text>
            <text class="sub-location" wx:if="{{item.locationName}}">📍 {{item.locationName}}</text>
          </view>
        </view>
        <view class="sub-right">
          <text class="sub-count {{item.isFull ? 'text-danger' : 'text-primary'}}">
            {{item.registrationCount}}<text wx:if="{{item.maxParticipants > 0}}"> / {{item.maxParticipants}}</text>
          </text>
          <text class="sub-status" wx:if="{{item.isFull}}">已报满</text>
        </view>
      </view>
    </view>

    <!-- 活动详情 -->
    <view class="section-card" wx:if="{{activity.description}}">
      <view class="section-title">活动详情</view>
      <text class="desc-text {{descExpanded ? '' : 'desc-collapsed'}}">{{activity.description}}</text>
      <view class="expand-btn" wx:if="{{activity.description && activity.description.length > 120}}" bindtap="toggleDesc">
        <text>{{descExpanded ? '收起 ↑' : '查看更多 ↓'}}</text>
      </view>
    </view>

    <!-- 已报名用户 -->
    <view class="section-card participants-card" wx:if="{{activity.registrationCount > 0}}">
      <view class="section-head-row">
        <view class="section-title section-title--bare">已报名</view>
        <text class="section-count-pill">{{activity.registrationCount}} 人</text>
      </view>
      <text class="participants-hint" wx:if="{{registrantSlots.length}}">展示最近报名者头像（最多 8 位）</text>
      <view class="avatar-list avatar-list--lg">
        <image
          wx:for="{{registrantSlots}}"
          wx:key="key"
          src="{{item.avatarUrl}}"
          mode="aspectFill"
          class="registrant-avatar"
        />
        <view class="avatar-more" wx:if="{{activity.registrationCount > 8}}">
          <text>+{{activity.registrationCount - 8}}</text>
        </view>
      </view>
    </view>

    <!-- 管理操作 -->
    <view class="section-card" wx:if="{{isCreator}}">
      <view class="section-title">管理操作</view>
      <view class="admin-actions">
        <view class="admin-action-btn" bindtap="onViewRegistrations">
          <text class="admin-icon">📋</text><text>查看名单</text>
        </view>
        <view class="admin-action-btn" bindtap="onCheckinQR">
          <text class="admin-icon">✅</text><text>核验二维码</text>
        </view>
        <view class="admin-action-btn" bindtap="onShareQR">
          <text class="admin-icon">🔗</text><text>分享二维码</text>
        </view>
        <view class="admin-action-btn" bindtap="onNotifyAll">
          <text class="admin-icon">🔔</text><text>通知全员</text>
        </view>
        <view class="admin-action-btn" bindtap="goWxGroupSetup">
          <text class="admin-icon">👥</text><text>交流群设置</text>
        </view>
        <view class="admin-action-btn" bindtap="onEditActivity">
          <text class="admin-icon">✏️</text><text>编辑活动</text>
        </view>
        <view class="admin-action-btn danger" bindtap="onOfflineActivity" wx:if="{{activity.status !== 'offline'}}">
          <text class="admin-icon">⏹</text><text>下架活动</text>
        </view>
      </view>
    </view>

    <!-- 已报名者：扫码签到（扫描主办方核验码） -->
    <view class="section-card registrant-checkin-card" wx:if="{{isRegistered && !isCreator}}">
      <view class="section-title">现场签到</view>
      <text class="registrant-checkin-hint">到场后请使用下方入口，扫描主办方出示的二维码完成签到。</text>
      <view class="admin-action-btn registrant-checkin-btn" bindtap="onRegistrantCheckin">
        <text class="admin-icon">📷</text><text>签到二维码</text>
      </view>
    </view>

    <!-- 复制 / 举报（不与底部「转发」重复图标入口） -->
    <view class="extras-bar">
      <view class="extras-inner">
        <view class="extras-chip" bindtap="onCopyLink">
          <text class="extras-chip-ico">📋</text>
          <text class="extras-chip-txt">复制活动摘要</text>
        </view>
        <view class="extras-chip extras-chip--danger" wx:if="{{!isCreator && activity.id}}" bindtap="onReport">
          <text class="extras-chip-ico">⚑</text>
          <text class="extras-chip-txt">举报</text>
        </view>
      </view>
    </view>

  </block>

  <!-- 底部操作栏（固定） -->
  <view class="bottom-bar" wx:if="{{!loading && !loadError}}">
    <view wx:if="{{!isRegistered && !isCreator}}" class="bottom-main-row">
      <button class="share-btn" open-type="share">
        <text class="share-btn-icon">↗</text>
      </button>
      <button class="btn btn-primary flex-1 btn-lg" bindtap="onRegister" disabled="{{cannotRegister}}">
        <text wx:if="{{statusKey === 'full'}}">已报满</text>
        <text wx:elif="{{statusKey === 'ended'}}">活动已结束</text>
        <text wx:else>立即报名</text>
      </button>
    </view>
    <view wx:elif="{{isRegistered && !isCreator}}" class="registered-bar">
      <view class="registered-tag">
        <text class="registered-check">✓</text><text>已报名</text>
      </view>
      <button class="btn btn-primary btn-sm flex-1" open-type="share">转发给好友</button>
      <button class="btn btn-gray btn-sm flex-1" bindtap="onCancelRegistration">取消报名</button>
    </view>
    <view wx:elif="{{isCreator}}" class="creator-bar">
      <button class="share-btn" open-type="share">
        <text class="share-btn-icon">↗</text>
      </button>
      <button class="btn btn-outline flex-1" bindtap="onEditActivity">编辑</button>
      <button class="btn btn-primary flex-1" bindtap="onViewRegistrations">查看名单</button>
    </view>
  </view>

  <!-- 时间冲突弹窗 -->
  <view class="mask" wx:if="{{showConflictModal}}" catchtap="">
    <view class="conflict-modal">
      <text class="conflict-title">⚠️ 时间冲突提示</text>
      <text class="conflict-desc">您已报名的「{{conflictActivity}}」与此场次时间重叠，是否仍要报名？</text>
      <view class="conflict-actions">
        <button class="btn btn-gray btn-sm" bindtap="cancelConflict">取消</button>
        <button class="btn btn-primary btn-sm" bindtap="forceRegister">我已知晓，仍要报名</button>
      </view>
    </view>
  </view>

</view>
