/* pages/activity-detail/index.wxss */

/* ===== 页面容器 ===== */
.page-wrap {
  min-height: 100vh;
  background: linear-gradient(145deg, #ede9fe 0%, #faf5ff 45%, #eff6ff 100%);
  padding-bottom: 200rpx;
  overflow-x: hidden;
}

/* ===== 固定返回键（顶、高与右上角胶囊对齐，全小程序自定义导航页保持一致）===== */
.nav-back-slot {
  position: fixed;
  left: 24rpx;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-back-circle {
  width: 64rpx;
  height: 64rpx;
  min-width: 64rpx;
  min-height: 64rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(120,80,220,0.14);
}
.nav-back-arrow {
  font-size: 40rpx;
  color: #5b21b6;
  line-height: 1;
  font-weight: 300;
}

/* ===== 骨架屏 ===== */
.skeleton-wrap { padding: 0 0 200rpx; background: linear-gradient(145deg, #ede9fe 0%, #faf5ff 45%, #eff6ff 100%); min-height: 100vh; }
.skeleton-cover { width: 100%; height: 260rpx; background: rgba(200,180,255,0.3); }
.skeleton-body { padding: 32rpx; }
.skeleton-line { border-radius: 14rpx; margin-bottom: 20rpx; background: rgba(200,180,255,0.3); }
.skeleton-line.w90 { width: 90%; }
.skeleton-line.w75 { width: 75%; height: 28rpx; }
.skeleton-line.w60 { width: 60%; height: 28rpx; }
.skeleton-line.w50 { width: 50%; height: 28rpx; }
.skeleton-shine {
  background: linear-gradient(90deg, rgba(200,180,255,0.2) 25%, rgba(220,200,255,0.45) 50%, rgba(200,180,255,0.2) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.6s infinite;
}
@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

/* ===== 错误状态 ===== */
.error-state {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  min-height: 60vh; padding: 80rpx 40rpx;
}
.error-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.error-text { font-size: 30rpx; color: #7c3aed; opacity: .7; text-align: center; }
.btn-sm { padding: 16rpx 40rpx; border-radius: 40rpx; font-size: 28rpx; }

/* ===== 封面 ===== */
.cover-section {
  position: relative;
  height: 260rpx;
  overflow: hidden;
}
.cover-image { width: 100%; height: 100%; }
.cover-placeholder {
  width: 100%;
  height: 100%;
  min-height: 260rpx;
  display: flex; align-items: center; justify-content: center;
  background: linear-gradient(145deg, #e9d5ff 0%, #c4b5fd 40%, #a5b4fc 100%);
}
.cover-emoji { font-size: 56rpx; }
.cover-gradient {
  position: absolute; bottom: 0; left: 0; right: 0;
  height: 120rpx;
  background: linear-gradient(to top, rgba(240,236,255,1) 0%, transparent 100%);
}

/* ===== 主信息卡 ===== */
.main-card {
  position: relative;
  z-index: 2;
  margin: -40rpx 20rpx 20rpx;
  background: rgba(255,255,255,0.98);
  border-radius: 32rpx;
  border: 1rpx solid rgba(255,255,255,1);
  box-shadow: 0 16rpx 48rpx rgba(91,33,182,0.12), 0 4rpx 12rpx rgba(91,33,182,0.06);
  padding: 48rpx 32rpx 36rpx;
  overflow: visible;
}

/* ===== section card ===== */
.section-card {
  margin: 0 20rpx 20rpx;
  background: rgba(255,255,255,0.92);
  border-radius: 28rpx;
  border: 1rpx solid rgba(255,255,255,0.98);
  box-shadow: 0 8rpx 28rpx rgba(120,80,220,0.08);
  padding: 32rpx;
}

/* ===== 标题区 ===== */
.hero-title-block { margin-bottom: 8rpx; padding-top: 4rpx; }

.hero-title-row { margin-bottom: 20rpx; }

.activity-title {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: #1e1b4b;
  line-height: 1.35;
  letter-spacing: 0.5rpx;
}

.hero-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.category-chip {
  font-size: 22rpx;
  font-weight: 700;
  color: #5b21b6;
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  background: rgba(124,58,237,0.12);
  border: 1rpx solid rgba(124,58,237,0.2);
}

.creator-line {
  display: block;
  font-size: 24rpx;
  color: rgba(30,27,75,0.45);
}

.hero-meta .status-badge { margin-left: 0; }

/* ===== 状态角标 ===== */
.status-badge {
  display: flex; align-items: center; gap: 8rpx;
  padding: 8rpx 20rpx; border-radius: 40rpx;
  font-size: 24rpx; font-weight: 600; flex-shrink: 0;
}
.status-badge.badge-active   { background: rgba(16,185,129,.15); color: #059669; }
.status-badge.badge-upcoming { background: rgba(124,58,237,.12);  color: #7c3aed; }
.status-badge.badge-ended    { background: rgba(100,116,139,.12); color: #64748b; }
.status-badge.badge-full     { background: rgba(245,158,11,.12);  color: #d97706; }
.status-badge.badge-offline  { background: rgba(239,68,68,.12);   color: #dc2626; }
.pulse-dot {
  width: 14rpx; height: 14rpx; border-radius: 50%;
  background: #10b981;
  animation: pulse 1.8s ease-in-out infinite;
}
@keyframes pulse { 0%,100%{transform:scale(1);opacity:1} 50%{transform:scale(1.5);opacity:.5} }

.divider { height: 1rpx; background: rgba(124,58,237,.1); margin: 0 0 20rpx; }

/* ===== info item ===== */
.info-item {
  display: flex; align-items: flex-start;
  gap: 20rpx; margin-bottom: 20rpx;
}
.info-icon-wrap {
  width: 64rpx; height: 64rpx; border-radius: 16rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.bg-blue   { background: rgba(99,102,241,.12); }
.bg-green  { background: rgba(16,185,129,.12); }
.bg-purple { background: rgba(124,58,237,.12); }
.info-emoji { font-size: 34rpx; }
.info-content { flex: 1; min-width: 0; }
.info-label  { font-size: 24rpx; color: #7c3aed; opacity: .75; display: block; margin-bottom: 4rpx; }
.info-value  { font-size: 30rpx; color: #1e1b4b; font-weight: 600; display: block; line-height: 1.45; }
.info-sub    { font-size: 24rpx; color: #64748b; display: block; margin-top: 6rpx; line-height: 1.45; }
.info-copy-hint { font-size: 22rpx; color: #7c3aed; opacity: 0.85; margin-top: 10rpx; }
.info-item--time .info-content .info-label { margin-bottom: 12rpx; }

.info-value--strong {
  font-size: 30rpx;
  font-weight: 700;
  color: #312e81;
  margin-top: 4rpx;
}

.info-value--end {
  font-size: 28rpx;
  font-weight: 600;
  color: #4338ca;
  margin-top: 8rpx;
}

.info-duration-pill {
  display: inline-block;
  margin-top: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #6d28d9;
  padding: 10rpx 22rpx;
  border-radius: 100rpx;
  background: linear-gradient(135deg, rgba(124,58,237,0.1), rgba(99,102,241,0.08));
  border: 1rpx solid rgba(124,58,237,0.18);
}
.flex-1 { flex: 1; }

/* 人数 */
.participants-row { display: flex; align-items: baseline; gap: 4rpx; }
.participants-num   { font-size: 40rpx; color: #7c3aed; font-weight: 700; }
.participants-total { font-size: 26rpx; color: #64748b; }
.progress-mini { display: flex; flex-direction: column; align-items: flex-end; gap: 4rpx; align-self: center; }
.progress-track-mini { width: 120rpx; height: 8rpx; background: rgba(124,58,237,.12); border-radius: 4rpx; overflow: hidden; }
.progress-fill-mini { height: 100%; background: linear-gradient(90deg, #7c3aed, #a78bfa); border-radius: 4rpx; transition: width .3s; }
.progress-fill-mini.danger { background: linear-gradient(90deg, #ef4444, #f87171); }
.progress-mini-pct { font-size: 22rpx; color: #7c3aed; }

/* 邀请码 */
.invite-banner {
  margin-top: 16rpx;
  background: rgba(245,158,11,.08); border: 1rpx solid rgba(245,158,11,.2);
  border-radius: 16rpx; padding: 20rpx 24rpx;
  display: flex; align-items: flex-start; gap: 16rpx;
}
.invite-banner-icon { font-size: 36rpx; flex-shrink: 0; }
.invite-banner-info { flex: 1; }
.invite-banner-title { font-size: 28rpx; color: #d97706; font-weight: 600; display: block; }
.invite-code-reveal { display: flex; align-items: center; gap: 16rpx; margin-top: 8rpx; }
.invite-code-text { font-size: 32rpx; color: #1e1b4b; font-weight: 700; letter-spacing: 4rpx; }
.invite-code-eye  { font-size: 24rpx; color: #7c3aed; }
.invite-code-copy { font-size: 24rpx; color: #7c3aed; padding: 4rpx 16rpx; border: 1rpx solid rgba(124,58,237,.3); border-radius: 12rpx; }

/* 提醒 */
.reminder-box {
  margin-top: 16rpx;
  background: rgba(99,102,241,.06); border-left: 4rpx solid #7c3aed;
  border-radius: 0 12rpx 12rpx 0; padding: 16rpx 20rpx;
  display: flex; gap: 12rpx;
}
.reminder-icon { font-size: 28rpx; flex-shrink: 0; }
.reminder-text { font-size: 26rpx; color: #4c1d95; line-height: 1.6; }

/* ===== section title ===== */
.section-title {
  font-size: 30rpx; font-weight: 700; color: #1e1b4b;
  margin-bottom: 24rpx; padding-left: 16rpx;
  border-left: 6rpx solid #7c3aed;
}

/* ===== 场次 ===== */
.sub-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 20rpx; border-radius: 16rpx;
  border: 2rpx solid transparent;
  background: rgba(124,58,237,.04);
  margin-bottom: 16rpx; transition: all .2s;
}
.sub-item.sub-selected { border-color: #7c3aed; background: rgba(124,58,237,.08); }
.sub-item.sub-disabled { opacity: .5; }
.sub-left  { display: flex; gap: 16rpx; align-items: flex-start; flex: 1; }
.sub-radio { width: 36rpx; height: 36rpx; border-radius: 50%; border: 3rpx solid rgba(124,58,237,.3); flex-shrink: 0; margin-top: 4rpx; transition: all .2s; }
.sub-radio.radio-checked { background: #7c3aed; border-color: #7c3aed; box-shadow: 0 0 12rpx rgba(124,58,237,.5); }
.sub-info  { flex: 1; }
.sub-name  { font-size: 30rpx; color: #1e1b4b; font-weight: 600; display: block; }
.sub-time  { font-size: 24rpx; color: #64748b; display: block; margin-top: 6rpx; }
.sub-location { font-size: 24rpx; color: #7c3aed; display: block; margin-top: 4rpx; }
.sub-right { display: flex; flex-direction: column; align-items: flex-end; gap: 6rpx; margin-left: 12rpx; }
.sub-count { font-size: 28rpx; font-weight: 700; }
.sub-status{ font-size: 22rpx; color: #ef4444; }
.text-primary { color: #7c3aed; }
.text-danger  { color: #ef4444; }

/* ===== 描述 ===== */
.desc-text { font-size: 28rpx; color: #374151; line-height: 1.8; white-space: pre-wrap; display: block; }
.desc-collapsed { display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden; }
.expand-btn { margin-top: 16rpx; text-align: center; color: #7c3aed; font-size: 26rpx; }

.section-title--bare {
  margin-bottom: 0;
  border-left: none;
  padding-left: 0;
  font-size: 32rpx;
}

.section-head-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-count-pill {
  font-size: 26rpx;
  font-weight: 700;
  color: #7c3aed;
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  background: rgba(124,58,237,0.1);
}

.participants-hint {
  display: block;
  font-size: 22rpx;
  color: rgba(30,27,75,0.38);
  margin-bottom: 20rpx;
}

.participants-card { padding-bottom: 28rpx; }

/* ===== 已报名头像 ===== */
.avatar-list { display: flex; flex-wrap: wrap; gap: 12rpx; align-items: center; }
.avatar-list--lg { gap: 16rpx; }
.registrant-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,.95);
  box-shadow: 0 4rpx 12rpx rgba(124,58,237,0.12);
}
.avatar-more {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: rgba(124,58,237,.1); display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; color: #7c3aed;
}

/* ===== 管理操作 ===== */
.admin-actions { display: flex; flex-wrap: wrap; gap: 16rpx; }
.admin-action-btn {
  flex: 1; min-width: calc(50% - 8rpx);
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
  background: rgba(124,58,237,.06); border-radius: 16rpx; padding: 24rpx 16rpx;
  border: 1rpx solid rgba(124,58,237,.1);
}
.admin-action-btn.danger { background: rgba(239,68,68,.06); border-color: rgba(239,68,68,.15); }
.admin-icon { font-size: 36rpx; }
.admin-action-btn text:last-child { font-size: 26rpx; color: #1e1b4b; }
.admin-action-btn.danger text:last-child { color: #ef4444; }

/* ===== 复制 / 举报 ===== */
.extras-bar {
  margin: 0 20rpx 24rpx;
}
.extras-inner {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 24rpx 28rpx;
  background: rgba(255,255,255,0.88);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255,255,255,0.95);
  box-shadow: 0 6rpx 20rpx rgba(120,80,220,0.07);
}
.extras-chip {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 28rpx;
  border-radius: 100rpx;
  background: rgba(124,58,237,0.08);
  border: 1rpx solid rgba(124,58,237,0.16);
}
.extras-chip:active { opacity: 0.82; }
.extras-chip-ico { font-size: 28rpx; }
.extras-chip-txt { font-size: 26rpx; font-weight: 600; color: #5b21b6; }
.extras-chip--danger {
  background: rgba(100,116,139,0.06);
  border-color: rgba(100,116,139,0.15);
}
.extras-chip--danger .extras-chip-txt { color: #64748b; }

/* ===== 底部操作栏 ===== */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: rgba(255,255,255,.95);
  border-top: 1rpx solid rgba(124,58,237,.1);
  backdrop-filter: blur(20px);
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  z-index: 50;
}
.bottom-main-row { display: flex; align-items: center; gap: 20rpx; }
.registered-bar { display: flex; align-items: center; gap: 16rpx; flex-wrap: nowrap; }
.creator-bar     { display: flex; align-items: center; gap: 16rpx; }

.registered-tag {
  display: flex; align-items: center; gap: 8rpx;
  background: rgba(16,185,129,.1); border-radius: 20rpx; padding: 12rpx 24rpx;
  flex-shrink: 0;
}
.registered-check { color: #10b981; font-size: 28rpx; font-weight: 700; }
.registered-tag text:last-child { font-size: 26rpx; color: #059669; font-weight: 600; }

.share-btn {
  width: 88rpx; height: 88rpx; border-radius: 50%;
  background: rgba(124,58,237,.1); display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.share-btn::after { border: none; }
.share-btn-icon { font-size: 36rpx; color: #7c3aed; }

/* 通用按钮 */
.btn {
  display: flex; align-items: center; justify-content: center;
  border-radius: 40rpx; font-size: 30rpx; font-weight: 600;
  padding: 20rpx 40rpx;
}
.btn::after { border: none; }
.btn-primary { background: linear-gradient(135deg, #7c3aed, #6d28d9); color: #fff; }
.btn-primary[disabled] { background: rgba(124,58,237,.3); color: rgba(255,255,255,.6); }
.btn-outline { background: transparent; border: 2rpx solid #7c3aed; color: #7c3aed; }
.btn-gray    { background: rgba(100,116,139,.1); color: #64748b; }
.btn-lg  { height: 88rpx; font-size: 32rpx; }
.btn-sm  { padding: 12rpx 28rpx; font-size: 26rpx; height: 76rpx; min-width: 0; }

/* ===== 冲突弹窗 ===== */
.mask {
  position: fixed; inset: 0;
  background: rgba(0,0,0,.45);
  z-index: 1000;
  display: flex; align-items: center; justify-content: center;
}
.conflict-modal {
  background: #fff; border-radius: 28rpx;
  margin: 0 40rpx; padding: 48rpx 40rpx;
  display: flex; flex-direction: column; gap: 20rpx;
}
.conflict-title { font-size: 34rpx; font-weight: 700; color: #1e1b4b; text-align: center; }
.conflict-desc  { font-size: 28rpx; color: #64748b; line-height: 1.6; text-align: center; }
.conflict-actions { display: flex; gap: 20rpx; margin-top: 8rpx; }
.conflict-actions .btn { flex: 1; }

/* ===== 活动微信群 ===== */
.wx-group-card {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.wx-group-card--highlight {
  box-shadow:
    0 0 0 3rpx rgba(124, 58, 237, 0.45),
    0 16rpx 40rpx rgba(91, 33, 182, 0.18);
}
.wx-group-name {
  align-self: flex-start;
  font-size: 28rpx;
  color: #5b21b6;
  font-weight: 600;
  margin-bottom: 20rpx;
}
.wx-group-qrcode {
  width: 100%;
  max-width: 440rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}
.wx-group-hint {
  font-size: 24rpx;
  color: #64748b;
  text-align: center;
  line-height: 1.5;
}
.wx-group-teaser .wx-group-teaser-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 27rpx;
  color: #64748b;
  line-height: 1.55;
}

/* 报名者 · 现场签到入口 */
.registrant-checkin-card .registrant-checkin-hint {
  display: block;
  margin-top: 8rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.55;
}
.registrant-checkin-card .registrant-checkin-btn {
  max-width: 100%;
}

/* 发布者 · 现场签到列表 */
.creator-checkin-card .checkin-detail-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(30, 27, 75, 0.08);
}
.creator-checkin-card .checkin-detail-row:last-child {
  border-bottom: none;
}
.creator-checkin-card .checkin-detail-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(124, 58, 237, 0.08);
  flex-shrink: 0;
}
.creator-checkin-card .checkin-detail-mid {
  flex: 1;
  min-width: 0;
}
.creator-checkin-card .checkin-detail-name {
  font-size: 29rpx;
  font-weight: 600;
  color: #1e1b4b;
  display: block;
}
.creator-checkin-card .checkin-detail-time {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 6rpx;
  display: block;
}
.creator-checkin-card .checkin-more-hint {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #94a3b8;
  line-height: 1.5;
}
