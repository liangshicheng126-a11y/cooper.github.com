/* pages/activity-detail/index.wxss */

/* ===== 页面容器 ===== */
.page-wrap {
  min-height: 100vh;
  background: var(--bg-radial);
  padding-bottom: 200rpx;
  overflow-x: hidden;
}

/* ===== 固定返回键（顶、高与右上角胶囊对齐，全小程序自定义导航页保持一致）===== */
.nav-back-slot {
  position: fixed;
  left: 24rpx;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-back-circle {
  width: 64rpx;
  height: 64rpx;
  min-width: 64rpx;
  min-height: 64rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(29,28,24,0.12);
}
.nav-back-arrow {
  font-size: 40rpx;
  color: var(--text-primary);
  line-height: 1;
  font-weight: 300;
}

/* ===== 骨架屏 ===== */
.skeleton-wrap { padding: 0 0 200rpx; background: var(--bg-radial); min-height: 100vh; }
.skeleton-cover { width: 100%; height: 260rpx; background: rgba(29,28,24,0.08); }
.skeleton-body { padding: 32rpx; }
.skeleton-line { border-radius: 14rpx; margin-bottom: 20rpx; background: rgba(200,180,255,0.3); }
.skeleton-line.w90 { width: 90%; }
.skeleton-line.w75 { width: 75%; height: 28rpx; }
.skeleton-line.w60 { width: 60%; height: 28rpx; }
.skeleton-line.w50 { width: 50%; height: 28rpx; }
.skeleton-shine {
  background: linear-gradient(90deg, rgba(29,28,24,0.05) 25%, rgba(154,107,36,0.12) 50%, rgba(29,28,24,0.05) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.6s infinite;
}
@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

/* ===== 错误状态 ===== */
.error-state {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  min-height: 60vh; padding: 80rpx 40rpx;
}
.error-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.error-text { font-size: 30rpx; color: var(--accent-text); opacity: .8; text-align: center; }
.btn-sm { padding: 16rpx 40rpx; border-radius: 40rpx; font-size: 28rpx; }

/* ===== 封面 ===== */
.cover-section {
  position: relative;
  height: 260rpx;
  overflow: hidden;
}
.cover-fallback {
  position: absolute; inset: 0;
  background: linear-gradient(145deg, #f8f6f0 0%, #eee9df 100%);
}
.cover-image { position: relative; z-index: 1; width: 100%; height: 100%; }
.cover-placeholder {
  width: 100%;
  height: 100%;
  min-height: 260rpx;
  display: flex; align-items: center; justify-content: center;
  background: linear-gradient(145deg, #f8f6f0 0%, #eee9df 100%);
}
.cover-emoji { font-size: 56rpx; }
.cover-gradient {
  position: absolute; bottom: 0; left: 0; right: 0;
  height: 120rpx;
  background: linear-gradient(to top, rgba(247,245,239,1) 0%, transparent 100%);
}

/* ===== 主信息卡 ===== */
.main-card {
  position: relative;
  z-index: 2;
  margin: -40rpx 20rpx 20rpx;
  background: var(--surface-strong);
  border-radius: 32rpx;
  border: 1rpx solid rgba(29,28,24,0.08);
  box-shadow: 0 18rpx 46rpx rgba(29,28,24,0.10), 0 4rpx 14rpx rgba(29,28,24,0.04);
  padding: 48rpx 32rpx 36rpx;
  overflow: visible;
}

/* 审核提示（仅发起人） */
.moderation-banner {
  margin: 24rpx -8rpx 0;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
}
.moderation-pending {
  background: rgba(217,119,6,0.08);
  border: 1rpx solid rgba(217, 119, 6, 0.22);
}
.moderation-reject {
  background: rgba(220,38,38,0.07);
  border: 1rpx solid rgba(239, 68, 68, 0.2);
}
.moderation-banner-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}
.moderation-banner-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(30, 27, 75, 0.72);
  line-height: 1.5;
}

/* ===== section card ===== */
.section-card {
  margin: 0 20rpx 20rpx;
  background: var(--surface);
  border-radius: 28rpx;
  border: 1rpx solid rgba(29,28,24,0.08);
  box-shadow: var(--shadow-md);
  padding: 32rpx;
}

/* ===== 标题区 ===== */
.hero-title-block { margin-bottom: 8rpx; padding-top: 4rpx; }

.hero-title-row { margin-bottom: 20rpx; }

.activity-title {
  display: block;
  font-size: 44rpx;
  font-weight: 760;
  color: var(--text-primary);
  line-height: 1.35;
  letter-spacing: 0;
}

.hero-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.category-chip {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--accent-text);
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  background: var(--accent-light);
  border: 1rpx solid rgba(154,107,36,0.20);
}

.creator-line {
  display: block;
  font-size: 24rpx;
  color: var(--text-muted);
}

.hero-meta .status-badge { margin-left: 0; }

/* ===== 状态角标 ===== */
.status-badge {
  display: flex; align-items: center; gap: 8rpx;
  padding: 8rpx 20rpx; border-radius: 40rpx;
  font-size: 24rpx; font-weight: 600; flex-shrink: 0;
}
.status-badge.badge-active   { background: rgba(16,185,129,.15); color: #059669; }
.status-badge.badge-upcoming { background: var(--warning-bg);  color: var(--warning); }
.status-badge.badge-ended    { background: rgba(100,116,139,.12); color: #64748b; }
.status-badge.badge-full     { background: rgba(245,158,11,.12);  color: #d97706; }
.status-badge.badge-offline  { background: rgba(239,68,68,.12);   color: #dc2626; }
.pulse-dot {
  width: 14rpx; height: 14rpx; border-radius: 50%;
  background: #10b981;
  animation: pulse 1.8s ease-in-out infinite;
}
@keyframes pulse { 0%,100%{transform:scale(1);opacity:1} 50%{transform:scale(1.08);opacity:.78} }

.divider { height: 1rpx; background: var(--divider); margin: 0 0 20rpx; }

/* ===== info item ===== */
.info-item {
  display: flex; align-items: flex-start;
  gap: 20rpx; margin-bottom: 20rpx;
}
.info-icon-wrap {
  width: 64rpx; height: 64rpx; border-radius: 16rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.bg-blue,
.bg-green,
.bg-purple { background: rgba(154,107,36,0.08); }
.info-emoji { font-size: 25rpx; color: var(--accent-text); font-weight: 700; }
.info-content { flex: 1; min-width: 0; }
.info-label  { font-size: 23rpx; color: var(--text-muted); display: block; margin-bottom: 4rpx; }
.info-value  { font-size: 30rpx; color: var(--text-primary); font-weight: 600; display: block; line-height: 1.45; }
.info-sub    { font-size: 24rpx; color: #64748b; display: block; margin-top: 6rpx; line-height: 1.45; }
.info-copy-hint { font-size: 22rpx; color: var(--accent-text); opacity: 0.9; margin-top: 10rpx; }
.info-item--time .info-content .info-label { margin-bottom: 12rpx; }

.info-value--strong {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-top: 4rpx;
}

.info-value--end {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.info-duration-pill {
  display: inline-block;
  margin-top: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--accent-text);
  padding: 10rpx 22rpx;
  border-radius: 100rpx;
  background: var(--accent-grad-soft);
  border: 1rpx solid rgba(154,107,36,0.18);
}
.flex-1 { flex: 1; }

/* 人数 */
.participants-row { display: flex; align-items: baseline; gap: 4rpx; }
.participants-num   { font-size: 40rpx; color: var(--text-primary); font-weight: 800; }
.participants-total { font-size: 26rpx; color: #64748b; }
.progress-mini { display: flex; flex-direction: column; align-items: flex-end; gap: 4rpx; align-self: center; }
.progress-track-mini { width: 120rpx; height: 8rpx; background: rgba(37,26,52,.09); border-radius: 4rpx; overflow: hidden; }
.progress-fill-mini { height: 100%; background: linear-gradient(90deg, var(--accent), var(--accent-3)); border-radius: 4rpx; transition: width var(--motion-medium) var(--ease-out); }
.progress-fill-mini.danger { background: linear-gradient(90deg, #ef4444, #f87171); }
.progress-mini-pct { font-size: 22rpx; color: var(--accent-text); }

/* 邀请码 */
.invite-banner {
  margin-top: 16rpx;
  background: rgba(245,158,11,.08); border: 1rpx solid rgba(245,158,11,.2);
  border-radius: 16rpx; padding: 20rpx 24rpx;
  display: flex; align-items: flex-start; gap: 16rpx;
}
.invite-banner-icon { width: 48rpx; height: 48rpx; border-radius: 50%; background: rgba(217,119,6,0.12); color: #d97706; font-size: 24rpx; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.invite-banner-info { flex: 1; }
.invite-banner-title { font-size: 28rpx; color: #d97706; font-weight: 600; display: block; }
.invite-code-reveal { display: flex; align-items: center; gap: 16rpx; margin-top: 8rpx; }
.invite-code-text { font-size: 32rpx; color: var(--text-primary); font-weight: 700; letter-spacing: 4rpx; }
.invite-code-eye  { font-size: 24rpx; color: var(--accent-text); }
.invite-code-copy { font-size: 24rpx; color: var(--accent-text); padding: 4rpx 16rpx; border: 1rpx solid rgba(154,107,36,.28); border-radius: 12rpx; }

/* 提醒 */
.reminder-box {
  margin-top: 16rpx;
  background: var(--accent-grad-soft); border: 1rpx solid rgba(154,107,36,0.14);
  border-radius: 16rpx; padding: 16rpx 20rpx;
  display: flex; gap: 12rpx;
}
.reminder-icon { width: 44rpx; height: 44rpx; border-radius: 50%; background: rgba(154,107,36,0.10); color: var(--accent-text); font-size: 22rpx; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.reminder-text { font-size: 26rpx; color: var(--text-secondary); line-height: 1.6; }

/* ===== section title ===== */
.section-title {
  font-size: 30rpx; font-weight: 700; color: var(--text-primary);
  margin-bottom: 24rpx; padding-left: 16rpx;
  border-left: 4rpx solid var(--accent);
}

/* ===== 场次 ===== */
.sub-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 20rpx; border-radius: 16rpx;
  border: 2rpx solid transparent;
  background: rgba(29,28,24,0.035);
  margin-bottom: 16rpx; transition: background .2s, border-color .2s, opacity .2s;
}
.sub-item.sub-selected { border-color: rgba(154,107,36,0.44); background: var(--accent-light); }
.sub-item.sub-disabled { opacity: .5; }
.sub-left  { display: flex; gap: 16rpx; align-items: flex-start; flex: 1; }
.sub-radio { width: 36rpx; height: 36rpx; border-radius: 50%; border: 3rpx solid rgba(154,107,36,.28); flex-shrink: 0; margin-top: 4rpx; transition: background var(--motion-base), border-color var(--motion-base), box-shadow var(--motion-base); }
.sub-radio.radio-checked { background: var(--accent); border-color: var(--accent); box-shadow: 0 0 0 5rpx rgba(154,107,36,.10); }
.sub-info  { flex: 1; }
.sub-name  { font-size: 30rpx; color: var(--text-primary); font-weight: 600; display: block; }
.sub-time  { font-size: 24rpx; color: #64748b; display: block; margin-top: 6rpx; }
.sub-location { font-size: 24rpx; color: var(--text-muted); display: block; margin-top: 4rpx; }
.sub-right { display: flex; flex-direction: column; align-items: flex-end; gap: 6rpx; margin-left: 12rpx; }
.sub-count { font-size: 28rpx; font-weight: 700; }
.sub-status{ font-size: 22rpx; color: #ef4444; }
.text-primary { color: var(--accent-text); }
.text-danger  { color: #ef4444; }

/* ===== 描述 ===== */
.desc-text { font-size: 28rpx; color: #374151; line-height: 1.8; white-space: pre-wrap; display: block; }
.desc-collapsed { display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden; }
.expand-btn { margin-top: 16rpx; text-align: center; color: var(--accent-text); font-size: 26rpx; }

.section-title--bare {
  margin-bottom: 0;
  border-left: none;
  padding-left: 0;
  font-size: 32rpx;
}

.section-head-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-count-pill {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--accent-text);
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  background: var(--accent-light);
}

.participants-hint {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 20rpx;
}

.participants-card { padding-bottom: 28rpx; }

/* ===== 已报名头像 ===== */
.avatar-list { display: flex; flex-wrap: wrap; gap: 12rpx; align-items: center; }
.avatar-list--lg { gap: 16rpx; }
.registrant-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,.95);
  box-shadow: 0 4rpx 12rpx rgba(29,28,24,0.10);
}
.registrant-avatar--fallback {
  background: linear-gradient(145deg, rgba(154,107,36,0.18), rgba(29,28,24,0.06));
}
.avatar-more {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: var(--accent-light); display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; color: var(--accent-text);
}

/* ===== 管理操作 ===== */
.admin-actions { display: flex; flex-wrap: wrap; gap: 16rpx; }
.admin-action-btn {
  flex: 1; min-width: calc(50% - 8rpx);
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
  background: rgba(255,255,255,0.72); border-radius: 16rpx; padding: 24rpx 16rpx;
  border: 1rpx solid rgba(29,28,24,.08);
}
.admin-action-btn.danger { background: rgba(239,68,68,.06); border-color: rgba(239,68,68,.15); }
.admin-icon {
  position: relative;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: var(--accent-light);
  color: var(--accent-text);
  display: flex;
  align-items: center;
  justify-content: center;
}
.admin-icon__mark,
.admin-icon__mark::before,
.admin-icon__mark::after {
  content: '';
  position: absolute;
  box-sizing: border-box;
}
.admin-icon--list .admin-icon__mark {
  width: 26rpx;
  height: 28rpx;
  border: 3rpx solid currentColor;
  border-radius: 5rpx;
}
.admin-icon--list .admin-icon__mark::before {
  left: 5rpx;
  top: 7rpx;
  width: 12rpx;
  height: 3rpx;
  border-radius: 4rpx;
  background: currentColor;
  box-shadow: 0 8rpx 0 currentColor;
}
.admin-icon--scan .admin-icon__mark {
  width: 28rpx;
  height: 28rpx;
  background:
    linear-gradient(currentColor, currentColor) left top / 12rpx 3rpx no-repeat,
    linear-gradient(currentColor, currentColor) left top / 3rpx 12rpx no-repeat,
    linear-gradient(currentColor, currentColor) right top / 12rpx 3rpx no-repeat,
    linear-gradient(currentColor, currentColor) right top / 3rpx 12rpx no-repeat,
    linear-gradient(currentColor, currentColor) left bottom / 12rpx 3rpx no-repeat,
    linear-gradient(currentColor, currentColor) left bottom / 3rpx 12rpx no-repeat,
    linear-gradient(currentColor, currentColor) right bottom / 12rpx 3rpx no-repeat,
    linear-gradient(currentColor, currentColor) right bottom / 3rpx 12rpx no-repeat;
}
.admin-icon--scan .admin-icon__mark::before {
  left: 5rpx;
  right: 5rpx;
  top: 13rpx;
  height: 3rpx;
  border-radius: 4rpx;
  background: currentColor;
  opacity: 0.75;
}
.admin-icon--qr .admin-icon__mark {
  width: 26rpx;
  height: 26rpx;
  border: 3rpx solid currentColor;
  border-radius: 4rpx;
}
.admin-icon--qr .admin-icon__mark::before {
  left: 4rpx;
  top: 4rpx;
  width: 5rpx;
  height: 5rpx;
  background: currentColor;
  box-shadow: 10rpx 0 0 currentColor, 0 10rpx 0 currentColor, 10rpx 10rpx 0 currentColor;
}
.admin-icon--bell .admin-icon__mark {
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid currentColor;
  border-bottom: none;
  border-radius: 14rpx 14rpx 8rpx 8rpx;
  transform: translateY(-2rpx);
}
.admin-icon--bell .admin-icon__mark::before {
  left: -4rpx;
  right: -4rpx;
  bottom: -5rpx;
  height: 3rpx;
  border-radius: 4rpx;
  background: currentColor;
}
.admin-icon--bell .admin-icon__mark::after {
  left: 8rpx;
  bottom: -11rpx;
  width: 7rpx;
  height: 7rpx;
  border-radius: 50%;
  background: currentColor;
}
.admin-icon--group .admin-icon__mark {
  width: 16rpx;
  height: 16rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
  transform: translateY(-7rpx);
}
.admin-icon--group .admin-icon__mark::before {
  left: -10rpx;
  top: 16rpx;
  width: 36rpx;
  height: 14rpx;
  border: 3rpx solid currentColor;
  border-top-left-radius: 16rpx;
  border-top-right-radius: 16rpx;
  border-bottom: none;
}
.admin-icon--group .admin-icon__mark::after {
  left: 20rpx;
  top: 4rpx;
  width: 11rpx;
  height: 11rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
  opacity: 0.75;
}
.admin-icon--edit .admin-icon__mark {
  width: 26rpx;
  height: 8rpx;
  border-radius: 8rpx;
  background: currentColor;
  transform: rotate(-42deg);
}
.admin-icon--edit .admin-icon__mark::before {
  right: -6rpx;
  top: 0;
  width: 4rpx;
  height: 8rpx;
  border-left: 3rpx solid rgba(255,255,255,0.75);
}
.admin-icon--edit .admin-icon__mark::after {
  left: -8rpx;
  top: 0;
  width: 0;
  height: 0;
  border-top: 4rpx solid transparent;
  border-bottom: 4rpx solid transparent;
  border-right: 8rpx solid currentColor;
}
.admin-icon--offline {
  color: #ef4444;
  background: rgba(239,68,68,.09);
}
.admin-icon--offline .admin-icon__mark {
  width: 26rpx;
  height: 26rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
}
.admin-icon--offline .admin-icon__mark::before {
  left: 4rpx;
  top: 10rpx;
  width: 14rpx;
  height: 3rpx;
  border-radius: 4rpx;
  background: currentColor;
}
.admin-action-btn text:last-child { font-size: 26rpx; color: var(--text-primary); }
.admin-action-btn.danger text:last-child { color: #ef4444; }

/* ===== 复制 / 举报 ===== */
.extras-bar {
  margin: 0 20rpx 24rpx;
}
.extras-inner {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 24rpx 28rpx;
  background: rgba(255,255,255,0.88);
  border-radius: 24rpx;
  border: 1rpx solid rgba(29,28,24,0.08);
  box-shadow: var(--shadow-md);
}
.extras-chip {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 28rpx;
  border-radius: 100rpx;
  background: rgba(154,107,36,0.08);
  border: 1rpx solid rgba(154,107,36,0.16);
}
.extras-chip:active { opacity: 0.82; }
.extras-chip-ico { font-size: 23rpx; font-weight: 700; color: var(--accent-text); }
.extras-chip-txt { font-size: 26rpx; font-weight: 700; color: var(--accent-text); }
.extras-chip--danger {
  background: rgba(100,116,139,0.06);
  border-color: rgba(100,116,139,0.15);
}
.extras-chip--danger .extras-chip-txt { color: #64748b; }

/* ===== 底部操作栏 ===== */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: rgba(255,255,255,.95);
  border-top: 1rpx solid rgba(29,28,24,.08);
  backdrop-filter: blur(8px);
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  z-index: 50;
}
.bottom-main-row { display: flex; align-items: center; gap: 20rpx; }
.registered-bar { display: flex; align-items: center; gap: 16rpx; flex-wrap: nowrap; }
.creator-bar     { display: flex; align-items: center; gap: 16rpx; }

.registered-tag {
  display: flex; align-items: center; gap: 8rpx;
  background: rgba(16,185,129,.10); border-radius: 20rpx; padding: 12rpx 24rpx;
  flex-shrink: 0;
}
.registered-check { color: #10b981; font-size: 28rpx; font-weight: 700; }
.registered-tag text:last-child { font-size: 26rpx; color: #059669; font-weight: 600; }

.share-btn {
  width: 88rpx; height: 88rpx; border-radius: 50%;
  background: rgba(154,107,36,.08); display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.share-btn::after { border: none; }
.share-btn-icon {
  position: relative;
  width: 38rpx;
  height: 34rpx;
  color: var(--accent-text);
}
.share-btn-icon::before,
.share-btn-icon::after {
  content: '';
  position: absolute;
  box-sizing: border-box;
}
.share-btn-icon::before {
  left: 0;
  top: 12rpx;
  width: 38rpx;
  height: 3rpx;
  border-radius: 4rpx;
  background: currentColor;
  transform: rotate(-24deg);
  opacity: 0.76;
  box-shadow: 5rpx 12rpx 0 currentColor;
}
.share-btn-icon::after {
  left: 0;
  top: 10rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: currentColor;
  box-shadow: 24rpx -9rpx 0 currentColor, 24rpx 17rpx 0 currentColor;
}

/* 通用按钮 */
.btn {
  display: flex; align-items: center; justify-content: center;
  border-radius: 40rpx; font-size: 30rpx; font-weight: 600;
  padding: 20rpx 40rpx;
}
.btn::after { border: none; }
.btn-primary { background: var(--accent-grad); color: #fff; box-shadow: 0 8rpx 20rpx rgba(29,28,24,0.14); }
.btn-primary[disabled] { background: rgba(29,28,24,.22); color: rgba(255,255,255,.76); box-shadow: none; }
.btn-outline { background: transparent; border: 2rpx solid var(--accent); color: var(--accent-text); }
.btn-gray    { background: rgba(100,116,139,.1); color: #64748b; }
.btn-lg  { height: 88rpx; font-size: 32rpx; }
.btn-sm  { padding: 12rpx 28rpx; font-size: 26rpx; height: 76rpx; min-width: 0; }

/* ===== 冲突弹窗 ===== */
.mask {
  position: fixed; inset: 0;
  background: rgba(0,0,0,.45);
  z-index: 1000;
  display: flex; align-items: center; justify-content: center;
}
.conflict-modal {
  background: #fff; border-radius: 28rpx;
  margin: 0 40rpx; padding: 48rpx 40rpx;
  display: flex; flex-direction: column; gap: 20rpx;
}
.conflict-title { font-size: 34rpx; font-weight: 700; color: var(--text-primary); text-align: center; }
.conflict-desc  { font-size: 28rpx; color: #64748b; line-height: 1.6; text-align: center; }
.conflict-actions { display: flex; gap: 20rpx; margin-top: 8rpx; }
.conflict-actions .btn { flex: 1; }

/* ===== 活动微信群 ===== */
.wx-group-card {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.wx-group-card--highlight {
  box-shadow:
    0 0 0 3rpx rgba(255, 90, 61, 0.36),
    0 16rpx 40rpx rgba(255, 90, 61, 0.18);
}
.wx-group-name {
  align-self: flex-start;
  font-size: 28rpx;
  color: var(--accent-text);
  font-weight: 600;
  margin-bottom: 20rpx;
}
.wx-group-qrcode {
  width: 100%;
  max-width: 440rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}
.wx-group-hint {
  font-size: 24rpx;
  color: #64748b;
  text-align: center;
  line-height: 1.5;
}
.wx-group-teaser .wx-group-teaser-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 27rpx;
  color: #64748b;
  line-height: 1.55;
}

/* 报名者 · 现场签到入口 */
.registrant-checkin-card .registrant-checkin-hint {
  display: block;
  margin-top: 8rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.55;
}
.registrant-checkin-card .registrant-checkin-btn {
  max-width: 100%;
}

/* 发布者 · 现场签到列表 */
.creator-checkin-card .checkin-detail-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--divider);
}
.creator-checkin-card .checkin-detail-row:last-child {
  border-bottom: none;
}
.creator-checkin-card .checkin-detail-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--accent-light);
  flex-shrink: 0;
}
.creator-checkin-card .checkin-detail-avatar--fallback {
  background: linear-gradient(145deg, rgba(154,107,36,0.18), rgba(29,28,24,0.06));
}
.creator-checkin-card .checkin-detail-mid {
  flex: 1;
  min-width: 0;
}
.creator-checkin-card .checkin-detail-name {
  font-size: 29rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}
.creator-checkin-card .checkin-detail-time {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 6rpx;
  display: block;
}
.creator-checkin-card .checkin-more-hint {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #94a3b8;
  line-height: 1.5;
}

@media (prefers-reduced-motion: reduce) {
  .skeleton-shine,
  .pulse-dot {
    animation: none;
  }
  .progress-fill-mini,
  .sub-radio {
    transition: none;
  }
}
