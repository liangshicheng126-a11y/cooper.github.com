/* pages/activity-detail/index.wxss · 毛玻璃活动详情 */

.page {
  min-height: 100vh;
  background: linear-gradient(145deg, #0d0b1e 0%, #1a1040 40%, #0d1f3c 100%);
}
.scroll-view { height: 100vh; }

/* ── 封面 ── */
.cover-section {
  position: relative;
  height: 480rpx;
  overflow: hidden;
}
.cover-image { width: 100%; height: 100%; }

.cover-gradient {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 280rpx;
  background: linear-gradient(transparent, #0d0b1e);
}

.cover-placeholder {
  height: 300rpx;
  background: linear-gradient(135deg, #1a1040, #0d1f3c);
  display: flex;
  align-items: center;
  justify-content: center;
}
.cover-emoji { font-size: 100rpx; opacity: 0.7; }

/* ── 返回按钮 ── */
.back-btn {
  position: fixed;
  top: calc(env(safe-area-inset-top) + 20rpx);
  left: 24rpx;
  width: 72rpx;
  height: 72rpx;
  background: rgba(13,11,30,0.6);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1rpx solid rgba(255,255,255,0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: rgba(255,255,255,0.9);
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.4);
  z-index: 100;
}
.back-btn:active { background: rgba(13,11,30,0.8); }

/* ── 主卡片 ── */
.main-card {
  margin: -48rpx 20rpx 20rpx;
  padding: 32rpx;
  position: relative;
  z-index: 1;
  background: rgba(255,255,255,0.08);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1rpx solid rgba(255,255,255,0.14);
  border-radius: 28rpx;
  box-shadow: 0 12rpx 48rpx rgba(0,0,0,0.45);
}
.main-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.28), transparent);
  pointer-events: none;
}

.title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.activity-title {
  font-size: 36rpx;
  font-weight: 800;
  color: rgba(255,255,255,0.95);
  flex: 1;
  line-height: 1.45;
  letter-spacing: 0.5rpx;
}

/* ── 内联状态标签 ── */
.status-badge {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 700;
  white-space: nowrap;
  flex-shrink: 0;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}
.badge-active   { background: rgba(52,211,153,0.15);  color: #34d399; border: 1rpx solid rgba(52,211,153,0.3); }
.badge-upcoming { background: rgba(251,191,36,0.14);  color: #fbbf24; border: 1rpx solid rgba(251,191,36,0.3); }
.badge-ended    { background: rgba(255,255,255,0.07); color: rgba(255,255,255,0.4); border: 1rpx solid rgba(255,255,255,0.12); }
.badge-full     { background: rgba(248,113,113,0.13); color: #f87171; border: 1rpx solid rgba(248,113,113,0.28); }

/* ── 信息项 ── */
.info-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 28rpx;
  gap: 20rpx;
}

.info-icon-wrap {
  width: 68rpx;
  height: 68rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.bg-blue   { background: rgba(96,165,250,0.12);  border: 1rpx solid rgba(96,165,250,0.2); }
.bg-green  { background: rgba(52,211,153,0.12);  border: 1rpx solid rgba(52,211,153,0.2); }
.bg-purple { background: rgba(167,139,250,0.12); border: 1rpx solid rgba(167,139,250,0.2); }

.info-emoji { font-size: 32rpx; }

.info-content { flex: 1; }
.info-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.4);
  display: block;
  margin-bottom: 6rpx;
  letter-spacing: 1rpx;
}
.info-value {
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  font-weight: 600;
  display: block;
}
.info-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.45);
  display: block;
  margin-top: 4rpx;
}

.nav-btn {
  display: flex;
  align-items: center;
  background: rgba(96,165,250,0.12);
  border: 1rpx solid rgba(96,165,250,0.25);
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  gap: 4rpx;
}
.nav-btn:active { background: rgba(96,165,250,0.22); }
.nav-text  { font-size: 24rpx; color: #60a5fa; font-weight: 600; }
.nav-arrow { font-size: 28rpx; color: #60a5fa; }

/* ── 人数进度（迷你）── */
.participants-row { display: flex; align-items: baseline; }
.participants-num  { font-size: 36rpx; font-weight: 800; color: #a78bfa; }
.participants-total { font-size: 24rpx; color: rgba(255,255,255,0.35); }

.progress-mini { display: flex; flex-direction: column; align-items: flex-end; gap: 6rpx; }
.progress-track-mini {
  width: 120rpx; height: 8rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 100rpx; overflow: hidden;
}
.progress-fill-mini { height: 100%; border-radius: 100rpx; }
.fill-primary { background: linear-gradient(90deg, #a78bfa, #60a5fa); }
.fill-warning { background: linear-gradient(90deg, #fde68a, #fbbf24); }
.fill-danger  { background: linear-gradient(90deg, #fca5a5, #f87171); }
.progress-mini-pct { font-size: 20rpx; color: rgba(255,255,255,0.3); }

/* ── 提醒框 ── */
.reminder-box {
  background: rgba(251,191,36,0.08);
  border: 1rpx solid rgba(251,191,36,0.25);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-top: 8rpx;
}
.reminder-icon { font-size: 28rpx; flex-shrink: 0; margin-top: 2rpx; }
.reminder-text { font-size: 26rpx; color: rgba(251,191,36,0.85); line-height: 1.7; }

/* ── Section 卡片 ── */
.section-card {
  margin: 0 20rpx 20rpx;
  padding: 28rpx 32rpx;
  background: rgba(255,255,255,0.07);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 24rpx;
  box-shadow: 0 6rpx 30rpx rgba(0,0,0,0.3);
  position: relative;
}
.section-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  pointer-events: none;
}

/* ── 子活动 ── */
.sub-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  background: rgba(255,255,255,0.04);
  transition: all 0.15s;
}
.sub-selected {
  border-color: rgba(167,139,250,0.45);
  background: rgba(167,139,250,0.1);
}
.sub-disabled { opacity: 0.4; }
.sub-left { display: flex; align-items: center; gap: 16rpx; flex: 1; }
.sub-radio {
  width: 36rpx; height: 36rpx;
  border: 2rpx solid rgba(255,255,255,0.2);
  border-radius: 50%; flex-shrink: 0;
  transition: all 0.15s;
}
.radio-checked {
  border-color: #a78bfa;
  background: #a78bfa;
  box-shadow: inset 0 0 0 7rpx rgba(13,11,30,0.9), 0 0 12rpx rgba(167,139,250,0.4);
}
.sub-info { flex: 1; }
.sub-name     { font-size: 28rpx; font-weight: 600; color: rgba(255,255,255,0.9); display: block; }
.sub-time     { font-size: 24rpx; color: rgba(255,255,255,0.45); display: block; margin-top: 4rpx; }
.sub-location { font-size: 22rpx; color: rgba(255,255,255,0.35); display: block; margin-top: 4rpx; }
.sub-right    { text-align: right; }
.sub-count  { font-size: 26rpx; font-weight: 700; }
.sub-status { font-size: 22rpx; color: #f87171; display: block; margin-top: 4rpx; }
.text-primary { color: #a78bfa; }
.text-danger  { color: #f87171; }

/* ── 活动描述 ── */
.desc-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
  line-height: 1.9;
  display: block;
}
.desc-collapsed {
  overflow: hidden; text-overflow: ellipsis;
  display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical;
}
.expand-btn {
  text-align: center;
  margin-top: 16rpx;
  color: #a78bfa;
  font-size: 26rpx;
  letter-spacing: 1rpx;
}

/* ── 报名者头像 ── */
.avatar-list { display: flex; flex-wrap: wrap; gap: 12rpx; }
.registrant-avatar {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  border: 2rpx solid rgba(255,255,255,0.15);
}
.avatar-more {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: rgba(167,139,250,0.15);
  border: 1rpx solid rgba(167,139,250,0.3);
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx;
  color: #a78bfa;
  font-weight: 600;
}

/* ── 举报 ── */
.report-section { text-align: center; padding: 20rpx; }
.report-btn { font-size: 24rpx; color: rgba(255,255,255,0.25); text-decoration: underline; }

/* ── 管理操作 ── */
.admin-actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}
.admin-action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 16rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.65);
  gap: 8rpx;
  transition: all 0.15s;
}
.admin-action-btn:active {
  transform: scale(0.93);
  background: rgba(255,255,255,0.1);
}
.admin-action-btn.danger { color: #f87171; }
.admin-icon { font-size: 40rpx; }

/* ── 底部操作栏 ── */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: rgba(13,11,30,0.88);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(255,255,255,0.09);
  z-index: 100;
}

.registered-bar {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.registered-tag {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: rgba(52,211,153,0.12);
  border: 1rpx solid rgba(52,211,153,0.25);
  border-radius: 16rpx;
  padding: 22rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #34d399;
}
.registered-check { font-size: 32rpx; }
.creator-bar { display: flex; gap: 20rpx; }

/* ── 冲突弹窗 ── */
.conflict-modal {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  padding: 40rpx 40rpx calc(40rpx + env(safe-area-inset-bottom));
  background: rgba(20,16,50,0.95);
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  border-top: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 40rpx 40rpx 0 0;
  z-index: 999;
  animation: slideUp 0.3s cubic-bezier(0.25,0.46,0.45,0.94);
}
.conflict-title {
  display: block;
  font-size: 32rpx; font-weight: 700;
  color: rgba(255,255,255,0.95);
  margin-bottom: 16rpx;
}
.conflict-desc {
  display: block;
  font-size: 27rpx;
  color: rgba(255,255,255,0.55);
  line-height: 1.7;
  margin-bottom: 32rpx;
}
.conflict-actions { display: flex; gap: 20rpx; }
.conflict-actions .btn { flex: 1; }

@keyframes slideUp {
  from { transform: translateY(40rpx); opacity: 0; }
  to   { transform: translateY(0);     opacity: 1; }
}
