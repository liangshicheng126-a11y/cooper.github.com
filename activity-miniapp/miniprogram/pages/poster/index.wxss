/* pages/poster/index.wxss */
.page { min-height: 100vh; background: var(--gray-50); }
.scroll-view { height: 100vh; }

.poster-preview-wrap { padding: 24rpx; text-align: center; }
.poster-preview { width: 100%; max-width: 700rpx; border-radius: var(--radius-xl); box-shadow: var(--shadow-lg); }

.preview-actions {
  display: flex;
  gap: 16rpx;
  justify-content: center;
  margin-top: 32rpx;
}

.generate-panel { margin: 24rpx; padding: 40rpx 32rpx; }

.gen-title { display: block; font-size: 36rpx; font-weight: 800; color: var(--gray-800); margin-bottom: 8rpx; text-align: center; }
.gen-activity-name { display: block; font-size: 26rpx; color: var(--primary); text-align: center; margin-bottom: 40rpx; }

.style-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; margin-top: 16rpx; }
.style-item {
  display: flex; flex-direction: column; align-items: center;
  padding: 24rpx 16rpx;
  border: 2rpx solid var(--gray-200);
  border-radius: var(--radius-lg);
  background: var(--gray-50);
  gap: 10rpx;
  transition: border-color 0.15s, background 0.15s, transform 0.15s;
}
.style-active { border-color: var(--primary); background: var(--primary-light); }
.style-emoji { font-size: 48rpx; }
.style-name { font-size: 22rpx; color: var(--gray-600); }
.style-active .style-name { color: var(--primary); font-weight: 600; }

.color-row { display: flex; gap: 20rpx; flex-wrap: wrap; margin-top: 16rpx; }
.color-circle {
  width: 60rpx; height: 60rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
  transition: transform 0.15s, border-color 0.15s, box-shadow 0.15s;
}
.color-active {
  border-color: var(--gray-800);
  transform: scale(1.15);
  box-shadow: 0 0 0 4rpx rgba(0,0,0,0.1);
}
