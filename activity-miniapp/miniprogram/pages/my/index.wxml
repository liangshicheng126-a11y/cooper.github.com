<!-- pages/my/index.wxml - 我的页面 -->
<view class="page-wrap">
    <!-- 用户信息卡 -->
    <view class="user-card">
      <view class="user-bg" />
      <view class="user-info">
        <image src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" class="user-avatar" />
        <view class="user-detail">
          <text class="user-name">{{userInfo.nickName || '未登录'}}</text>
          <text class="user-sub" wx:if="{{userInfo.openid}}">ID: {{userInfo.openid.slice(0,8)}}...</text>
        </view>
        <view class="user-badge" wx:if="{{isAdmin}}">
          <text>管理员</text>
        </view>
      </view>

      <!-- 数据统计：点击进入二级列表页 -->
      <view class="stats-row">
        <view class="stat-item stat-tap" bindtap="goPublishedList">
          <text class="stat-num">{{myActivitiesCount}}</text>
          <text class="stat-label">发布的活动</text>
          <text class="stat-link">列表 ›</text>
        </view>
        <view class="stat-divider" />
        <view class="stat-item stat-tap" bindtap="goRegisteredList">
          <text class="stat-num">{{myRegistrationsCount}}</text>
          <text class="stat-label">参与的活动</text>
          <text class="stat-link">列表 ›</text>
        </view>
      </view>
      <text class="stats-tip">点此进入对应活动清单</text>
    </view>

    <!-- 功能菜单 -->
    <view class="menu-section">
      <view class="menu-group card">
        <view class="menu-item" bindtap="goAdmin" wx:if="{{isAdmin}}">
          <text class="menu-icon">⚙️</text>
          <text class="menu-label">管理后台</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="toggleLanguage">
          <text class="menu-icon">🌐</text>
          <text class="menu-label">语言切换</text>
          <text class="menu-value">{{langText}}</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="openPrivacyPolicy">
          <text class="menu-icon">📄</text>
          <text class="menu-label">隐私协议</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item danger" bindtap="onLogout">
          <text class="menu-icon">🚪</text>
          <text class="menu-label">退出登录</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>

    <view style="height: 60rpx;" />
</view>
