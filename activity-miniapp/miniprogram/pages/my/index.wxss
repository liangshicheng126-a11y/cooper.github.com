/* pages/my/index.wxss · 活力年轻"我的"页面 */
.page-wrap {
  min-height: 100vh;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  background: var(--bg-radial);
}

/* ── 用户卡片 ── */
.user-card {
  background: linear-gradient(145deg, rgba(255,90,61,0.22), rgba(250,204,21,0.18), rgba(124,58,237,0.12));
  border-bottom: 1rpx solid rgba(255,255,255,0.70);
  position: relative; overflow: hidden;
}
.user-card::before {
  content: '';
  position: absolute; top: -80rpx; right: -80rpx;
  width: 360rpx; height: 360rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.30) 0%, transparent 70%);
  pointer-events: none;
}

.user-info {
  display: flex; align-items: center;
  padding: calc(env(safe-area-inset-top) + 60rpx) 32rpx 28rpx;
  gap: 24rpx; position: relative; z-index: 1;
}

.user-avatar {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.80);
  background: rgba(255,255,255,0.40);
  box-shadow: 0 8rpx 24rpx rgba(255,90,61,0.20);
}

.user-detail { flex: 1; }
.user-name { font-size: 34rpx; font-weight: 800; color: var(--text-primary); display: block; letter-spacing: 0.5rpx; }
.user-sub  { font-size: 22rpx; color: var(--text-secondary); display: block; margin-top: 6rpx; }
.user-sub.login-hint { color: var(--accent-text); }

.user-badge {
  background: rgba(255,255,255,0.60);
  border: 1rpx solid rgba(255,255,255,0.80);
  padding: 8rpx 20rpx; border-radius: 100rpx;
  font-size: 22rpx; color: var(--accent-text); font-weight: 700;
  backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
}

/* ── 数据统计 ── */
.stats-row {
  display: flex;
  background: rgba(255,255,255,0.78);
  border: 1rpx solid rgba(255,255,255,0.85);
  margin: 0 24rpx;
  border-radius: 20rpx; padding: 24rpx 0;
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  box-shadow: var(--shadow-md);
  position: relative; z-index: 1;
}
.stat-item  { flex: 1; text-align: center; }
.stat-num   { display: block; font-size: 44rpx; font-weight: 800; color: var(--text-primary); }
.stat-label { font-size: 22rpx; color: var(--text-secondary); margin-top: 6rpx; display: block; }
.stat-link {
  font-size: 22rpx; color: var(--accent-text); font-weight: 700;
  margin-top: 12rpx; display: block; opacity: 0.85;
}
.stat-divider { width: 1rpx; background: var(--divider); margin: 8rpx 0; }
.stat-tap:active { opacity: 0.75; }
.stats-tip {
  display: block; text-align: center;
  font-size: 22rpx; color: var(--text-muted);
  margin: 14rpx 24rpx 22rpx; position: relative; z-index: 1;
}

/* ── 功能菜单 ── */
.menu-section { padding: 20rpx 24rpx; }

.menu-group {
  background: var(--surface);
  backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
  border: 1rpx solid rgba(255,255,255,0.95);
  border-radius: 20rpx; overflow: hidden;
  box-shadow: var(--shadow-md);
}

.menu-item {
  display: flex; align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--divider);
  transition: background var(--motion-fast), transform var(--motion-fast) var(--ease-out);
}
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: rgba(255,90,61,0.07); transform: scale(0.995); }

.menu-icon  { font-size: 36rpx; margin-right: 24rpx; }
.menu-label { font-size: 28rpx; color: var(--text-primary); flex: 1; }
.menu-value { font-size: 26rpx; color: var(--text-muted); margin-right: 8rpx; }
.menu-arrow { font-size: 36rpx; color: rgba(37,26,52,0.24); }

.menu-item.danger .menu-label { color: #dc2626; }

.mt-20 { margin-top: 24rpx; }
