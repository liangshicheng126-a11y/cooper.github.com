/* pages/my/index.wxss · 简洁高级"我的"页面 */
.page-wrap {
  min-height: 100vh;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 14% -6%, rgba(154,107,36,0.13), transparent 28%),
    radial-gradient(circle at 92% 6%, rgba(29,28,24,0.08), transparent 26%),
    linear-gradient(180deg, #f6f1e7 0%, #eee7da 44%, #e9e2d5 100%);
}

/* ── 用户卡片 ── */
.user-card {
  background: linear-gradient(180deg, #fffdf8 0%, #f7f2e8 100%);
  border-bottom: 1rpx solid rgba(29,28,24,0.10);
  border-radius: 0 0 44rpx 44rpx;
  box-shadow: 0 18rpx 42rpx rgba(83,64,34,0.10);
  position: relative; overflow: hidden;
}
.user-card::before {
  content: '';
  position: absolute; top: -80rpx; right: -80rpx;
  width: 360rpx; height: 360rpx;
  background: radial-gradient(circle, rgba(154,107,36,0.16) 0%, transparent 68%);
  pointer-events: none;
}
.user-card::after {
  content: '';
  position: absolute;
  left: 28rpx; right: 28rpx; bottom: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(154,107,36,0.24), transparent);
  pointer-events: none;
}

.user-info {
  display: flex; align-items: center;
  padding: calc(env(safe-area-inset-top) + 60rpx) 32rpx 28rpx;
  gap: 24rpx; position: relative; z-index: 1;
}

.user-avatar {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.90);
  background: rgba(255,255,255,0.60);
  box-shadow: 0 8rpx 22rpx rgba(29,28,24,0.10);
}

.user-detail { flex: 1; }
.user-name { font-size: 34rpx; font-weight: 760; color: var(--text-primary); display: block; letter-spacing: 0; }
.user-sub  { font-size: 22rpx; color: var(--text-secondary); display: block; margin-top: 6rpx; }
.user-sub.login-hint { color: var(--accent-text); }

.user-badge {
  background: rgba(154,107,36,0.08);
  border: 1rpx solid rgba(154,107,36,0.18);
  padding: 8rpx 20rpx; border-radius: 100rpx;
  font-size: 22rpx; color: var(--accent-text); font-weight: 700;
}

/* ── 数据统计 ── */
.stats-row {
  display: flex;
  background: #fffefa;
  border: 1rpx solid rgba(83,64,34,0.12);
  margin: 0 24rpx;
  border-radius: 20rpx; padding: 24rpx 0;
  box-shadow:
    0 18rpx 36rpx rgba(83,64,34,0.14),
    0 2rpx 8rpx rgba(29,28,24,0.05),
    inset 0 1rpx 0 rgba(255,255,255,0.90);
  position: relative; z-index: 1;
}
.stat-item  { flex: 1; text-align: center; }
.stat-num   { display: block; font-size: 44rpx; font-weight: 800; color: var(--text-primary); }
.stat-label { font-size: 22rpx; color: var(--text-secondary); margin-top: 6rpx; display: block; }
.stat-link {
  font-size: 22rpx; color: var(--accent-text); font-weight: 700;
  margin-top: 12rpx; display: block; opacity: 0.85;
}
.stat-divider { width: 1rpx; background: var(--divider); margin: 8rpx 0; }
.stat-tap:active { opacity: 0.75; }
.stats-tip {
  display: block; text-align: center;
  font-size: 22rpx; color: var(--text-muted);
  margin: 16rpx 24rpx 30rpx; position: relative; z-index: 1;
}

/* ── 功能菜单 ── */
.menu-section { padding: 32rpx 24rpx 20rpx; }

.menu-group {
  background: rgba(255,254,250,0.98);
  border: 1rpx solid rgba(83,64,34,0.12);
  border-radius: 20rpx; overflow: hidden;
  box-shadow:
    0 20rpx 44rpx rgba(83,64,34,0.12),
    0 2rpx 8rpx rgba(29,28,24,0.05),
    inset 0 1rpx 0 rgba(255,255,255,0.92);
}

.menu-item {
  display: flex; align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(83,64,34,0.10);
  transition: background var(--motion-fast), transform var(--motion-fast) var(--ease-out);
}
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: rgba(154,107,36,0.07); transform: scale(0.996); }

.menu-icon  { width: 44rpx; height: 44rpx; border-radius: 50%; background: rgba(154,107,36,0.12); color: var(--accent-text); font-size: 22rpx; font-weight: 700; margin-right: 24rpx; display: flex; align-items: center; justify-content: center; box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.70); }
.menu-label { font-size: 28rpx; color: var(--text-primary); flex: 1; }
.menu-value { font-size: 26rpx; color: var(--text-muted); margin-right: 8rpx; }
.menu-arrow { font-size: 36rpx; color: rgba(37,26,52,0.24); }

.menu-item.danger .menu-label { color: #dc2626; }

.mt-20 { margin-top: 24rpx; }
