/* pages/my/index.wxss · 毛玻璃"我的"页面 */
.page {
  background: linear-gradient(145deg, #0d0b1e 0%, #1a1040 40%, #0d1f3c 100%);
  min-height: 100vh;
}
.scroll-view { height: 100vh; }

/* ── 用户卡片 ── */
.user-card {
  background: linear-gradient(145deg, rgba(124,58,237,0.45), rgba(37,99,235,0.35));
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
  position: relative;
  overflow: hidden;
}

/* 背景光晕 */
.user-card::after {
  content: '';
  position: absolute;
  top: -100rpx; right: -100rpx;
  width: 400rpx; height: 400rpx;
  background: radial-gradient(circle, rgba(167,139,250,0.25) 0%, transparent 70%);
  pointer-events: none;
}

.user-info {
  display: flex;
  align-items: center;
  padding: calc(env(safe-area-inset-top) + 60rpx) 32rpx 28rpx;
  gap: 24rpx;
  position: relative;
  z-index: 1;
}

.user-avatar {
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.3);
  background: rgba(255,255,255,0.1);
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.3);
}

.user-detail { flex: 1; }
.user-name { font-size: 34rpx; font-weight: 700; color: #fff; display: block; letter-spacing: 0.5rpx; }
.user-sub  { font-size: 22rpx; color: rgba(255,255,255,0.55); display: block; margin-top: 6rpx; }

.user-badge {
  background: rgba(255,255,255,0.15);
  border: 1rpx solid rgba(255,255,255,0.2);
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

/* ── 数据统计 ── */
.stats-row {
  display: flex;
  background: rgba(255,255,255,0.07);
  border: 1rpx solid rgba(255,255,255,0.1);
  margin: 0 24rpx 0;
  border-radius: 20rpx;
  padding: 24rpx 0;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  position: relative; z-index: 1;
}
.stat-item   { flex: 1; text-align: center; }
.stat-num    { display: block; font-size: 44rpx; font-weight: 800; color: #fff; }
.stat-label  { font-size: 22rpx; color: rgba(255,255,255,0.5); margin-top: 6rpx; display: block; }
.stat-divider { width: 1rpx; background: rgba(255,255,255,0.12); margin: 8rpx 0; }

/* ── Tab 栏 ── */
.tab-bar {
  display: flex;
  background: rgba(13,11,30,0.75);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
  position: sticky; top: 0; z-index: 10;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0 20rpx;
  font-size: 28rpx;
  color: rgba(255,255,255,0.4);
  position: relative;
  transition: color 0.2s;
}
.tab-active { color: #c4b5fd; font-weight: 700; }
.tab-indicator {
  position: absolute; bottom: 0;
  left: 50%; transform: translateX(-50%);
  width: 48rpx; height: 4rpx;
  background: linear-gradient(90deg, #a78bfa, #60a5fa);
  border-radius: 2rpx;
  box-shadow: 0 2rpx 8rpx rgba(167,139,250,0.5);
}

/* ── 活动列表项 ── */
.list-container { padding: 20rpx 24rpx; }

.my-activity-item {
  display: flex;
  margin-bottom: 20rpx;
  overflow: hidden;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.07);
  border: 1rpx solid rgba(255,255,255,0.11);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  transition: transform 0.15s;
}
.my-activity-item:active { transform: scale(0.98); }

.item-cover { width: 200rpx; height: 160rpx; flex-shrink: 0; }
.item-body {
  flex: 1; padding: 20rpx 24rpx;
  display: flex; flex-direction: column;
  justify-content: space-between;
}
.item-name     { font-size: 28rpx; font-weight: 600; color: rgba(255,255,255,0.9); }
.item-info-row { margin-top: 8rpx; }
.item-time     { font-size: 22rpx; color: rgba(255,255,255,0.4); }
.item-footer {
  display: flex; align-items: center;
  justify-content: space-between; margin-top: 8rpx;
}

.status-mini {
  padding: 6rpx 16rpx; border-radius: 100rpx;
  font-size: 20rpx; font-weight: 600;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}
.status-mini-active   { background: rgba(52,211,153,0.15);  color: #34d399; border: 1rpx solid rgba(52,211,153,0.25); }
.status-mini-upcoming { background: rgba(251,191,36,0.14);  color: #fbbf24; border: 1rpx solid rgba(251,191,36,0.25); }
.status-mini-ended    { background: rgba(255,255,255,0.07); color: rgba(255,255,255,0.35); border: 1rpx solid rgba(255,255,255,0.1); }
.status-mini-full     { background: rgba(248,113,113,0.13); color: #f87171; border: 1rpx solid rgba(248,113,113,0.25); }

.item-count { font-size: 22rpx; color: rgba(255,255,255,0.35); }
.text-gray  { color: rgba(255,255,255,0.2); }

/* ── 功能菜单 ── */
.menu-section { padding: 20rpx 24rpx; }

.menu-group {
  background: rgba(255,255,255,0.07);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255,255,255,0.11);
  border-radius: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex; align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.07);
  transition: background 0.15s;
}
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: rgba(255,255,255,0.06); }

.menu-icon  { font-size: 36rpx; margin-right: 24rpx; }
.menu-label { font-size: 28rpx; color: rgba(255,255,255,0.8); flex: 1; }
.menu-value { font-size: 26rpx; color: rgba(255,255,255,0.35); margin-right: 8rpx; }
.menu-arrow { font-size: 36rpx; color: rgba(255,255,255,0.2); }

.menu-item.danger .menu-label { color: #f87171; }

.mt-20 { margin-top: 24rpx; }
