/* pages/my/index.wxss · 白色毛玻璃"我的"页面 */
.page-wrap {
  min-height: 100vh;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  background: linear-gradient(145deg, #ede9fe 0%, #faf5ff 45%, #eff6ff 100%);
}

/* ── 用户卡片 ── */
.user-card {
  background: linear-gradient(145deg, rgba(124,58,237,0.22), rgba(37,99,235,0.15));
  border-bottom: 1rpx solid rgba(255,255,255,0.70);
  position: relative; overflow: hidden;
}
.user-card::before {
  content: '';
  position: absolute; top: -80rpx; right: -80rpx;
  width: 360rpx; height: 360rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.30) 0%, transparent 70%);
  pointer-events: none;
}

.user-info {
  display: flex; align-items: center;
  padding: calc(env(safe-area-inset-top) + 60rpx) 32rpx 28rpx;
  gap: 24rpx; position: relative; z-index: 1;
}

.user-avatar {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.80);
  background: rgba(255,255,255,0.40);
  box-shadow: 0 6rpx 24rpx rgba(109,40,217,0.20);
}

.user-detail { flex: 1; }
.user-name { font-size: 34rpx; font-weight: 700; color: #1e1b4b; display: block; letter-spacing: 0.5rpx; }
.user-sub  { font-size: 22rpx; color: rgba(30,27,75,0.55); display: block; margin-top: 6rpx; }

.user-badge {
  background: rgba(255,255,255,0.60);
  border: 1rpx solid rgba(255,255,255,0.80);
  padding: 8rpx 20rpx; border-radius: 100rpx;
  font-size: 22rpx; color: #7c3aed; font-weight: 700;
  backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
}

/* ── 数据统计 ── */
.stats-row {
  display: flex;
  background: rgba(255,255,255,0.60);
  border: 1rpx solid rgba(255,255,255,0.85);
  margin: 0 24rpx;
  border-radius: 20rpx; padding: 24rpx 0;
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  box-shadow: 0 4rpx 16rpx rgba(109,40,217,0.08);
  position: relative; z-index: 1;
}
.stat-item  { flex: 1; text-align: center; }
.stat-num   { display: block; font-size: 44rpx; font-weight: 800; color: #1e1b4b; }
.stat-label { font-size: 22rpx; color: rgba(30,27,75,0.55); margin-top: 6rpx; display: block; }
.stat-divider { width: 1rpx; background: rgba(30,27,75,0.12); margin: 8rpx 0; }

/* ── Tab 栏（页内 tab） ── */
.tab-bar {
  display: flex;
  background: rgba(255,255,255,0.72);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border-bottom: 1rpx solid rgba(124,58,237,0.08);
  position: sticky; top: 0; z-index: 10;
  box-shadow: 0 2rpx 12rpx rgba(109,40,217,0.05);
}
.tab-item {
  flex: 1; text-align: center;
  padding: 28rpx 0 20rpx;
  font-size: 28rpx; color: rgba(30,27,75,0.45);
  position: relative; transition: color 0.2s;
}
.tab-active { color: #7c3aed; font-weight: 700; }
.tab-indicator {
  position: absolute; bottom: 0;
  left: 50%; transform: translateX(-50%);
  width: 48rpx; height: 4rpx;
  background: linear-gradient(90deg, #7c3aed, #2563eb);
  border-radius: 2rpx;
  box-shadow: 0 2rpx 8rpx rgba(124,58,237,0.35);
}

/* ── 活动列表项 ── */
.list-container { padding: 20rpx 24rpx; }

.my-activity-item {
  display: flex; margin-bottom: 20rpx; overflow: hidden;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.72);
  border: 1rpx solid rgba(255,255,255,0.95);
  backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
  box-shadow: 0 4rpx 16rpx rgba(109,40,217,0.07);
  transition: transform 0.15s;
}
.my-activity-item:active { transform: scale(0.98); }

.item-cover  { width: 200rpx; height: 160rpx; flex-shrink: 0; }
.item-body   {
  flex: 1; padding: 20rpx 24rpx;
  display: flex; flex-direction: column; justify-content: space-between;
}
.item-name     { font-size: 28rpx; font-weight: 600; color: #1e1b4b; }
.item-info-row { margin-top: 8rpx; }
.item-time     { font-size: 22rpx; color: rgba(30,27,75,0.45); }
.item-footer   {
  display: flex; align-items: center;
  justify-content: space-between; margin-top: 8rpx;
}

.status-mini {
  padding: 6rpx 16rpx; border-radius: 100rpx;
  font-size: 20rpx; font-weight: 600;
}
.status-mini-active   { background: rgba(5,150,105,0.10);  color: #059669; border: 1rpx solid rgba(5,150,105,0.20); }
.status-mini-upcoming { background: rgba(217,119,6,0.10);  color: #d97706; border: 1rpx solid rgba(217,119,6,0.20); }
.status-mini-ended    { background: rgba(30,27,75,0.06);   color: rgba(30,27,75,0.45); border: 1rpx solid rgba(30,27,75,0.12); }
.status-mini-full     { background: rgba(220,38,38,0.08);  color: #dc2626; border: 1rpx solid rgba(220,38,38,0.18); }

.item-count { font-size: 22rpx; color: rgba(30,27,75,0.40); }
.text-gray  { color: rgba(30,27,75,0.25); }

/* ── 功能菜单 ── */
.menu-section { padding: 20rpx 24rpx; }

.menu-group {
  background: rgba(255,255,255,0.72);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255,255,255,0.95);
  border-radius: 20rpx; overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(109,40,217,0.07);
}

.menu-item {
  display: flex; align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(30,27,75,0.06);
  transition: background 0.15s;
}
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: rgba(124,58,237,0.05); }

.menu-icon  { font-size: 36rpx; margin-right: 24rpx; }
.menu-label { font-size: 28rpx; color: #1e1b4b; flex: 1; }
.menu-value { font-size: 26rpx; color: rgba(30,27,75,0.40); margin-right: 8rpx; }
.menu-arrow { font-size: 36rpx; color: rgba(30,27,75,0.22); }

.menu-item.danger .menu-label { color: #dc2626; }

.mt-20 { margin-top: 24rpx; }
