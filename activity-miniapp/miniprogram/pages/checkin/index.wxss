/* pages/checkin/index.wxss */
.page { min-height: 100vh; background: var(--gray-50); padding: 24rpx; box-sizing: border-box; }

.qr-card, .scan-pending, .checkin-success {
  padding: 48rpx 40rpx;
  text-align: center;
}

.qr-title { display: block; font-size: 32rpx; font-weight: 700; color: var(--gray-800); margin-bottom: 8rpx; }
.qr-activity-name { display: block; font-size: 26rpx; color: var(--gray-500); margin-bottom: 32rpx; }
.qr-image { width: 480rpx; height: 480rpx; border-radius: var(--radius-lg); }
.qr-hint { display: block; font-size: 24rpx; color: var(--gray-400); margin-top: 24rpx; }

.section-card { margin-top: 20rpx; padding: 28rpx 32rpx; }
.section-title-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.refresh-btn { font-size: 26rpx; color: var(--primary); }

.checkin-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--gray-100);
  gap: 16rpx;
}
.checkin-item:last-child { border-bottom: none; }
.checkin-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; }
.checkin-info { flex: 1; }
.checkin-name { font-size: 28rpx; color: var(--gray-800); font-weight: 500; display: block; }
.checkin-time { font-size: 22rpx; color: var(--gray-400); display: block; margin-top: 4rpx; }
.checkin-badge {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: var(--success);
  color: #FFFFFF;
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; font-weight: 700;
}

/* 扫码 */
.scan-title { display: block; font-size: 36rpx; font-weight: 800; color: var(--gray-800); margin-bottom: 8rpx; }
.scan-activity { display: block; font-size: 26rpx; color: var(--primary); margin-bottom: 48rpx; }
.scan-icon-wrap {
  width: 200rpx; height: 200rpx;
  border-radius: 50%;
  background: var(--primary-light);
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 32rpx;
}
.scan-icon { font-size: 80rpx; }
.scan-hint { font-size: 26rpx; color: var(--gray-400); }

/* 签到成功 */
.success-circle {
  width: 200rpx; height: 200rpx;
  border-radius: 50%;
  background: var(--success);
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 32rpx;
  box-shadow: 0 0 0 20rpx rgba(16,185,129,0.15), 0 0 0 40rpx rgba(16,185,129,0.08);
  animation: pulse 2s infinite;
}
.success-icon { font-size: 80rpx; color: #FFFFFF; font-weight: 700; }
.success-title { display: block; font-size: 48rpx; font-weight: 800; color: var(--gray-800); margin-bottom: 16rpx; }
.success-time { display: block; font-size: 28rpx; color: var(--success); font-weight: 600; margin-bottom: 8rpx; }
.success-activity { display: block; font-size: 26rpx; color: var(--gray-500); }

.mt-24 { margin-top: 28rpx; }
.mt-16 { margin-top: 20rpx; }
.mt-32 { margin-top: 40rpx; }
