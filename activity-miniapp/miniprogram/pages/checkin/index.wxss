/* pages/checkin/index.wxss · 简洁高级签到页 */
.page {
  min-height: 100vh;
  background: var(--bg-radial);
  padding: 24rpx; box-sizing: border-box;
}

.qr-card, .scan-pending, .checkin-success {
  padding: 48rpx 40rpx; text-align: center;
  background: var(--surface);
  border: 1rpx solid rgba(29,28,24,0.08);
  border-radius: 28rpx;
  box-shadow: var(--shadow-md);
}

.qr-title         { display: block; font-size: 32rpx; font-weight: 760; color: var(--text-primary); margin-bottom: 8rpx; }
.qr-activity-name { display: block; font-size: 26rpx; color: var(--text-secondary); margin-bottom: 32rpx; }
.qr-image         { width: 480rpx; height: 480rpx; border-radius: 20rpx; border: 1rpx solid rgba(29,28,24,0.10); }
.qr-hint          { display: block; font-size: 24rpx; color: var(--text-muted); margin-top: 24rpx; }

.section-card {
  margin-top: 20rpx; padding: 28rpx 32rpx;
  background: var(--surface);
  border: 1rpx solid rgba(29,28,24,0.08);
  border-radius: 24rpx; box-shadow: var(--shadow-md);
}
.section-title-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.refresh-btn { font-size: 26rpx; color: var(--accent-text); font-weight: 700; }

.checkin-item {
  display: flex; align-items: center;
  padding: 16rpx 0; border-bottom: 1rpx solid var(--divider); gap: 16rpx;
}
.checkin-item:last-child { border-bottom: none; }
.checkin-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; background: var(--accent-light); }
.checkin-info { flex: 1; }
.checkin-name { font-size: 28rpx; color: var(--text-primary); font-weight: 600; display: block; }
.checkin-time { font-size: 22rpx; color: var(--text-muted); display: block; margin-top: 4rpx; }
.checkin-badge {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: rgba(5,150,105,0.12); border: 1rpx solid rgba(5,150,105,0.25);
  color: #059669; display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; font-weight: 700;
}

/* ── 扫码 ── */
.scan-title    { display: block; font-size: 36rpx; font-weight: 800; color: var(--text-primary); margin-bottom: 8rpx; }
.scan-activity { display: block; font-size: 26rpx; color: var(--accent-text); margin-bottom: 48rpx; }
.scan-icon-wrap {
  width: 200rpx; height: 200rpx; border-radius: 50%;
  background: var(--accent-light); border: 2rpx solid rgba(154,107,36,0.20);
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 32rpx;
  box-shadow: 0 8rpx 26rpx rgba(29,28,24,0.08);
}
.scan-icon { font-size: 54rpx; color: var(--accent-text); font-weight: 760; }
.scan-hint { font-size: 26rpx; color: var(--text-muted); }

/* ── 签到成功 ── */
.success-circle {
  width: 200rpx; height: 200rpx; border-radius: 50%;
  background: rgba(5,150,105,0.12); border: 2rpx solid rgba(5,150,105,0.30);
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(5,150,105,0.18);
  animation: none;
}
.success-icon     { font-size: 80rpx; }
.success-title    { display: block; font-size: 48rpx; font-weight: 800; color: var(--text-primary); margin-bottom: 16rpx; }
.success-time     { display: block; font-size: 28rpx; color: #059669; font-weight: 600; margin-bottom: 8rpx; }
.success-activity { display: block; font-size: 26rpx; color: var(--text-secondary); }

@media (prefers-reduced-motion: reduce) {
  .success-circle {
    animation: none;
  }
}

.mt-24 { margin-top: 28rpx; }
.mt-16 { margin-top: 20rpx; }
.mt-32 { margin-top: 40rpx; }
