/* pages/checkin/index.wxss · 白色毛玻璃签到页 */
.page {
  min-height: 100vh;
  background: linear-gradient(145deg, #ede9fe 0%, #faf5ff 45%, #eff6ff 100%);
  padding: 24rpx; box-sizing: border-box;
}

.qr-card, .scan-pending, .checkin-success {
  padding: 48rpx 40rpx; text-align: center;
  background: rgba(255,255,255,0.75);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1rpx solid rgba(255,255,255,0.95);
  border-radius: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(109,40,217,0.09);
}

.qr-title         { display: block; font-size: 32rpx; font-weight: 700; color: #1e1b4b; margin-bottom: 8rpx; }
.qr-activity-name { display: block; font-size: 26rpx; color: rgba(30,27,75,0.50); margin-bottom: 32rpx; }
.qr-image         { width: 480rpx; height: 480rpx; border-radius: 20rpx; border: 1rpx solid rgba(124,58,237,0.10); }
.qr-hint          { display: block; font-size: 24rpx; color: rgba(30,27,75,0.40); margin-top: 24rpx; }

.section-card {
  margin-top: 20rpx; padding: 28rpx 32rpx;
  background: rgba(255,255,255,0.72);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255,255,255,0.95);
  border-radius: 24rpx; box-shadow: 0 4rpx 16rpx rgba(109,40,217,0.07);
}
.section-title-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.refresh-btn { font-size: 26rpx; color: #7c3aed; }

.checkin-item {
  display: flex; align-items: center;
  padding: 16rpx 0; border-bottom: 1rpx solid rgba(30,27,75,0.06); gap: 16rpx;
}
.checkin-item:last-child { border-bottom: none; }
.checkin-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; background: rgba(124,58,237,0.08); }
.checkin-info { flex: 1; }
.checkin-name { font-size: 28rpx; color: #1e1b4b; font-weight: 500; display: block; }
.checkin-time { font-size: 22rpx; color: rgba(30,27,75,0.42); display: block; margin-top: 4rpx; }
.checkin-badge {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: rgba(5,150,105,0.12); border: 1rpx solid rgba(5,150,105,0.25);
  color: #059669; display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; font-weight: 700;
}

/* ── 扫码 ── */
.scan-title    { display: block; font-size: 36rpx; font-weight: 800; color: #1e1b4b; margin-bottom: 8rpx; }
.scan-activity { display: block; font-size: 26rpx; color: #7c3aed; margin-bottom: 48rpx; }
.scan-icon-wrap {
  width: 200rpx; height: 200rpx; border-radius: 50%;
  background: rgba(124,58,237,0.10); border: 2rpx solid rgba(124,58,237,0.22);
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(124,58,237,0.15);
}
.scan-icon { font-size: 80rpx; }
.scan-hint { font-size: 26rpx; color: rgba(30,27,75,0.45); }

/* ── 签到成功 ── */
.success-circle {
  width: 200rpx; height: 200rpx; border-radius: 50%;
  background: rgba(5,150,105,0.12); border: 2rpx solid rgba(5,150,105,0.30);
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(5,150,105,0.18);
  animation: success-pulse 2s infinite;
}
.success-icon     { font-size: 80rpx; }
.success-title    { display: block; font-size: 48rpx; font-weight: 800; color: #1e1b4b; margin-bottom: 16rpx; }
.success-time     { display: block; font-size: 28rpx; color: #059669; font-weight: 600; margin-bottom: 8rpx; }
.success-activity { display: block; font-size: 26rpx; color: rgba(30,27,75,0.55); }

@keyframes success-pulse {
  0%,100% { box-shadow: 0 8rpx 32rpx rgba(5,150,105,0.18); }
  50%      { box-shadow: 0 8rpx 48rpx rgba(5,150,105,0.30); }
}

.mt-24 { margin-top: 28rpx; }
.mt-16 { margin-top: 20rpx; }
.mt-32 { margin-top: 40rpx; }
