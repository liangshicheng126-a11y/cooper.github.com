/* pages/checkin/index.wxss · 毛玻璃签到页 */
.page {
  min-height: 100vh;
  background: linear-gradient(145deg, #0d0b1e 0%, #1a1040 40%, #0d1f3c 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.qr-card, .scan-pending, .checkin-success {
  padding: 48rpx 40rpx;
  text-align: center;
  background: rgba(255,255,255,0.07);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 28rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.4);
  position: relative;
}

.qr-title        { display: block; font-size: 32rpx; font-weight: 700; color: rgba(255,255,255,0.95); margin-bottom: 8rpx; }
.qr-activity-name{ display: block; font-size: 26rpx; color: rgba(255,255,255,0.5); margin-bottom: 32rpx; }
.qr-image        { width: 480rpx; height: 480rpx; border-radius: 20rpx; border: 2rpx solid rgba(255,255,255,0.1); }
.qr-hint         { display: block; font-size: 24rpx; color: rgba(255,255,255,0.35); margin-top: 24rpx; }

.section-card {
  margin-top: 20rpx; padding: 28rpx 32rpx;
  background: rgba(255,255,255,0.07);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 24rpx;
}
.section-title-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.refresh-btn { font-size: 26rpx; color: #a78bfa; }

.checkin-item {
  display: flex; align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.07);
  gap: 16rpx;
}
.checkin-item:last-child { border-bottom: none; }
.checkin-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; background: rgba(255,255,255,0.1); }
.checkin-info   { flex: 1; }
.checkin-name   { font-size: 28rpx; color: rgba(255,255,255,0.88); font-weight: 500; display: block; }
.checkin-time   { font-size: 22rpx; color: rgba(255,255,255,0.38); display: block; margin-top: 4rpx; }
.checkin-badge  {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: rgba(52,211,153,0.2);
  border: 1rpx solid rgba(52,211,153,0.35);
  color: #34d399;
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; font-weight: 700;
}

/* ── 扫码等待 ── */
.scan-title    { display: block; font-size: 36rpx; font-weight: 800; color: rgba(255,255,255,0.95); margin-bottom: 8rpx; }
.scan-activity { display: block; font-size: 26rpx; color: #a78bfa; margin-bottom: 48rpx; }
.scan-icon-wrap {
  width: 200rpx; height: 200rpx; border-radius: 50%;
  background: rgba(167,139,250,0.12);
  border: 2rpx solid rgba(167,139,250,0.25);
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 32rpx;
  box-shadow: 0 0 40rpx rgba(167,139,250,0.2);
}
.scan-icon { font-size: 80rpx; }
.scan-hint { font-size: 26rpx; color: rgba(255,255,255,0.4); }

/* ── 签到成功 ── */
.success-circle {
  width: 200rpx; height: 200rpx;
  border-radius: 50%;
  background: rgba(52,211,153,0.2);
  border: 2rpx solid rgba(52,211,153,0.4);
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 32rpx;
  box-shadow: 0 0 40rpx rgba(52,211,153,0.25), 0 0 80rpx rgba(52,211,153,0.12);
  animation: pulse 2s infinite;
}
.success-icon     { font-size: 80rpx; color: #34d399; font-weight: 700; }
.success-title    { display: block; font-size: 48rpx; font-weight: 800; color: rgba(255,255,255,0.95); margin-bottom: 16rpx; }
.success-time     { display: block; font-size: 28rpx; color: #34d399; font-weight: 600; margin-bottom: 8rpx; }
.success-activity { display: block; font-size: 26rpx; color: rgba(255,255,255,0.5); }

@keyframes pulse {
  0%,100% { opacity: 1; box-shadow: 0 0 40rpx rgba(52,211,153,0.25); }
  50%      { opacity: 0.85; box-shadow: 0 0 60rpx rgba(52,211,153,0.4); }
}

.mt-24 { margin-top: 28rpx; }
.mt-16 { margin-top: 20rpx; }
.mt-32 { margin-top: 40rpx; }
