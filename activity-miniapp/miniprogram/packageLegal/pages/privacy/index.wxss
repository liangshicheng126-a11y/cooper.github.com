/* pages/privacy/index.wxss */

.wrap {
  height: 100vh;
  background: var(--bg-radial);
}

.scroll {
  height: 100%;
  box-sizing: border-box;
  padding: 0 32rpx 48rpx;
}

.hero {
  padding: 28rpx 8rpx 36rpx;
}

.h1 {
  display: block;
  font-size: 42rpx;
  font-weight: 800;
  color: var(--text-primary);
  letter-spacing: 1rpx;
}

.subtitle {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  color: var(--accent-text);
  font-weight: 600;
}

.meta {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.5;
}

.section {
  background: var(--surface);
  border-radius: 20rpx;
  padding: 28rpx 28rpx 32rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.92);
  box-shadow: var(--shadow-sm);
}

.h2 {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.para {
  display: block;
  font-size: 26rpx;
  line-height: 1.75;
  color: var(--text-secondary);
  margin-bottom: 18rpx;
  text-align: justify;
}

.para:last-child {
  margin-bottom: 0;
}

.bullets {
  margin-top: 12rpx;
}

.bullet-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.bullet-item:last-child {
  margin-bottom: 0;
}

.dot {
  flex-shrink: 0;
  width: 36rpx;
  font-size: 26rpx;
  line-height: 1.65;
  color: var(--accent-text);
}

.line {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--text-secondary);
  text-align: justify;
}

.bottom-space {
  height: 80rpx;
}
