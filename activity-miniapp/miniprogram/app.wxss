/* app.wxss - 全局样式 · 白色毛玻璃美学主题 */

/* ══════════════════════════════════════
   CSS 设计令牌（白色毛玻璃）
══════════════════════════════════════ */
page {
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  box-sizing: border-box;
  color: #1e1b4b;
  background: #f0ecff;

  /* ── 背景 ── */
  --bg-page:     #f0ecff;
  --bg-gradient: linear-gradient(145deg, #ede9fe 0%, #faf5ff 45%, #eff6ff 100%);

  /* ── 白色毛玻璃层 ── */
  --glass-bg:        rgba(255,255,255,0.70);
  --glass-bg-hover:  rgba(255,255,255,0.85);
  --glass-bg-strong: rgba(255,255,255,0.88);
  --glass-border:    rgba(255,255,255,0.92);
  --glass-border-subtle: rgba(124,58,237,0.12);
  --glass-blur:      16px;
  --glass-shadow:    0 8rpx 32rpx rgba(109,40,217,0.08), 0 2rpx 8rpx rgba(109,40,217,0.04);
  --glass-shadow-sm: 0 4rpx 16rpx rgba(109,40,217,0.06);

  /* ── 主色调 ── */
  --accent:          #7c3aed;
  --accent-2:        #2563eb;
  --accent-text:     #7c3aed;
  --accent-light:    rgba(124,58,237,0.10);
  --accent-grad:     linear-gradient(135deg, #7c3aed, #2563eb);
  --accent-grad-2:   linear-gradient(135deg, #8b5cf6, #3b82f6);
  --accent-glow:     rgba(124,58,237,0.18);

  /* ── 文字 ── */
  --text-primary:   #1e1b4b;
  --text-secondary: rgba(30,27,75,0.65);
  --text-muted:     rgba(30,27,75,0.40);
  --text-accent:    #7c3aed;

  /* ── 状态色 ── */
  --success:    #059669;
  --success-bg: rgba(5,150,105,0.10);
  --warning:    #d97706;
  --warning-bg: rgba(217,119,6,0.10);
  --danger:     #dc2626;
  --danger-bg:  rgba(220,38,38,0.08);
  --info:       #2563eb;
  --info-bg:    rgba(37,99,235,0.08);

  /* ── 圆角 ── */
  --radius-sm:  12rpx;
  --radius-md:  20rpx;
  --radius-lg:  28rpx;
  --radius-xl:  36rpx;
  --radius-2xl: 48rpx;

  /* ── 分割线 ── */
  --divider: rgba(109,40,217,0.08);

  /* ── 向后兼容别名 ── */
  --primary:       #7c3aed;
  --primary-light: rgba(124,58,237,0.10);
  --primary-dark:  #6d28d9;

  --gray-50:  rgba(30,27,75,0.03);
  --gray-100: rgba(30,27,75,0.06);
  --gray-200: rgba(30,27,75,0.10);
  --gray-300: rgba(30,27,75,0.18);
  --gray-400: rgba(30,27,75,0.38);
  --gray-500: rgba(30,27,75,0.50);
  --gray-600: rgba(30,27,75,0.65);
  --gray-700: rgba(30,27,75,0.75);
  --gray-800: rgba(30,27,75,0.90);

  --shadow-sm: 0 2rpx 12rpx rgba(109,40,217,0.06);
  --shadow-md: 0 4rpx 24rpx rgba(109,40,217,0.10);
  --shadow-lg: 0 8rpx 48rpx rgba(109,40,217,0.14);
}

/* ══ 通用布局 ══ */
.container { padding: 24rpx; min-height: 100vh; }
.page-scroll { height: 100vh; }
.flex-1 { flex: 1; }
.row         { display: flex; align-items: center; }
.row-between { display: flex; align-items: center; justify-content: space-between; }

/* ══════════════════════════════════════
   白色毛玻璃卡片
══════════════════════════════════════ */
.card {
  background: var(--glass-bg);
  backdrop-filter: blur(var(--glass-blur)) saturate(180%);
  -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(180%);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-xl);
  box-shadow: var(--glass-shadow);
  overflow: hidden;
  position: relative;
}

/* 顶部高光线 */
.card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,1), transparent);
  pointer-events: none;
  z-index: 1;
}

.card-padding { padding: 32rpx; }

/* 强化卡片（表单/详情用） */
.card-solid {
  background: var(--glass-bg-strong);
  backdrop-filter: blur(24px) saturate(200%);
  -webkit-backdrop-filter: blur(24px) saturate(200%);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-xl);
  box-shadow: var(--glass-shadow);
  overflow: hidden;
}

/* ══════════════════════════════════════
   按钮
══════════════════════════════════════ */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
  padding: 0 32rpx;
  height: 88rpx;
  border: none;
  transition: transform 0.2s, opacity 0.2s, box-shadow 0.2s, background 0.2s, border-color 0.2s;
  position: relative;
  overflow: hidden;
}
.btn::after { border: none; }

/* 主按钮：渐变 + 发光 */
.btn-primary {
  background: var(--accent-grad);
  color: #fff;
  box-shadow: 0 6rpx 24rpx rgba(124,58,237,0.35);
}
.btn-primary:active {
  opacity: 0.88;
  transform: scale(0.97);
  box-shadow: 0 3rpx 12rpx rgba(124,58,237,0.25);
}

/* 轮廓按钮 */
.btn-outline {
  background: rgba(124,58,237,0.08);
  color: var(--accent);
  border: 1.5rpx solid rgba(124,58,237,0.3);
}
.btn-outline:active { background: rgba(124,58,237,0.14); transform: scale(0.97); }

/* 灰色按钮 */
.btn-gray {
  background: rgba(30,27,75,0.06);
  color: var(--text-secondary);
  border: 1rpx solid rgba(30,27,75,0.12);
}
.btn-gray:active { background: rgba(30,27,75,0.10); transform: scale(0.97); }

.btn-danger {
  background: rgba(220,38,38,0.09);
  color: var(--danger);
  border: 1rpx solid rgba(220,38,38,0.22);
}

.btn-sm   { height: 64rpx; font-size: 26rpx; padding: 0 24rpx; border-radius: var(--radius-sm); }
.btn-lg   { height: 96rpx; font-size: 32rpx; border-radius: var(--radius-2xl); }
.btn-block { width: 100%; }
.btn[disabled] { opacity: 0.4; }

/* ══════════════════════════════════════
   表单
══════════════════════════════════════ */
.form-group { margin-bottom: 32rpx; }

.form-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  letter-spacing: 0.5rpx;
}

.form-required { color: var(--danger); margin-left: 4rpx; font-size: 24rpx; }

.form-input {
  background: rgba(255,255,255,0.75);
  border: 1.5rpx solid rgba(124,58,237,0.15);
  border-radius: var(--radius-md);
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  width: 100%;
  box-sizing: border-box;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.form-input:focus {
  border-color: rgba(124,58,237,0.4);
  box-shadow: 0 0 0 4rpx rgba(124,58,237,0.08);
  background: #fff;
}

.form-textarea {
  background: rgba(255,255,255,0.75);
  border: 1.5rpx solid rgba(124,58,237,0.15);
  border-radius: var(--radius-md);
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  width: 100%;
  box-sizing: border-box;
  min-height: 160rpx;
}

.form-hint  { font-size: 22rpx; color: var(--text-muted); margin-top: 8rpx; }
.form-error { font-size: 22rpx; color: var(--danger);     margin-top: 8rpx; }

.picker-input { display: flex; align-items: center; justify-content: space-between; }
.picker-value       { color: var(--text-primary); }
.picker-placeholder { color: var(--text-muted); }

/* ══════════════════════════════════════
   标签
══════════════════════════════════════ */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 600;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}
.tag-active   { background: var(--success-bg); color: var(--success); border: 1rpx solid rgba(5,150,105,0.2); }
.tag-ended    { background: rgba(30,27,75,0.06); color: var(--text-muted); border: 1rpx solid rgba(30,27,75,0.12); }
.tag-full     { background: var(--danger-bg);  color: var(--danger);  border: 1rpx solid rgba(220,38,38,0.18); }
.tag-upcoming { background: var(--warning-bg); color: var(--warning); border: 1rpx solid rgba(217,119,6,0.2); }

/* ══════════════════════════════════════
   分割线
══════════════════════════════════════ */
.divider { height: 1rpx; background: var(--divider); margin: 24rpx 0; }

/* ══════════════════════════════════════
   空状态
══════════════════════════════════════ */
.empty-state {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 80rpx 40rpx;
}
.empty-icon { font-size: 96rpx; margin-bottom: 24rpx; opacity: 0.5; }
.empty-text { font-size: 28rpx; font-weight: 600; color: var(--text-secondary); margin-bottom: 8rpx; }
.empty-sub  { font-size: 24rpx; color: var(--text-muted); text-align: center; }

/* ══════════════════════════════════════
   底部固定栏
══════════════════════════════════════ */
.bottom-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: rgba(255,255,255,0.88);
  backdrop-filter: blur(24px) saturate(200%);
  -webkit-backdrop-filter: blur(24px) saturate(200%);
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(124,58,237,0.08);
  box-shadow: 0 -4rpx 20rpx rgba(109,40,217,0.06);
  z-index: 100;
}

/* ══════════════════════════════════════
   Section 标题
══════════════════════════════════════ */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  letter-spacing: 0.5rpx;
}
.section-title::before {
  content: '';
  width: 6rpx; height: 28rpx;
  background: var(--accent-grad);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

/* ══════════════════════════════════════
   动画
══════════════════════════════════════ */
@keyframes pulse {
  0%,100% { opacity: 1; }
  50%      { opacity: 0.5; }
}
@keyframes glow-pulse {
  0%,100% { box-shadow: 0 6rpx 24rpx rgba(124,58,237,0.30); }
  50%      { box-shadow: 0 6rpx 40rpx rgba(124,58,237,0.50); }
}
@keyframes slideUp {
  from { transform: translateY(40rpx); opacity: 0; }
  to   { transform: translateY(0);     opacity: 1; }
}
@keyframes slideDown {
  from { transform: translateY(-20rpx); opacity: 0; }
  to   { transform: translateY(0);      opacity: 1; }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes shimmer {
  0%   { background-position: -200% 0; }
  100% { background-position:  200% 0; }
}
@keyframes float {
  0%,100% { transform: translateY(0); }
  50%      { transform: translateY(-8rpx); }
}

.animate-slide-up   { animation: slideUp   0.35s cubic-bezier(0.25,0.46,0.45,0.94); }
.animate-slide-down { animation: slideDown 0.30s cubic-bezier(0.25,0.46,0.45,0.94); }
.animate-fade-in    { animation: fadeIn    0.30s ease-out; }

/* ══════════════════════════════════════
   骨架屏（浅色版）
══════════════════════════════════════ */
.skeleton-base {
  background: linear-gradient(90deg,
    rgba(124,58,237,0.05) 25%,
    rgba(124,58,237,0.12) 50%,
    rgba(124,58,237,0.05) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.8s infinite;
  border-radius: var(--radius-sm);
}

/* ══════════════════════════════════════
   脉冲绿点
══════════════════════════════════════ */
.pulse-dot {
  width: 14rpx; height: 14rpx;
  border-radius: 50%;
  background: var(--success);
  display: inline-block;
  margin-right: 8rpx;
  animation: pulse 2s infinite;
  box-shadow: 0 0 8rpx rgba(5,150,105,0.4);
}

/* ══════════════════════════════════════
   文字工具
══════════════════════════════════════ */
.text-ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.text-ellipsis-2 {
  overflow: hidden; text-overflow: ellipsis;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
}

/* ══════════════════════════════════════
   遮罩
══════════════════════════════════════ */
.mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(30,27,75,0.35);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  z-index: 200;
  animation: fadeIn 0.2s;
}

/* ══════════════════════════════════════
   安全区
══════════════════════════════════════ */
.safe-bottom { padding-bottom: env(safe-area-inset-bottom); }

/* 自定义导航：返回栏位置请用 utils/nav.js（与胶囊对齐），勿仅用 env(safe-area-inset-top) */
