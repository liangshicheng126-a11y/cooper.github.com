/* app.wxss - 全局样式 · 简洁高级活动产品主题 */
page {
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  box-sizing: border-box;
  color: #1d1c18;
  background: #f7f5ef;

  /* 背景与表面 */
  --bg-page: #f7f5ef;
  --bg-gradient: linear-gradient(180deg, #f7f5ef 0%, #f4f1ea 48%, #efece4 100%);
  --bg-radial: radial-gradient(circle at 12% -8%, rgba(154,107,36,0.10), transparent 32%),
               radial-gradient(circle at 92% 4%, rgba(29,28,24,0.05), transparent 28%),
               linear-gradient(180deg, #f7f5ef 0%, #f4f1ea 48%, #efece4 100%);
  --surface: rgba(255,255,255,0.88);
  --surface-strong: #fffefa;
  --surface-soft: #f8f6f0;
  --surface-tint: rgba(154,107,36,0.08);
  --surface-violet: rgba(29,28,24,0.05);
  --surface-yellow: rgba(154,107,36,0.10);
  --border-subtle: rgba(29,28,24,0.08);
  --border-strong: rgba(154,107,36,0.20);

  /* 兼容旧毛玻璃变量，语义改为轻表面层 */
  --glass-bg: var(--surface);
  --glass-bg-hover: #fffefa;
  --glass-bg-strong: var(--surface-strong);
  --glass-border: rgba(29,28,24,0.08);
  --glass-border-subtle: var(--border-strong);
  --glass-blur: 0px;
  --glass-shadow: 0 18rpx 42rpx rgba(29,28,24,0.08), 0 2rpx 8rpx rgba(29,28,24,0.04);
  --glass-shadow-sm: 0 8rpx 18rpx rgba(29,28,24,0.06);

  /* 主色调 */
  --accent: #9a6b24;
  --accent-2: #1d1c18;
  --accent-3: #c9a45b;
  --accent-text: #8a5f1d;
  --accent-light: rgba(154,107,36,0.10);
  --accent-strong: #6f4c18;
  --accent-grad: linear-gradient(135deg, #1d1c18 0%, #3a3429 100%);
  --accent-grad-2: linear-gradient(135deg, #9a6b24 0%, #c9a45b 100%);
  --accent-grad-soft: linear-gradient(135deg, rgba(154,107,36,0.12), rgba(29,28,24,0.04));
  --accent-glow: rgba(154,107,36,0.18);

  /* 文字 */
  --text-primary: #1d1c18;
  --text-secondary: rgba(29,28,24,0.68);
  --text-muted: rgba(29,28,24,0.46);
  --text-accent: var(--accent-text);

  /* 状态色 */
  --success: #059669;
  --success-bg: rgba(5,150,105,0.12);
  --warning: #d97706;
  --warning-bg: rgba(250,204,21,0.18);
  --danger: #dc2626;
  --danger-bg: rgba(220,38,38,0.09);
  --info: #3b5b85;
  --info-bg: rgba(59,91,133,0.10);

  /* 圆角 */
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-xl: 36rpx;
  --radius-2xl: 48rpx;

  /* 动效 */
  --motion-fast: 120ms;
  --motion-base: 200ms;
  --motion-medium: 280ms;
  --motion-slow: 400ms;
  --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
  --ease-pop: cubic-bezier(0.2, 0, 0, 1);

  --divider: rgba(29,28,24,0.08);

  /* 向后兼容别名 */
  --primary: var(--accent);
  --primary-light: var(--accent-light);
  --primary-dark: var(--accent-strong);

  --gray-50: rgba(29,28,24,0.035);
  --gray-100: rgba(29,28,24,0.06);
  --gray-200: rgba(29,28,24,0.10);
  --gray-300: rgba(29,28,24,0.18);
  --gray-400: rgba(29,28,24,0.38);
  --gray-500: rgba(29,28,24,0.50);
  --gray-600: rgba(29,28,24,0.66);
  --gray-700: rgba(29,28,24,0.78);
  --gray-800: rgba(29,28,24,0.90);

  --shadow-sm: 0 4rpx 12rpx rgba(29,28,24,0.05);
  --shadow-md: 0 12rpx 30rpx rgba(29,28,24,0.08), 0 2rpx 8rpx rgba(29,28,24,0.04);
  --shadow-lg: 0 22rpx 58rpx rgba(29,28,24,0.12), 0 8rpx 18rpx rgba(29,28,24,0.06);
}

/* ══ 通用布局 ══ */
.container { padding: 24rpx; min-height: 100vh; }
.page-scroll { height: 100vh; }
.flex-1 { flex: 1; }
.row         { display: flex; align-items: center; }
.row-between { display: flex; align-items: center; justify-content: space-between; }

.card {
  background: var(--glass-bg);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-xl);
  box-shadow: var(--glass-shadow);
  overflow: hidden;
  position: relative;
}

.card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, var(--accent), rgba(154,107,36,0.18));
  opacity: 0.42;
  pointer-events: none;
  z-index: 1;
}

.card-padding { padding: 32rpx; }

.card-solid {
  background: var(--glass-bg-strong);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-xl);
  box-shadow: var(--glass-shadow);
  overflow: hidden;
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
  padding: 0 32rpx;
  height: 88rpx;
  border: none;
  transition: transform var(--motion-fast) var(--ease-out), opacity var(--motion-fast), box-shadow var(--motion-base) var(--ease-out), background var(--motion-base), border-color var(--motion-base);
  position: relative;
  overflow: hidden;
}
.btn::after { border: none; }

.btn-primary {
  background: var(--accent-grad);
  color: #fff;
  box-shadow: 0 12rpx 26rpx rgba(29,28,24,0.16);
}
.btn-primary:active {
  opacity: 0.92;
  transform: translateY(2rpx) scale(0.985);
  box-shadow: 0 6rpx 16rpx rgba(29,28,24,0.14);
}

.btn-outline {
  background: rgba(154,107,36,0.08);
  color: var(--accent-text);
  border: 1.5rpx solid rgba(154,107,36,0.26);
}
.btn-outline:active { background: rgba(154,107,36,0.13); transform: scale(0.985); }

.btn-gray {
  background: rgba(37,26,52,0.06);
  color: var(--text-secondary);
  border: 1rpx solid rgba(37,26,52,0.12);
}
.btn-gray:active { background: rgba(29,28,24,0.10); transform: scale(0.985); }

.btn-danger {
  background: rgba(220,38,38,0.09);
  color: var(--danger);
  border: 1rpx solid rgba(220,38,38,0.22);
}

.btn-sm   { height: 64rpx; font-size: 26rpx; padding: 0 24rpx; border-radius: var(--radius-sm); }
.btn-lg   { height: 96rpx; font-size: 32rpx; border-radius: var(--radius-2xl); }
.btn-block { width: 100%; }
.btn[disabled] { opacity: 0.4; }

.form-group { margin-bottom: 32rpx; }

.form-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  letter-spacing: 0.5rpx;
}

.form-required { color: var(--danger); margin-left: 4rpx; font-size: 24rpx; }

.form-input {
  background: rgba(255,255,255,0.82);
  border: 1.5rpx solid rgba(29,28,24,0.12);
  border-radius: var(--radius-md);
  height: 88rpx;
  min-height: 88rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  line-height: 88rpx;
  color: var(--text-primary);
  width: 100%;
  box-sizing: border-box;
  transition: border-color var(--motion-base), box-shadow var(--motion-base), background var(--motion-base);
}
.form-input:focus {
  border-color: rgba(154,107,36,0.48);
  box-shadow: 0 0 0 5rpx rgba(154,107,36,0.10);
  background: #fff;
}

.form-textarea {
  background: rgba(255,255,255,0.82);
  border: 1.5rpx solid rgba(29,28,24,0.12);
  border-radius: var(--radius-md);
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  line-height: 1.55;
  color: var(--text-primary);
  width: 100%;
  box-sizing: border-box;
  min-height: 160rpx;
}

.form-hint  { font-size: 22rpx; color: var(--text-muted); margin-top: 8rpx; }
.form-error { font-size: 22rpx; color: var(--danger);     margin-top: 8rpx; }

.picker-input { display: flex; align-items: center; justify-content: space-between; line-height: normal; }
.picker-value       { color: var(--text-primary); }
.picker-placeholder { color: var(--text-muted); }

.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 600;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}
.tag-active   { background: var(--success-bg); color: var(--success); border: 1rpx solid rgba(5,150,105,0.2); }
.tag-ended    { background: rgba(30,27,75,0.06); color: var(--text-muted); border: 1rpx solid rgba(30,27,75,0.12); }
.tag-full     { background: var(--danger-bg);  color: var(--danger);  border: 1rpx solid rgba(220,38,38,0.18); }
.tag-upcoming { background: var(--warning-bg); color: var(--warning); border: 1rpx solid rgba(217,119,6,0.2); }

.divider { height: 1rpx; background: var(--divider); margin: 24rpx 0; }

.empty-state {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 80rpx 40rpx;
}
.empty-icon { font-size: 96rpx; margin-bottom: 24rpx; opacity: 0.5; }
.empty-text { font-size: 28rpx; font-weight: 600; color: var(--text-secondary); margin-bottom: 8rpx; }
.empty-sub  { font-size: 24rpx; color: var(--text-muted); text-align: center; }

.bottom-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: rgba(255,255,255,0.94);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(29,28,24,0.08);
  box-shadow: 0 -8rpx 24rpx rgba(29,28,24,0.06);
  z-index: 100;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  letter-spacing: 0.5rpx;
}
.section-title::before {
  content: '';
  width: 12rpx; height: 28rpx;
  background: var(--accent);
  border-radius: 999rpx;
  margin-right: 16rpx;
}

@keyframes pulse {
  0%,100% { opacity: 1; }
  50%      { opacity: 0.5; }
}
@keyframes glow-pulse {
  0%,100% { box-shadow: 0 8rpx 20rpx rgba(154,107,36,0.16); }
  50%      { box-shadow: 0 10rpx 26rpx rgba(154,107,36,0.20); }
}
@keyframes slideUp {
  from { transform: translateY(40rpx); opacity: 0; }
  to   { transform: translateY(0);     opacity: 1; }
}
@keyframes slideDown {
  from { transform: translateY(-20rpx); opacity: 0; }
  to   { transform: translateY(0);      opacity: 1; }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes shimmer {
  0%   { background-position: -200% 0; }
  100% { background-position:  200% 0; }
}
.animate-slide-up   { animation: slideUp var(--motion-medium) var(--ease-out); }
.animate-slide-down { animation: slideDown var(--motion-medium) var(--ease-out); }
.animate-fade-in    { animation: fadeIn var(--motion-base) var(--ease-out); }

.skeleton-base {
  background: linear-gradient(90deg,
    rgba(29,28,24,0.05) 25%,
    rgba(154,107,36,0.12) 50%,
    rgba(29,28,24,0.05) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.8s infinite;
  border-radius: var(--radius-sm);
}

.pulse-dot {
  width: 14rpx; height: 14rpx;
  border-radius: 50%;
  background: var(--success);
  display: inline-block;
  margin-right: 8rpx;
  animation: pulse 2s infinite;
  box-shadow: 0 0 8rpx rgba(5,150,105,0.4);
}

.text-ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.text-ellipsis-2 {
  overflow: hidden; text-overflow: ellipsis;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
}

.mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(37,26,52,0.36);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  z-index: 200;
  animation: fadeIn 0.2s;
}

.safe-bottom { padding-bottom: env(safe-area-inset-bottom); }

/* 自定义导航：返回栏位置请用 utils/nav.js（与胶囊对齐），勿仅用 env(safe-area-inset-top) */

@media (prefers-reduced-motion: reduce) {
  .animate-slide-up,
  .animate-slide-down,
  .animate-fade-in,
  .skeleton-base,
  .pulse-dot {
    animation: none !important;
  }

  .btn,
  .card,
  .form-input,
  .form-textarea {
    transition: opacity var(--motion-fast), background var(--motion-fast), border-color var(--motion-fast) !important;
  }
}
