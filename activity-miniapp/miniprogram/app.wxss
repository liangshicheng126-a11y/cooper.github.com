/* app.wxss - 全局样式 · 毛玻璃美学主题 */

/* ══════════════════════════════════════
   CSS 设计令牌
══════════════════════════════════════ */
page {
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  box-sizing: border-box;
  color: rgba(255,255,255,0.92);

  /* 深色渐变背景 */
  --bg-gradient: linear-gradient(145deg, #0d0b1e 0%, #1a1040 40%, #0d1f3c 100%);
  --bg-page: #0d0b1e;

  /* 毛玻璃层 */
  --glass-bg:       rgba(255,255,255,0.07);
  --glass-bg-hover: rgba(255,255,255,0.11);
  --glass-bg-strong:rgba(255,255,255,0.13);
  --glass-border:   rgba(255,255,255,0.14);
  --glass-border-strong: rgba(255,255,255,0.22);
  --glass-blur:     20px;
  --glass-shadow:   0 8rpx 40rpx rgba(0,0,0,0.45);
  --glass-shadow-sm:0 4rpx 20rpx rgba(0,0,0,0.3);

  /* 主色调 - 紫蓝渐变 */
  --accent:         #a78bfa;
  --accent-2:       #60a5fa;
  --accent-grad:    linear-gradient(135deg, #7c3aed, #2563eb);
  --accent-grad-2:  linear-gradient(135deg, #a78bfa, #60a5fa);
  --accent-glow:    rgba(124,58,237,0.35);

  /* 文字 */
  --text-primary:   rgba(255,255,255,0.95);
  --text-secondary: rgba(255,255,255,0.65);
  --text-muted:     rgba(255,255,255,0.38);
  --text-accent:    #c4b5fd;

  /* 状态色 */
  --success:        #34d399;
  --success-bg:     rgba(52,211,153,0.12);
  --warning:        #fbbf24;
  --warning-bg:     rgba(251,191,36,0.12);
  --danger:         #f87171;
  --danger-bg:      rgba(248,113,113,0.12);
  --info:           #60a5fa;
  --info-bg:        rgba(96,165,250,0.12);

  /* 圆角 */
  --radius-sm:  12rpx;
  --radius-md:  20rpx;
  --radius-lg:  28rpx;
  --radius-xl:  36rpx;
  --radius-2xl: 48rpx;

  /* 分割线 */
  --divider: rgba(255,255,255,0.08);
}

/* ══ 页面背景 ══ */
page {
  background: var(--bg-page);
  min-height: 100vh;
}

/* ══════════════════════════════════════
   通用布局
══════════════════════════════════════ */
.page-bg {
  min-height: 100vh;
  background: var(--bg-gradient);
  position: relative;
}

/* 背景光晕装饰 */
.page-bg::before {
  content: '';
  position: fixed;
  top: -200rpx;
  left: -200rpx;
  width: 700rpx;
  height: 700rpx;
  background: radial-gradient(circle, rgba(124,58,237,0.18) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}
.page-bg::after {
  content: '';
  position: fixed;
  bottom: -150rpx;
  right: -100rpx;
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(37,99,235,0.15) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

.container { padding: 24rpx; min-height: 100vh; }
.page-scroll { height: 100vh; }
.flex-1 { flex: 1; }
.row { display: flex; align-items: center; }
.row-between { display: flex; align-items: center; justify-content: space-between; }

/* ══════════════════════════════════════
   毛玻璃卡片
══════════════════════════════════════ */
.card {
  background: var(--glass-bg);
  backdrop-filter: blur(var(--glass-blur));
  -webkit-backdrop-filter: blur(var(--glass-blur));
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-xl);
  box-shadow: var(--glass-shadow);
  overflow: hidden;
  position: relative;
}

.card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
  pointer-events: none;
}

.card-padding { padding: 32rpx; }

/* 强化玻璃卡（表单/详情用） */
.card-solid {
  background: rgba(255,255,255,0.10);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1rpx solid var(--glass-border-strong);
  border-radius: var(--radius-xl);
  box-shadow: var(--glass-shadow);
  overflow: hidden;
}

/* 深色实底卡（导航栏用） */
.card-dark {
  background: rgba(13,11,30,0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1rpx solid var(--glass-border);
}

/* ══════════════════════════════════════
   按钮
══════════════════════════════════════ */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
  padding: 0 32rpx;
  height: 88rpx;
  border: none;
  transition: all 0.2s;
  position: relative;
  overflow: hidden;
}
.btn::after { border: none; }

/* 主按钮：渐变 + 发光 */
.btn-primary {
  background: var(--accent-grad);
  color: #fff;
  box-shadow: 0 4rpx 24rpx var(--accent-glow);
}
.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.97);
  box-shadow: 0 2rpx 12rpx var(--accent-glow);
}

/* 轮廓按钮：玻璃边框 */
.btn-outline {
  background: rgba(167,139,250,0.1);
  color: var(--accent);
  border: 1.5rpx solid rgba(167,139,250,0.4);
}
.btn-outline:active { background: rgba(167,139,250,0.18); transform: scale(0.97); }

/* 灰色按钮 */
.btn-gray {
  background: rgba(255,255,255,0.08);
  color: var(--text-secondary);
  border: 1rpx solid var(--glass-border);
}
.btn-gray:active { background: rgba(255,255,255,0.13); transform: scale(0.97); }

.btn-danger {
  background: rgba(248,113,113,0.2);
  color: var(--danger);
  border: 1rpx solid rgba(248,113,113,0.3);
}

.btn-sm   { height: 64rpx; font-size: 26rpx; padding: 0 24rpx; border-radius: var(--radius-sm); }
.btn-lg   { height: 96rpx; font-size: 32rpx; border-radius: var(--radius-2xl); }
.btn-block { width: 100%; }
.btn[disabled] { opacity: 0.4; }

/* ══════════════════════════════════════
   表单
══════════════════════════════════════ */
.form-group { margin-bottom: 32rpx; }

.form-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  letter-spacing: 1rpx;
}

.form-required { color: var(--danger); margin-left: 4rpx; font-size: 24rpx; }

.form-input {
  background: rgba(255,255,255,0.06);
  border: 1.5rpx solid var(--glass-border);
  border-radius: var(--radius-md);
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  width: 100%;
  box-sizing: border-box;
  transition: border-color 0.2s, background 0.2s;
}
.form-input:focus {
  border-color: rgba(167,139,250,0.5);
  background: rgba(255,255,255,0.09);
}

.form-textarea {
  background: rgba(255,255,255,0.06);
  border: 1.5rpx solid var(--glass-border);
  border-radius: var(--radius-md);
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  width: 100%;
  box-sizing: border-box;
  min-height: 160rpx;
}

.form-hint  { font-size: 22rpx; color: var(--text-muted); margin-top: 8rpx; }
.form-error { font-size: 22rpx; color: var(--danger);     margin-top: 8rpx; }

/* picker 输入行 */
.picker-input {
  display: flex;
  align-items: center;
  justify-content: space-between;
  cursor: pointer;
}
.picker-value      { color: var(--text-primary); }
.picker-placeholder{ color: var(--text-muted); }

/* ══════════════════════════════════════
   标签
══════════════════════════════════════ */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 600;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}
.tag-active   { background: var(--success-bg);  color: var(--success); border: 1rpx solid rgba(52,211,153,0.25); }
.tag-ended    { background: rgba(255,255,255,0.07); color: var(--text-muted); border: 1rpx solid var(--glass-border); }
.tag-full     { background: var(--danger-bg);   color: var(--danger);  border: 1rpx solid rgba(248,113,113,0.25); }
.tag-upcoming { background: var(--warning-bg);  color: var(--warning); border: 1rpx solid rgba(251,191,36,0.25); }

/* ══════════════════════════════════════
   分割线
══════════════════════════════════════ */
.divider {
  height: 1rpx;
  background: var(--divider);
  margin: 24rpx 0;
}

/* ══════════════════════════════════════
   空状态
══════════════════════════════════════ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}
.empty-icon { font-size: 96rpx; margin-bottom: 24rpx; opacity: 0.6; }
.empty-text { font-size: 28rpx; font-weight: 600; color: var(--text-secondary); margin-bottom: 8rpx; }
.empty-sub  { font-size: 24rpx; color: var(--text-muted); text-align: center; }

/* ══════════════════════════════════════
   底部固定栏
══════════════════════════════════════ */
.bottom-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: rgba(13,11,30,0.88);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--glass-border);
  z-index: 100;
}

/* ══════════════════════════════════════
   Section 标题
══════════════════════════════════════ */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  letter-spacing: 1rpx;
}
.section-title::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background: var(--accent-grad-2);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

/* ══════════════════════════════════════
   动画
══════════════════════════════════════ */
@keyframes pulse {
  0%,100% { opacity: 1; }
  50%      { opacity: 0.4; }
}
@keyframes glow-pulse {
  0%,100% { box-shadow: 0 0 20rpx var(--accent-glow); }
  50%      { box-shadow: 0 0 40rpx var(--accent-glow), 0 0 80rpx var(--accent-glow); }
}
@keyframes slideUp {
  from { transform: translateY(40rpx); opacity: 0; }
  to   { transform: translateY(0);     opacity: 1; }
}
@keyframes slideDown {
  from { transform: translateY(-20rpx); opacity: 0; }
  to   { transform: translateY(0);      opacity: 1; }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes shimmer {
  0%   { background-position: -200% 0; }
  100% { background-position:  200% 0; }
}

.animate-slide-up   { animation: slideUp  0.35s cubic-bezier(0.25,0.46,0.45,0.94); }
.animate-slide-down { animation: slideDown 0.3s cubic-bezier(0.25,0.46,0.45,0.94); }
.animate-fade-in    { animation: fadeIn   0.3s ease-out; }

/* ══════════════════════════════════════
   骨架屏（深色版）
══════════════════════════════════════ */
.skeleton-base {
  background: linear-gradient(90deg,
    rgba(255,255,255,0.05) 25%,
    rgba(255,255,255,0.10) 50%,
    rgba(255,255,255,0.05) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.8s infinite;
  border-radius: var(--radius-sm);
}

/* ══════════════════════════════════════
   脉冲指示点
══════════════════════════════════════ */
.pulse-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--success);
  display: inline-block;
  margin-right: 8rpx;
  animation: pulse 2s infinite;
  box-shadow: 0 0 10rpx var(--success);
}

/* ══════════════════════════════════════
   文字工具
══════════════════════════════════════ */
.text-ellipsis {
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.text-ellipsis-2 {
  overflow: hidden; text-overflow: ellipsis;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
}

/* ══════════════════════════════════════
   遮罩
══════════════════════════════════════ */
.mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  z-index: 200;
  animation: fadeIn 0.2s;
}

/* ══════════════════════════════════════
   安全区
══════════════════════════════════════ */
.safe-bottom { padding-bottom: env(safe-area-inset-bottom); }
