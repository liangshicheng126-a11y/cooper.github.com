/* app.wxss - 全局样式 */
page {
  background-color: #F8F9FD;
  font-family: -apple-system, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  color: #1A1A2E;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* ===== CSS 变量 ===== */
page {
  --primary: #4F46E5;
  --primary-light: #EEF2FF;
  --primary-dark: #3730A3;
  --success: #10B981;
  --warning: #F59E0B;
  --danger: #EF4444;
  --gray-50: #F9FAFB;
  --gray-100: #F3F4F6;
  --gray-200: #E5E7EB;
  --gray-300: #D1D5DB;
  --gray-400: #9CA3AF;
  --gray-500: #6B7280;
  --gray-600: #4B5563;
  --gray-700: #374151;
  --gray-800: #1F2937;
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.06);
  --shadow-md: 0 4rpx 20rpx rgba(0,0,0,0.10);
  --shadow-lg: 0 8rpx 40rpx rgba(0,0,0,0.14);
}

/* ===== 通用容器 ===== */
.container {
  padding: 24rpx;
  min-height: 100vh;
}

.page-scroll {
  height: 100vh;
}

/* ===== 卡片 ===== */
.card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.card-padding {
  padding: 32rpx;
}

/* ===== 按钮 ===== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
  padding: 0 32rpx;
  height: 88rpx;
  transition: all 0.2s;
  border: none;
}

.btn::after { border: none; }

.btn-primary {
  background: var(--primary);
  color: #FFFFFF;
}

.btn-primary:active {
  background: var(--primary-dark);
  transform: scale(0.98);
}

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
}

.btn-outline:active {
  background: var(--primary-light);
  transform: scale(0.98);
}

.btn-danger {
  background: var(--danger);
  color: #FFFFFF;
}

.btn-gray {
  background: var(--gray-100);
  color: var(--gray-600);
}

.btn-sm {
  height: 64rpx;
  font-size: 26rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-sm);
}

.btn-lg {
  height: 96rpx;
  font-size: 32rpx;
  border-radius: var(--radius-xl);
}

.btn-block {
  width: 100%;
}

.btn[disabled] {
  opacity: 0.5;
}

/* ===== 表单 ===== */
.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--gray-700);
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.form-required {
  color: var(--danger);
  margin-left: 4rpx;
  font-size: 24rpx;
}

.form-input {
  background: var(--gray-50);
  border: 2rpx solid var(--gray-200);
  border-radius: var(--radius-md);
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: var(--gray-800);
  width: 100%;
  box-sizing: border-box;
  transition: border-color 0.2s;
}

.form-input:focus {
  border-color: var(--primary);
  background: #FFFFFF;
}

.form-input-placeholder {
  color: var(--gray-400);
}

.form-textarea {
  background: var(--gray-50);
  border: 2rpx solid var(--gray-200);
  border-radius: var(--radius-md);
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: var(--gray-800);
  width: 100%;
  box-sizing: border-box;
  min-height: 160rpx;
}

.form-hint {
  font-size: 22rpx;
  color: var(--gray-400);
  margin-top: 8rpx;
}

.form-error {
  font-size: 22rpx;
  color: var(--danger);
  margin-top: 8rpx;
}

/* ===== 标签 ===== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.tag-active {
  background: #DCFCE7;
  color: #16A34A;
}

.tag-ended {
  background: var(--gray-100);
  color: var(--gray-500);
}

.tag-full {
  background: #FEE2E2;
  color: #DC2626;
}

.tag-upcoming {
  background: #FEF3C7;
  color: #D97706;
}

/* ===== 分割线 ===== */
.divider {
  height: 1rpx;
  background: var(--gray-100);
  margin: 24rpx 0;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  color: var(--gray-400);
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--gray-500);
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: var(--gray-400);
  text-align: center;
}

/* ===== 加载 ===== */
.loading-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

/* ===== 安全区域 ===== */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===== 动画 ===== */
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

@keyframes slideUp {
  from { transform: translateY(40rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.animate-slide-up {
  animation: slideUp 0.3s ease-out;
}

.animate-fade-in {
  animation: fadeIn 0.3s ease-out;
}

/* ===== 脉冲绿点 ===== */
.pulse-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #10B981;
  display: inline-block;
  margin-right: 8rpx;
  animation: pulse 2s infinite;
}

/* ===== 文字省略 ===== */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* ===== 底部固定栏 ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 20rpx rgba(0,0,0,0.08);
  z-index: 100;
}

/* ===== 遮罩 ===== */
.mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 200;
  animation: fadeIn 0.2s;
}

/* ===== Section 标题 ===== */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--gray-800);
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: var(--primary);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

/* ===== 行布局 ===== */
.row {
  display: flex;
  align-items: center;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-1 { flex: 1; }
