/* app.wxss - 全局样式 · 活力年轻产品主题 */
page {
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  box-sizing: border-box;
  color: #251a34;
  background: #fff7ed;

  /* 背景与表面 */
  --bg-page: #fff7ed;
  --bg-gradient: linear-gradient(160deg, #fff7ed 0%, #fff1f2 42%, #eef2ff 100%);
  --bg-radial: radial-gradient(circle at 12% 0%, rgba(250,204,21,0.24), transparent 34%),
               radial-gradient(circle at 86% 12%, rgba(255,90,61,0.20), transparent 30%),
               linear-gradient(160deg, #fff7ed 0%, #fff1f2 42%, #eef2ff 100%);
  --surface: rgba(255,255,255,0.88);
  --surface-strong: rgba(255,255,255,0.96);
  --surface-soft: rgba(255,246,238,0.78);
  --surface-tint: rgba(255,90,61,0.08);
  --surface-violet: rgba(124,58,237,0.08);
  --surface-yellow: rgba(250,204,21,0.14);
  --border-subtle: rgba(37,26,52,0.08);
  --border-strong: rgba(255,90,61,0.18);

  /* 兼容旧毛玻璃变量，语义改为轻表面层 */
  --glass-bg: var(--surface);
  --glass-bg-hover: rgba(255,255,255,0.98);
  --glass-bg-strong: var(--surface-strong);
  --glass-border: rgba(255,255,255,0.96);
  --glass-border-subtle: var(--border-strong);
  --glass-blur: 12px;
  --glass-shadow: 0 16rpx 42rpx rgba(255,90,61,0.12), 0 4rpx 14rpx rgba(37,26,52,0.06);
  --glass-shadow-sm: 0 8rpx 22rpx rgba(255,90,61,0.09);

  /* 主色调 */
  --accent: #ff5a3d;
  --accent-2: #7c3aed;
  --accent-3: #facc15;
  --accent-text: #e84a2a;
  --accent-light: rgba(255,90,61,0.12);
  --accent-strong: #d63f24;
  --accent-grad: linear-gradient(135deg, #ff5a3d 0%, #ff7a45 48%, #7c3aed 100%);
  --accent-grad-2: linear-gradient(135deg, #ff7a45 0%, #facc15 100%);
  --accent-grad-soft: linear-gradient(135deg, rgba(255,90,61,0.16), rgba(124,58,237,0.10));
  --accent-glow: rgba(255,90,61,0.24);

  /* 文字 */
  --text-primary: #251a34;
  --text-secondary: rgba(37,26,52,0.68);
  --text-muted: rgba(37,26,52,0.42);
  --text-accent: var(--accent-text);

  /* 状态色 */
  --success: #059669;
  --success-bg: rgba(5,150,105,0.12);
  --warning: #d97706;
  --warning-bg: rgba(250,204,21,0.18);
  --danger: #dc2626;
  --danger-bg: rgba(220,38,38,0.09);
  --info: #2563eb;
  --info-bg: rgba(37,99,235,0.09);

  /* 圆角 */
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-xl: 36rpx;
  --radius-2xl: 48rpx;

  /* 动效 */
  --motion-fast: 120ms;
  --motion-base: 200ms;
  --motion-medium: 280ms;
  --motion-slow: 400ms;
  --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
  --ease-pop: cubic-bezier(0.2, 0, 0, 1);

  --divider: rgba(37,26,52,0.08);

  /* 向后兼容别名 */
  --primary: var(--accent);
  --primary-light: var(--accent-light);
  --primary-dark: var(--accent-strong);

  --gray-50: rgba(37,26,52,0.035);
  --gray-100: rgba(37,26,52,0.06);
  --gray-200: rgba(37,26,52,0.10);
  --gray-300: rgba(37,26,52,0.18);
  --gray-400: rgba(37,26,52,0.38);
  --gray-500: rgba(37,26,52,0.50);
  --gray-600: rgba(37,26,52,0.66);
  --gray-700: rgba(37,26,52,0.78);
  --gray-800: rgba(37,26,52,0.90);

  --shadow-sm: 0 4rpx 14rpx rgba(37,26,52,0.05);
  --shadow-md: 0 10rpx 28rpx rgba(255,90,61,0.10), 0 3rpx 10rpx rgba(37,26,52,0.06);
  --shadow-lg: 0 18rpx 56rpx rgba(255,90,61,0.16), 0 8rpx 18rpx rgba(37,26,52,0.08);
}

/* ══ 通用布局 ══ */
.container { padding: 24rpx; min-height: 100vh; }
.page-scroll { height: 100vh; }
.flex-1 { flex: 1; }
.row         { display: flex; align-items: center; }
.row-between { display: flex; align-items: center; justify-content: space-between; }

.card {
  background: var(--glass-bg);
  backdrop-filter: blur(var(--glass-blur)) saturate(145%);
  -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(145%);
  border: 1rpx solid rgba(255,255,255,0.92);
  border-radius: var(--radius-xl);
  box-shadow: var(--glass-shadow);
  overflow: hidden;
  position: relative;
}

.card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, var(--accent), var(--accent-3), var(--accent-2));
  opacity: 0.75;
  pointer-events: none;
  z-index: 1;
}

.card-padding { padding: 32rpx; }

.card-solid {
  background: var(--glass-bg-strong);
  backdrop-filter: blur(14px) saturate(150%);
  -webkit-backdrop-filter: blur(14px) saturate(150%);
  border: 1rpx solid rgba(255,255,255,0.96);
  border-radius: var(--radius-xl);
  box-shadow: var(--glass-shadow);
  overflow: hidden;
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
  padding: 0 32rpx;
  height: 88rpx;
  border: none;
  transition: transform var(--motion-base) var(--ease-out), opacity var(--motion-fast), box-shadow var(--motion-base) var(--ease-out), background var(--motion-base), border-color var(--motion-base);
  position: relative;
  overflow: hidden;
}
.btn::after { border: none; }

.btn-primary {
  background: var(--accent-grad);
  color: #fff;
  box-shadow: 0 10rpx 26rpx rgba(255,90,61,0.26), 0 4rpx 12rpx rgba(124,58,237,0.14);
}
.btn-primary:active {
  opacity: 0.92;
  transform: translateY(2rpx) scale(0.975);
  box-shadow: 0 5rpx 16rpx rgba(255,90,61,0.22);
}

.btn-outline {
  background: rgba(255,90,61,0.08);
  color: var(--accent-text);
  border: 1.5rpx solid rgba(255,90,61,0.28);
}
.btn-outline:active { background: rgba(255,90,61,0.14); transform: scale(0.97); }

.btn-gray {
  background: rgba(37,26,52,0.06);
  color: var(--text-secondary);
  border: 1rpx solid rgba(37,26,52,0.12);
}
.btn-gray:active { background: rgba(37,26,52,0.10); transform: scale(0.97); }

.btn-danger {
  background: rgba(220,38,38,0.09);
  color: var(--danger);
  border: 1rpx solid rgba(220,38,38,0.22);
}

.btn-sm   { height: 64rpx; font-size: 26rpx; padding: 0 24rpx; border-radius: var(--radius-sm); }
.btn-lg   { height: 96rpx; font-size: 32rpx; border-radius: var(--radius-2xl); }
.btn-block { width: 100%; }
.btn[disabled] { opacity: 0.4; }

.form-group { margin-bottom: 32rpx; }

.form-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  letter-spacing: 0.5rpx;
}

.form-required { color: var(--danger); margin-left: 4rpx; font-size: 24rpx; }

.form-input {
  background: rgba(255,255,255,0.86);
  border: 1.5rpx solid rgba(255,90,61,0.16);
  border-radius: var(--radius-md);
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  width: 100%;
  box-sizing: border-box;
  transition: border-color var(--motion-base), box-shadow var(--motion-base), background var(--motion-base);
}
.form-input:focus {
  border-color: rgba(255,90,61,0.48);
  box-shadow: 0 0 0 5rpx rgba(255,90,61,0.11);
  background: #fff;
}

.form-textarea {
  background: rgba(255,255,255,0.86);
  border: 1.5rpx solid rgba(255,90,61,0.16);
  border-radius: var(--radius-md);
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  width: 100%;
  box-sizing: border-box;
  min-height: 160rpx;
}

.form-hint  { font-size: 22rpx; color: var(--text-muted); margin-top: 8rpx; }
.form-error { font-size: 22rpx; color: var(--danger);     margin-top: 8rpx; }

.picker-input { display: flex; align-items: center; justify-content: space-between; }
.picker-value       { color: var(--text-primary); }
.picker-placeholder { color: var(--text-muted); }

.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 600;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}
.tag-active   { background: var(--success-bg); color: var(--success); border: 1rpx solid rgba(5,150,105,0.2); }
.tag-ended    { background: rgba(30,27,75,0.06); color: var(--text-muted); border: 1rpx solid rgba(30,27,75,0.12); }
.tag-full     { background: var(--danger-bg);  color: var(--danger);  border: 1rpx solid rgba(220,38,38,0.18); }
.tag-upcoming { background: var(--warning-bg); color: var(--warning); border: 1rpx solid rgba(217,119,6,0.2); }

.divider { height: 1rpx; background: var(--divider); margin: 24rpx 0; }

.empty-state {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 80rpx 40rpx;
}
.empty-icon { font-size: 96rpx; margin-bottom: 24rpx; opacity: 0.5; }
.empty-text { font-size: 28rpx; font-weight: 600; color: var(--text-secondary); margin-bottom: 8rpx; }
.empty-sub  { font-size: 24rpx; color: var(--text-muted); text-align: center; }

.bottom-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: rgba(255,255,255,0.94);
  backdrop-filter: blur(16px) saturate(150%);
  -webkit-backdrop-filter: blur(16px) saturate(150%);
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(255,90,61,0.10);
  box-shadow: 0 -8rpx 28rpx rgba(255,90,61,0.10);
  z-index: 100;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  letter-spacing: 0.5rpx;
}
.section-title::before {
  content: '';
  width: 12rpx; height: 28rpx;
  background: var(--accent-grad-2);
  border-radius: 999rpx;
  margin-right: 16rpx;
}

@keyframes pulse {
  0%,100% { opacity: 1; }
  50%      { opacity: 0.5; }
}
@keyframes glow-pulse {
  0%,100% { box-shadow: 0 8rpx 24rpx rgba(255,90,61,0.26); }
  50%      { box-shadow: 0 12rpx 42rpx rgba(250,204,21,0.34); }
}
@keyframes slideUp {
  from { transform: translateY(40rpx); opacity: 0; }
  to   { transform: translateY(0);     opacity: 1; }
}
@keyframes slideDown {
  from { transform: translateY(-20rpx); opacity: 0; }
  to   { transform: translateY(0);      opacity: 1; }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes shimmer {
  0%   { background-position: -200% 0; }
  100% { background-position:  200% 0; }
}
@keyframes float {
  0%,100% { transform: translateY(0); }
  50%      { transform: translateY(-8rpx); }
}

.animate-slide-up   { animation: slideUp var(--motion-medium) var(--ease-out); }
.animate-slide-down { animation: slideDown var(--motion-medium) var(--ease-out); }
.animate-fade-in    { animation: fadeIn var(--motion-base) var(--ease-out); }

.skeleton-base {
  background: linear-gradient(90deg,
    rgba(255,90,61,0.05) 25%,
    rgba(255,90,61,0.14) 50%,
    rgba(124,58,237,0.06) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.8s infinite;
  border-radius: var(--radius-sm);
}

.pulse-dot {
  width: 14rpx; height: 14rpx;
  border-radius: 50%;
  background: var(--success);
  display: inline-block;
  margin-right: 8rpx;
  animation: pulse 2s infinite;
  box-shadow: 0 0 8rpx rgba(5,150,105,0.4);
}

.text-ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.text-ellipsis-2 {
  overflow: hidden; text-overflow: ellipsis;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
}

.mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(37,26,52,0.36);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  z-index: 200;
  animation: fadeIn 0.2s;
}

.safe-bottom { padding-bottom: env(safe-area-inset-bottom); }

/* 自定义导航：返回栏位置请用 utils/nav.js（与胶囊对齐），勿仅用 env(safe-area-inset-top) */

@media (prefers-reduced-motion: reduce) {
  .animate-slide-up,
  .animate-slide-down,
  .animate-fade-in,
  .skeleton-base,
  .pulse-dot {
    animation: none !important;
  }

  .btn,
  .card,
  .form-input,
  .form-textarea {
    transition: opacity var(--motion-fast), background var(--motion-fast), border-color var(--motion-fast) !important;
  }
}
