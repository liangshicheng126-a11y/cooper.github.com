# 后端环境变量配置
# 复制本文件为 .env 并填入真实值

# 服务器
PORT=3000
NODE_ENV=development

# 数据库
DB_HOST=localhost
DB_PORT=3306
DB_NAME=activity_miniapp
DB_USER=root
DB_PASSWORD=your_db_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_very_long_random_jwt_secret_key_here
JWT_EXPIRES_IN=30d

# 小程序 URL Link 打开环境：release | trial | develop（影响现场签到二维码跳转版本，默认 release）
# WX_MINI_ENV_VERSION=release

# 现场签到二维码：默认先尝试 URL Link（企业主体）。个人主体易报 85407 无 scheme 权限，可设为 minicode 直接使用无上限小程序码 + Redis（须配置 Redis）
# CHECKIN_QR_MODE=minicode

# 腾讯云
TENCENT_SECRET_ID=your_secret_id
TENCENT_SECRET_KEY=your_secret_key
TENCENT_REGION=ap-beijing

# 腾讯云 COS（对象存储，用于图片）
COS_BUCKET=your_bucket-1234567890
COS_REGION=ap-beijing

# 腾讯云 KMS（密钥管理）
KMS_KEY_ID=your_kms_key_id

# AES 加密（备用，优先使用 KMS）
AES_KEY=your_32_char_aes_key_here_00000000

# 短信服务（腾讯云 SMS）
SMS_APP_ID=your_sms_app_id
SMS_SIGN_NAME=您的签名
SMS_TEMPLATE_VERIFY=SMS_TEMPLATE_ID

# AI 海报生成（豆包 / 其他）
AI_POSTER_API_KEY=your_ai_api_key
AI_POSTER_API_URL=https://ark.cn-beijing.volces.com/api/v3/images/generations

# 管理员 OpenID 列表（逗号分隔）
ADMIN_OPENIDS=openid1,openid2

# 日志级别
LOG_LEVEL=info
